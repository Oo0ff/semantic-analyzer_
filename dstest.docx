# Core Configuration
determinism:
  base_seed: 42
  enable_stable_sort: true
  
performance:
  max_workers: 10
  buffer_size: 1000
  enable_memory_pool: true
  
processing:
  unicode_normalization: "NFC"
  enable_lowercase: true
  sentence_delimiters: [".", "!", "?"]
  
# Rule Definitions
rules:
  atomic:
    - id: "url_pattern"
      type: "regex"
      pattern: "https?://\S+|www\.\S+"
      weight: 1.0
      
    - id: "email_pattern"
      type: "regex"
      pattern: "\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b"
      weight: 0.8
  
  composite:
    proximity_window: 3  # sentences
    min_density: 0.3
    max_span: 10
    
# Semantic Networks
semantic_networks:
  topics:
    - name: "technology"
      keywords: ["software", "hardware", "algorithm", "database", "network"]
    - name: "business"
      keywords: ["revenue", "profit", "market", "strategy", "investment"]
      
# Output Configuration
output:
  enable_audit_trail: true
  pretty_print_json: false
  include_confidence_scores: true
```

