package semantic_test

import (
    "testing"
    
    "semantic-analyzer/internal/engine/semantic"
    "semantic-analyzer/pkg/config"
)

func TestNEREngine_ExtractPersons(t *testing.T) {
    // Create NER configuration
    nerConfig := config.NERConfig{
        PersonTitles: []string{"Mr.", "Ms.", "Dr.", "Prof."},
        PersonPatterns: []config.RegexRuleConfig{
            {
                ID:      "person_name",
                Pattern: `\b(?:Mr\.|Ms\.|Dr\.|Prof\.)\s+[A-Z][a-z]+\s+[A-Z][a-z]+\b`,
                Weight:  0.9,
                Type:    "PERSON",
                Level:   3,
                Name:    "Person Name",
            },
        },
    }
    
    engine, err := semantic.NewNEREngine(nerConfig)
    if err != nil {
        t.Fatalf("Failed to create NER engine: %v", err)
    }
    
    // Test text with person names
    text := "Please contact Dr. John Smith or Ms. Jane Doe for more information."
    
    entities := engine.ExtractEntities(text)
    
    personCount := 0
    for _, entity := range entities {
        if entity.Type == "PERSON" {
            personCount++
            if entity.Text != "Dr. John Smith" && entity.Text != "Ms. Jane Doe" {
                t.Errorf("Unexpected person entity: %s", entity.Text)
            }
        }
    }
    
    if personCount != 2 {
        t.Errorf("Expected 2 person entities, got %d", personCount)
    }
}

func TestNEREngine_ExtractOrganizations(t *testing.T) {
    nerConfig := config.NERConfig{
        OrganizationSuffixes: []string{"Inc.", "Corp.", "LLC"},
        OrganizationPatterns: []config.RegexRuleConfig{
            {
                ID:      "organization_name",
                Pattern: `\b[A-Z][A-Za-z0-9&\s]+(?:Inc\.|Corp\.|LLC)\b`,
                Weight:  0.8,
                Type:    "ORGANIZATION",
                Level:   3,
                Name:    "Organization Name",
            },
        },
    }
    
    engine, err := semantic.NewNEREngine(nerConfig)
    if err != nil {
        t.Fatalf("Failed to create NER engine: %v", err)
    }
    
    text := "Our partners include Apple Inc. and Google LLC."
    
    entities := engine.ExtractEntities(text)
    
    orgCount := 0
    for _, entity := range entities {
        if entity.Type == "ORGANIZATION" {
            orgCount++
            if entity.Confidence < 0.5 {
                t.Errorf("Organization entity confidence too low: %f", entity.Confidence)
            }
        }
    }
    
    if orgCount < 1 {
        t.Errorf("Expected at least 1 organization entity, got %d", orgCount)
    }
}

func TestNEREngine_ExtractLocations(t *testing.T) {
    nerConfig := config.NERConfig{
        LocationKeywords: []string{"street", "city", "state"},
        LocationPatterns: []string{
            `\b[A-Z][a-z]+(?:[ -][A-Z][a-z]+)*\b`,
        },
    }
    
    engine, err := semantic.NewNEREngine(nerConfig)
    if err != nil {
        t.Fatalf("Failed to create NER engine: %v", err)
    }
    
    text := "Our office is located at 123 Main Street in New York City."
    
    entities := engine.ExtractEntities(text)
    
    locationCount := 0
    for _, entity := range entities {
        if entity.Type == "LOCATION" {
            locationCount++
            if entity.Confidence < 0.3 {
                t.Errorf("Location entity confidence too low: %f", entity.Confidence)
            }
        }
    }
    
    if locationCount < 1 {
        t.Errorf("Expected at least 1 location entity, got %d", locationCount)
    }
}

func TestNEREngine_OverlapRemoval(t *testing.T) {
    nerConfig := config.NERConfig{
        PersonTitles: []string{"Dr."},
    }
    
    engine, err := semantic.NewNEREngine(nerConfig)
    if err != nil {
        t.Fatalf("Failed to create NER engine: %v", err)
    }
    
    // Text with overlapping patterns
    text := "Dr. John Smith Dr. John Smith" // Duplicate
    
    entities := engine.ExtractEntities(text)
    
    // Should have removed duplicates or overlapping entities
    uniqueTexts := make(map[string]bool)
    for _, entity := range entities {
        if uniqueTexts[entity.Text] {
            t.Errorf("Duplicate entity found: %s", entity.Text)
        }
        uniqueTexts[entity.Text] = true
    }
}

func BenchmarkNEREngine_ExtractEntities(b *testing.B) {
    nerConfig := config.NERConfig{
        PersonTitles:        []string{"Mr.", "Ms.", "Dr."},
        OrganizationSuffixes: []string{"Inc.", "LLC"},
        LocationKeywords:    []string{"street", "city"},
        PersonPatterns: []config.RegexRuleConfig{
            {
                ID:      "person_name",
                Pattern: `\b(?:Mr\.|Ms\.|Dr\.)\s+[A-Z][a-z]+\s+[A-Z][a-z]+\b`,
                Weight:  0.9,
                Type:    "PERSON",
                Level:   3,
                Name:    "Person Name",
            },
        },
    }
    
    engine, err := semantic.NewNEREngine(nerConfig)
    if err != nil {
        b.Fatalf("Failed to create NER engine: %v", err)
    }
    
    // Create test text
    text := `Mr. John Doe from ABC Inc. visited our office at 123 Main Street. 
             Please contact Dr. Jane Smith for more information about New York City projects.`
    
    b.ResetTimer()
    for i := 0; i < b.N; i++ {
        engine.ExtractEntities(text)
    }
}
```

### **internal/engine/semantic/proximity_analyzer_test.go**
```go
package semantic_test

import (
    "testing"
    
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/engine/semantic"
    "semantic-analyzer/pkg/config"
)

func TestProximityAnalyzer_CalculateSemanticRelatedness(t *testing.T) {
    // Create semantic configuration
    semanticConfig := config.SemanticRulesConfig{
        Networks: map[string][]string{
            "technology": {"software", "hardware", "algorithm"},
            "business":   {"revenue", "profit", "market"},
        },
        ProximityWeights: config.ProximityWeights{
            NetworkMatch:   0.5,
            TypeSimilarity: 0.3,
            ContextOverlap: 0.2,
        },
    }
    
    analyzer := semantic.NewProximityAnalyzer(semanticConfig)
    
    // Create test markers
    marker1 := domain.NewMarker(1, "TECH", "software development", 0, 10, 0.8, "r1", true)
    marker2 := domain.NewMarker(1, "TECH", "hardware design", 20, 30, 0.7, "r2", true)
    marker3 := domain.NewMarker(1, "BUSINESS", "revenue growth", 40, 50, 0.9, "r3", true)
    
    // Test similar markers (both in technology network)
    relatedness1 := analyzer.CalculateSemanticRelatedness(*marker1, *marker2)
    if relatedness1 < 0.3 {
        t.Errorf("Expected high relatedness between technology markers, got %f", relatedness1)
    }
    
    // Test different markers (different networks)
    relatedness2 := analyzer.CalculateSemanticRelatedness(*marker1, *marker3)
    if relatedness2 > 0.5 {
        t.Errorf("Expected low relatedness between different network markers, got %f", relatedness2)
    }
    
    // Test same marker
    relatedness3 := analyzer.CalculateSemanticRelatedness(*marker1, *marker1)
    if relatedness3 != 1.0 {
        t.Errorf("Expected relatedness of 1.0 for same marker, got %f", relatedness3)
    }
}

func TestProximityAnalyzer_FindRelatedMarkers(t *testing.T) {
    semanticConfig := config.SemanticRulesConfig{
        Networks: map[string][]string{
            "contact": {"email", "phone", "contact"},
            "urgency": {"urgent", "immediate", "priority"},
        },
        ProximityWeights: config.ProximityWeights{
            NetworkMatch:   0.6,
            TypeSimilarity: 0.4,
        },
    }
    
    analyzer := semantic.NewProximityAnalyzer(semanticConfig)
    
    // Create target marker
    target := domain.NewMarker(1, "CONTACT", "email contact", 0, 10, 0.9, "r1", true)
    
    // Create other markers
    markers := []domain.Marker{
        *domain.NewMarker(1, "CONTACT", "phone number", 20, 30, 0.8, "r2", true),
        *domain.NewMarker(1, "URGENCY", "urgent matter", 40, 50, 0.7, "r3", true),
        *domain.NewMarker(1, "OTHER", "unrelated text", 60, 70, 0.5, "r4", true),
    }
    
    // Find related markers
    related := analyzer.FindRelatedMarkers(*target, markers, 0.4)
    
    // Should find contact-related markers
    if len(related) < 1 {
        t.Errorf("Expected at least 1 related marker, got %d", len(related))
    }
    
    for _, rel := range related {
        if rel.Relatedness < 0.4 {
            t.Errorf("Relatedness below threshold: %f", rel.Relatedness)
        }
    }
}

func TestProximityAnalyzer_CalculateClusterCohesion(t *testing.T) {
    semanticConfig := config.SemanticRulesConfig{
        Networks: map[string][]string{
            "project": {"timeline", "deadline", "milestone"},
        },
    }
    
    analyzer := semantic.NewProximityAnalyzer(semanticConfig)
    
    // Create cohesive cluster
    cohesiveMarkers := []domain.Marker{
        *domain.NewMarker(1, "PROJECT", "project timeline", 0, 10, 0.8, "r1", true),
        *domain.NewMarker(1, "PROJECT", "deadline approaching", 20, 30, 0.7, "r2", true),
        *domain.NewMarker(1, "PROJECT", "milestone reached", 40, 50, 0.9, "r3", true),
    }
    
    cohesion1 := analyzer.CalculateClusterCohesion(cohesiveMarkers)
    if cohesion1 < 0.5 {
        t.Errorf("Expected high cohesion for similar markers, got %f", cohesion1)
    }
    
    // Create non-cohesive cluster
    diverseMarkers := []domain.Marker{
        *domain.NewMarker(1, "PROJECT", "timeline", 0, 10, 0.8, "r1", true),
        *domain.NewMarker(1, "CONTACT", "email", 20, 30, 0.7, "r2", true),
        *domain.NewMarker(1, "URGENCY", "urgent", 40, 50, 0.9, "r3", true),
    }
    
    cohesion2 := analyzer.CalculateClusterCohesion(diverseMarkers)
    if cohesion2 > 0.5 {
        t.Errorf("Expected low cohesion for diverse markers, got %f", cohesion2)
    }
}

func BenchmarkProximityAnalyzer_CalculateSemanticRelatedness(b *testing.B) {
    semanticConfig := config.SemanticRulesConfig{
        Networks: map[string][]string{
            "tech":    {"software", "code", "algorithm", "database", "server"},
            "biz":     {"business", "revenue", "profit", "market", "strategy"},
            "project": {"timeline", "deadline", "milestone", "deliverable"},
        },
        ProximityWeights: config.ProximityWeights{
            NetworkMatch:   0.4,
            TypeSimilarity: 0.3,
            ContextOverlap: 0.3,
        },
    }
    
    analyzer := semantic.NewProximityAnalyzer(semanticConfig)
    
    marker1 := domain.NewMarker(1, "TECH", "software development project", 0, 10, 0.8, "r1", true)
    marker2 := domain.NewMarker(1, "PROJECT", "project timeline and deadlines", 20, 30, 0.7, "r2", true)
    
    b.ResetTimer()
    for i := 0; i < b.N; i++ {
        analyzer.CalculateSemanticRelatedness(*marker1, *marker2)
    }
}
