### **test/integration_test.go**
```go
package integration_test

import (
    "bytes"
    "crypto/md5"
    "encoding/hex"
    "encoding/json"
    "os"
    "path/filepath"
    "testing"
    "time"

    "semantic-analyzer/cmd/pipeline"
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
    "semantic-analyzer/pkg/determinism"
)

func TestFullPipelineDeterminism(t *testing.T) {
    // Create test configuration
    cfg := config.GetTestConfig()
    cfg.Determinism.BaseSeed = 42
    
    // Create test transcript
    transcript := &domain.Transcript{
        ID:        "test_transcript",
        RawText:   "Contact us at test@example.com for urgent matters. Call 123-456-7890.",
        Source:    "test.txt",
        CreatedAt: time.Now(),
    }
    
    // Run pipeline multiple times
    var firstOutput []byte
    hashes := make(map[string]int)
    
    for i := 0; i < 100; i++ {
        // Create new pipeline for each run
        p := pipeline.NewPipeline(cfg)
        
        // Execute pipeline
        result, err := p.Execute(context.Background(), transcript)
        if err != nil {
            t.Fatalf("Pipeline execution failed at iteration %d: %v", i, err)
        }
        
        // Convert result to JSON
        output, err := json.Marshal(result)
        if err != nil {
            t.Fatalf("Failed to marshal result at iteration %d: %v", i, err)
        }
        
        // Calculate hash
        hash := md5.Sum(output)
        hashStr := hex.EncodeToString(hash[:])
        hashes[hashStr]++
        
        // Store first output
        if i == 0 {
            firstOutput = output
        } else {
            // Compare with first output
            if !bytes.Equal(output, firstOutput) {
                t.Errorf("Output mismatch at iteration %d", i)
            }
        }
    }
    
    // Verify all hashes are identical
    if len(hashes) != 1 {
        t.Errorf("Expected 1 unique hash, got %d", len(hashes))
    }
}

func TestPipelinePerformance(t *testing.T) {
    // Create large test text
    var builder bytes.Buffer
    for i := 0; i < 10000; i++ {
        builder.WriteString("Test sentence with contact@example.com and urgent keyword. ")
    }
    
    cfg := config.GetTestConfig()
    transcript := &domain.Transcript{
        ID:      "performance_test",
        RawText: builder.String(),
        Source:  "performance.txt",
    }
    
    // Run pipeline
    startTime := time.Now()
    
    p := pipeline.NewPipeline(cfg)
    result, err := p.Execute(context.Background(), transcript)
    
    duration := time.Since(startTime)
    
    if err != nil {
        t.Fatalf("Pipeline execution failed: %v", err)
    }
    
    // Check performance target (30 seconds)
    if duration > 30*time.Second {
        t.Errorf("Pipeline took %v, exceeds 30 second target", duration)
    }
    
    // Verify results
    if result.Statistics.TotalMarkers == 0 {
        t.Error("Expected markers to be detected")
    }
    
    t.Logf("Processed %d words in %v", transcript.TokenCount, duration)
}

func TestMemoryLeakDetection(t *testing.T) {
    cfg := config.GetTestConfig()
    
    // Create test transcript
    transcript := &domain.Transcript{
        ID:      "memory_test",
        RawText: "Test text for memory leak detection.",
        Source:  "memory.txt",
    }
    
    // Run pipeline multiple times to detect memory leaks
    var pipelines []*pipeline.Pipeline
    
    for i := 0; i < 1000; i++ {
        p := pipeline.NewPipeline(cfg)
        pipelines = append(pipelines, p)
        
        _, err := p.Execute(context.Background(), transcript)
        if err != nil {
            t.Logf("Iteration %d: %v", i, err)
        }
        
        // Reset pipeline to clear state
        p.Reset()
        
        // Force garbage collection every 100 iterations
        if i%100 == 0 {
            runtime.GC()
        }
    }
    
    // Check memory usage
    var memStats runtime.MemStats
    runtime.ReadMemStats(&memStats)
    
    t.Logf("Memory after 1000 iterations: %.2f MB", 
        float64(memStats.Alloc)/1024/1024)
}

func TestErrorHandling(t *testing.T) {
    cfg := config.GetTestConfig()
    
    testCases := []struct {
        name      string
        text      string
        expectErr bool
    }{
        {
            name:      "empty_text",
            text:      "",
            expectErr: true,
        },
        {
            name:      "valid_text",
            text:      "Valid text with email@example.com",
            expectErr: false,
        },
        {
            name:      "large_text",
            text:      string(make([]byte, 2*1024*1024)), // 2MB
            expectErr: true,
        },
    }
    
    for _, tc := range testCases {
        t.Run(tc.name, func(t *testing.T) {
            transcript := &domain.Transcript{
                ID:      tc.name,
                RawText: tc.text,
                Source:  "test.txt",
            }
            
            p := pipeline.NewPipeline(cfg)
            _, err := p.Execute(context.Background(), transcript)
            
            if tc.expectErr && err == nil {
                t.Error("Expected error but got none")
            }
            if !tc.expectErr && err != nil {
                t.Errorf("Unexpected error: %v", err)
            }
        })
    }
}

func TestConfigurationValidation(t *testing.T) {
    testConfigs := []struct {
        name   string
        config func() *config.Config
        valid  bool
    }{
        {
            name: "valid_config",
            config: func() *config.Config {
                return config.GetTestConfig()
            },
            valid: true,
        },
        {
            name: "invalid_seed",
            config: func() *config.Config {
                cfg := config.GetTestConfig()
                cfg.Determinism.BaseSeed = -1
                return cfg
            },
            valid: false,
        },
        {
            name: "invalid_threshold",
            config: func() *config.Config {
                cfg := config.GetTestConfig()
                cfg.Quality.Confidence.MinThreshold = -0.1
                return cfg
            },
            valid: false,
        },
    }
    
    for _, tc := range testConfigs {
        t.Run(tc.name, func(t *testing.T) {
            cfg := tc.config()
            
            // Try to create pipeline
            p := pipeline.NewPipeline(cfg)
            
            // Test with simple transcript
            transcript := &domain.Transcript{
                ID:      "config_test",
                RawText: "Test text",
                Source:  "test.txt",
            }
            
            _, err := p.Execute(context.Background(), transcript)
            
            if tc.valid && err != nil {
                t.Errorf("Expected valid config but got error: %v", err)
            }
            if !tc.valid && err == nil {
                t.Error("Expected error for invalid config but got none")
            }
        })
    }
}
