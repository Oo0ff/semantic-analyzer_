    // Processing defaults
    viper.SetDefault("processing.unicode_normalization", "NFC")
    viper.SetDefault("processing.enable_lowercase", true)
    viper.SetDefault("processing.sentence_delimiters", []string{".", "!", "?", ";", ":"})
    viper.SetDefault("processing.preserve_whitespace", false)
    viper.SetDefault("processing.max_sentence_length", 1000)
    viper.SetDefault("processing.remove_punctuation", false)
    viper.SetDefault("processing.stop_words", []string{
        "the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for",
