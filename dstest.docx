## **2. Phase 4: Composite Aggregation**

### **internal/engine/composite/types.go**
```go
package composite

import "semantic-analyzer/internal/domain"

// CompositeCandidate represents a candidate for composite marker formation
type CompositeCandidate struct {
    ID           string           `json:"id"`
    Markers      []domain.Marker  `json:"markers"`
    Score        float64          `json:"score"`
    SpanStart    int              `json:"span_start"`
    SpanEnd      int              `json:"span_end"`
    SentenceIDs  []int            `json:"sentence_ids"`
    Density      float64          `json:"density"`
    TypeDiversity float64         `json:"type_diversity"`
    SpanLength   int              `json:"span_length"`
    MarkerCount  int              `json:"marker_count"`
    PrimaryType  string           `json:"primary_type"`
    Confidence   float64          `json:"confidence"`
    Context      string           `json:"context,omitempty"`
    Metadata     map[string]interface{} `json:"metadata,omitempty"`
}

// ContextWindow represents a window of text for composite analysis
type ContextWindow struct {
    ID          string           `json:"id"`
    StartPos    int              `json:"start_pos"`
    EndPos      int              `json:"end_pos"`
    Text        string           `json:"text"`
    Markers     []domain.Marker  `json:"markers"`
    SentenceIDs []int            `json:"sentence_ids"`
    SentenceCount int            `json:"sentence_count"`
    WindowSize  int              `json:"window_size"`
}

// NewCompositeCandidate creates a new composite candidate
func NewCompositeCandidate(id string, markers []domain.Marker, spanStart, spanEnd int, sentenceIDs []int) *CompositeCandidate {
    spanLength := spanEnd - spanStart
    density := 0.0
    if spanLength > 0 {
        density = float64(len(markers)) / float64(spanLength)
    }
    
    // Calculate type diversity
    typeCount := make(map[string]int)
    for _, marker := range markers {
        typeCount[marker.Type]++
    }
    typeDiversity := float64(len(typeCount)) / float64(len(markers))
    
    // Find primary type
    primaryType := ""
    maxCount := 0
    for t, count := range typeCount {
        if count > maxCount {
            maxCount = count
            primaryType = t
        }
    }
    
    return &CompositeCandidate{
        ID:            id,
        Markers:       markers,
        SpanStart:     spanStart,
        SpanEnd:       spanEnd,
        SpanLength:    spanLength,
        SentenceIDs:   sentenceIDs,
        Density:       density,
        TypeDiversity: typeDiversity,
        MarkerCount:   len(markers),
        PrimaryType:   primaryType,
        Confidence:    0.0, // Will be set by scorer
        Metadata:      make(map[string]interface{}),
    }
}

// AddMarker adds a marker to the candidate
func (cc *CompositeCandidate) AddMarker(marker domain.Marker) {
    cc.Markers = append(cc.Markers, marker)
    cc.MarkerCount++
    
    // Update span if needed
    if marker.Start < cc.SpanStart {
        cc.SpanStart = marker.Start
    }
    if marker.End > cc.SpanEnd {
        cc.SpanEnd = marker.End
    }
    
    cc.SpanLength = cc.SpanEnd - cc.SpanStart
    if cc.SpanLength > 0 {
        cc.Density = float64(cc.MarkerCount) / float64(cc.SpanLength)
    }
    
    // Update type diversity
    typeCount := make(map[string]int)
    for _, m := range cc.Markers {
        typeCount[m.Type]++
    }
    cc.TypeDiversity = float64(len(typeCount)) / float64(cc.MarkerCount)
    
    // Update primary type
    maxCount := 0
    for t, count := range typeCount {
        if count > maxCount {
            maxCount = count
            cc.PrimaryType = t
        }
    }
}

// Overlaps checks if this candidate overlaps with another candidate
func (cc *CompositeCandidate) Overlaps(other *CompositeCandidate, threshold float64) bool {
    overlapStart := max(cc.SpanStart, other.SpanStart)
    overlapEnd := min(cc.SpanEnd, other.SpanEnd)
    
    if overlapStart >= overlapEnd {
        return false
    }
    
    overlapLength := overlapEnd - overlapStart
    minSpan := min(cc.SpanLength, other.SpanLength)
    
    return float64(overlapLength)/float64(minSpan) >= threshold
}

// ContainsMarker checks if the candidate contains a specific marker
func (cc *CompositeCandidate) ContainsMarker(markerID string) bool {
    for _, m := range cc.Markers {
        if m.ID == markerID {
            return true
        }
    }
    return false
}

// GetMarkerTypes returns all unique marker types in the candidate
func (cc *CompositeCandidate) GetMarkerTypes() []string {
    typeSet := make(map[string]bool)
    for _, m := range cc.Markers {
        typeSet[m.Type] = true
    }
    
    types := make([]string, 0, len(typeSet))
    for t := range typeSet {
        types = append(types, t)
    }
    return types
}

// GetAverageConfidence calculates the average confidence of markers
func (cc *CompositeCandidate) GetAverageConfidence() float64 {
    if cc.MarkerCount == 0 {
        return 0.0
    }
    
    total := 0.0
    for _, m := range cc.Markers {
        total += m.Confidence
    }
    return total / float64(cc.MarkerCount)
}

// Helper functions
func min(a, b int) int {
    if a < b {
        return a
    }
    return b
}

func max(a, b int) int {
    if a > b {
        return a
    }
    return b
}
```

### **internal/engine/composite/builder.go**
```go
package composite

import (
    "fmt"
    "sort"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
)

// Builder constructs composite candidates from atomic markers
type Builder struct {
    config        config.CompositeRulesConfig
    seedManager   interface{} // Placeholder for seed manager
    auditEvents   []domain.AuditEvent
}

// NewBuilder creates a new composite builder
func NewBuilder(cfg config.CompositeRulesConfig) *Builder {
    return &Builder{
        config:      cfg,
        auditEvents: []domain.AuditEvent{},
    }
}

// BuildContextWindows builds context windows from atomic markers and sentences
func (b *Builder) BuildContextWindows(atomicMarkers []domain.Marker, sentences []string) []CompositeCandidate {
    startTime := time.Now()
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("composite_builder", "build_context_windows")
    auditEvent.AddData("atomic_markers", len(atomicMarkers))
    auditEvent.AddData("sentences", len(sentences))
    auditEvent.AddData("proximity_window", b.config.ProximityWindow)
    b.addAuditEvent(auditEvent)
    
    // Group markers by sentence
    sentenceMarkers := b.groupMarkersBySentence(atomicMarkers, sentences)
    
    // Build context windows
    windows := b.buildWindows(sentenceMarkers, sentences)
    
    // Create candidates from windows
    candidates := b.windowsToCandidates(windows)
    
    // Filter candidates by minimum density
    filteredCandidates := b.filterByDensity(candidates)
    
    // Create final audit event
    endEvent := domain.NewAuditEvent("composite_builder", "complete")
    endEvent.AddData("windows_built", len(windows))
    endEvent.AddData("candidates_created", len(candidates))
    endEvent.AddData("candidates_filtered", len(filteredCandidates))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    b.addAuditEvent(endEvent)
    
    return filteredCandidates
}

// groupMarkersBySentence groups markers by the sentence they appear in
func (b *Builder) groupMarkersBySentence(markers []domain.Marker, sentences []string) [][]domain.Marker {
    sentenceMarkers := make([][]domain.Marker, len(sentences))
    
    for _, marker := range markers {
        // Find which sentence contains this marker
        for i, sentence := range sentences {
            // Simple containment check - in production, use proper sentence boundaries
            if strings.Contains(sentence, marker.TextSpan) {
                sentenceMarkers[i] = append(sentenceMarkers[i], marker)
                break
            }
        }
    }
    
    return sentenceMarkers
}

// buildWindows builds context windows based on proximity
func (b *Builder) buildWindows(sentenceMarkers [][]domain.Marker, sentences []string) []ContextWindow {
    var windows []ContextWindow
    
    for i := 0; i < len(sentenceMarkers); i++ {
        // Create window starting at sentence i
        windowEnd := min(i+b.config.ProximityWindow, len(sentenceMarkers))
        
        // Collect all markers in this window
        var windowMarkers []domain.Marker
        var windowSentenceIDs []int
        markerSet := make(map[string]bool) // To avoid duplicates
        
        for j := i; j < windowEnd; j++ {
            for _, marker := range sentenceMarkers[j] {
                if !markerSet[marker.ID] {
                    windowMarkers = append(windowMarkers, marker)
                    markerSet[marker.ID] = true
                }
            }
            windowSentenceIDs = append(windowSentenceIDs, j)
        }
        
        // Only create window if it has markers
        if len(windowMarkers) >= 2 {
            // Calculate window span
            spanStart, spanEnd := b.calculateWindowSpan(windowMarkers)
            
            // Get window text
            windowText := b.getWindowText(sentences, i, windowEnd)
            
            window := ContextWindow{
                ID:           fmt.Sprintf("window_%d_%d", i, windowEnd),
                StartPos:     spanStart,
                EndPos:       spanEnd,
                Text:         windowText,
                Markers:      windowMarkers,
                SentenceIDs:  windowSentenceIDs,
                SentenceCount: windowEnd - i,
                WindowSize:   b.config.ProximityWindow,
            }
            
            windows = append(windows, window)
        }
    }
    
    return windows
}

// calculateWindowSpan calculates the span of a window based on its markers
func (b *Builder) calculateWindowSpan(markers []domain.Marker) (int, int) {
    if len(markers) == 0 {
        return 0, 0
    }
    
    start := markers[0].Start
    end := markers[0].End
    
    for _, marker := range markers {
        if marker.Start < start {
            start = marker.Start
        }
        if marker.End > end {
            end = marker.End
        }
    }
    
    // Apply max span constraint
    if end-start > b.config.MaxSpan {
        end = start + b.config.MaxSpan
    }
    
    return start, end
}

// getWindowText extracts text for a window from sentences
func (b *Builder) getWindowText(sentences []string, start, end int) string {
    if start >= end || start >= len(sentences) {
        return ""
    }
    
    if end > len(sentences) {
        end = len(sentences)
    }
    
    return strings.Join(sentences[start:end], " ")
}

// windowsToCandidates converts windows to composite candidates
func (b *Builder) windowsToCandidates(windows []ContextWindow) []CompositeCandidate {
    var candidates []CompositeCandidate
    
    for i, window := range windows {
        candidate := NewCompositeCandidate(
            fmt.Sprintf("candidate_%d", i),
            window.Markers,
            window.StartPos,
            window.EndPos,
            window.SentenceIDs,
        )
        
        // Add window metadata
        candidate.Metadata["window_id"] = window.ID
        candidate.Metadata["sentence_count"] = window.SentenceCount
        candidate.Metadata["window_text"] = window.Text
        candidate.Metadata["window_size"] = window.WindowSize
        
        candidates = append(candidates, *candidate)
    }
    
    return candidates
}

// filterByDensity filters candidates by minimum density
func (b *Builder) filterByDensity(candidates []CompositeCandidate) []CompositeCandidate {
    var filtered []CompositeCandidate
    
    for _, candidate := range candidates {
        if candidate.Density >= b.config.MinDensity {
            filtered = append(filtered, candidate)
        }
    }
    
    return filtered
}

// MergeSimilarCandidates merges similar candidates to reduce redundancy
func (b *Builder) MergeSimilarCandidates(candidates []CompositeCandidate, similarityThreshold float64) []CompositeCandidate {
    if len(candidates) <= 1 {
        return candidates
    }
    
    // Sort candidates by span start for consistent merging
    sort.Slice(candidates, func(i, j int) bool {
        if candidates[i].SpanStart == candidates[j].SpanStart {
            return candidates[i].SpanEnd < candidates[j].SpanEnd
        }
        return candidates[i].SpanStart < candidates[j].SpanStart
    })
    
    var merged []CompositeCandidate
    mergedSet := make(map[int]bool)
    
    for i := 0; i < len(candidates); i++ {
        if mergedSet[i] {
            continue
        }
        
        current := candidates[i]
        mergedIndices := []int{i}
        
        // Find similar candidates to merge with current
        for j := i + 1; j < len(candidates); j++ {
            if mergedSet[j] {
                continue
            }
            
            if current.Overlaps(&candidates[j], similarityThreshold) {
                mergedIndices = append(mergedIndices, j)
            }
        }
        
        // Merge candidates if we found similar ones
        if len(mergedIndices) > 1 {
            mergedCandidate := b.mergeCandidateGroup(candidates, mergedIndices)
            merged = append(merged, mergedCandidate)
            
            // Mark all merged indices as processed
            for _, idx := range mergedIndices {
                mergedSet[idx] = true
            }
        } else {
            // Keep candidate as-is
            merged = append(merged, current)
            mergedSet[i] = true
        }
    }
    
    return merged
}

// mergeCandidateGroup merges a group of similar candidates
func (b *Builder) mergeCandidateGroup(candidates []CompositeCandidate, indices []int) CompositeCandidate {
    if len(indices) == 0 {
        return CompositeCandidate{}
    }
    
    // Collect all markers from the group
    var allMarkers []domain.Marker
    markerSet := make(map[string]bool)
    var allSentenceIDs []int
    sentenceIDSet := make(map[int]bool)
    
    spanStart := candidates[indices[0]].SpanStart
    spanEnd := candidates[indices[0]].SpanEnd
    
    for _, idx := range indices {
        candidate := candidates[idx]
        
        // Update span
        if candidate.SpanStart < spanStart {
            spanStart = candidate.SpanStart
        }
        if candidate.SpanEnd > spanEnd {
            spanEnd = candidate.SpanEnd
        }
        
        // Collect unique markers
        for _, marker := range candidate.Markers {
            if !markerSet[marker.ID] {
                allMarkers = append(allMarkers, marker)
                markerSet[marker.ID] = true
            }
        }
        
        // Collect unique sentence IDs
        for _, sid := range candidate.SentenceIDs {
            if !sentenceIDSet[sid] {
                allSentenceIDs = append(allSentenceIDs, sid)
                sentenceIDSet[sid] = true
            }
        }
    }
    
    // Sort sentence IDs
    sort.Ints(allSentenceIDs)
    
    // Create merged candidate
    merged := NewCompositeCandidate(
        fmt.Sprintf("merged_%d", time.Now().UnixNano()),
        allMarkers,
        spanStart,
        spanEnd,
        allSentenceIDs,
    )
    
    // Add metadata about merging
    merged.Metadata["merged_from"] = indices
    merged.Metadata["original_candidate_count"] = len(indices)
    merged.Metadata["merge_timestamp"] = time.Now().Format(time.RFC3339)
    
    return *merged
}

// addAuditEvent adds an audit event
func (b *Builder) addAuditEvent(event *domain.AuditEvent) {
    b.auditEvents = append(b.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (b *Builder) GetAuditEvents() []domain.AuditEvent {
    return b.auditEvents
}
```

### **internal/engine/composite/scorer.go**
```go
package composite

import (
    "math"
    "sort"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
)

// Scorer calculates scores for composite candidates
type Scorer struct {
    config      config.CompositeRulesConfig
    auditEvents []domain.AuditEvent
}

// NewScorer creates a new composite scorer
func NewScorer(cfg config.CompositeRulesConfig) *Scorer {
    return &Scorer{
        config:      cfg,
        auditEvents: []domain.AuditEvent{},
    }
}

// ScoreCandidate calculates a score for a composite candidate
func (s *Scorer) ScoreCandidate(candidate CompositeCandidate) float64 {
    startTime := time.Now()
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("composite_scorer", "score_candidate")
    auditEvent.AddData("candidate_id", candidate.ID)
    auditEvent.AddData("marker_count", candidate.MarkerCount)
    auditEvent.AddData("span_length", candidate.SpanLength)
    s.addAuditEvent(auditEvent)
    
    // Calculate individual components
    markerCountScore := s.scoreMarkerCount(candidate)
    densityScore := s.scoreDensity(candidate)
    spanCompactnessScore := s.scoreSpanCompactness(candidate)
    typeDiversityScore := s.scoreTypeDiversity(candidate)
    typeWeightScore := s.scoreTypeWeights(candidate)
    confidenceScore := s.scoreConfidence(candidate)
    
    // Calculate weighted total
    totalScore := (markerCountScore * s.config.SelectionWeights.MarkerCount) +
                  (densityScore * s.config.SelectionWeights.Density) +
                  (spanCompactnessScore * s.config.SelectionWeights.SpanCompactness) +
                  (typeDiversityScore * s.config.SelectionWeights.TypeDiversity) +
                  (typeWeightScore * 0.2) + // Additional weight for type importance
                  (confidenceScore * 0.1)   // Additional weight for confidence
    
    // Normalize score to [0, 1]
    normalizedScore := math.Min(math.Max(totalScore, 0.0), 1.0)
    
    // Update candidate
    candidate.Score = normalizedScore
    candidate.Confidence = normalizedScore
    
    // Add scoring details to metadata
    candidate.Metadata["scoring_components"] = map[string]float64{
        "marker_count":      markerCountScore,
        "density":           densityScore,
        "span_compactness":  spanCompactnessScore,
        "type_diversity":    typeDiversityScore,
        "type_weight":       typeWeightScore,
        "confidence":        confidenceScore,
        "weights_applied": map[string]float64{
            "marker_count":      s.config.SelectionWeights.MarkerCount,
            "density":           s.config.SelectionWeights.Density,
            "span_compactness":  s.config.SelectionWeights.SpanCompactness,
            "type_diversity":    s.config.SelectionWeights.TypeDiversity,
        },
    }
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("composite_scorer", "candidate_scored")
    endEvent.AddData("candidate_id", candidate.ID)
    endEvent.AddData("final_score", normalizedScore)
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    s.addAuditEvent(endEvent)
    
    return normalizedScore
}

// scoreMarkerCount scores based on the number of markers
func (s *Scorer) scoreMarkerCount(candidate CompositeCandidate) float64 {
    // Ideal marker count is between 3 and 6
    idealMin := 3
    idealMax := 6
    
    if candidate.MarkerCount < 2 {
        return 0.1 // Very low score for too few markers
    }
    
    if candidate.MarkerCount >= idealMin && candidate.MarkerCount <= idealMax {
        return 1.0 // Perfect score for ideal range
    }
    
    if candidate.MarkerCount > idealMax {
        // Gradually decrease score for too many markers
        excess := candidate.MarkerCount - idealMax
        penalty := float64(excess) * 0.1
        return math.Max(0.3, 1.0-penalty)
    }
    
    // For 2 markers (just above minimum)
    return 0.5
}

// scoreDensity scores based on marker density
func (s *Scorer) scoreDensity(candidate CompositeCandidate) float64 {
    if candidate.SpanLength == 0 {
        return 0.0
    }
    
    // Normalize density to [0, 1]
    // Assuming density of 0.01 (1 marker per 100 chars) is good baseline
    baselineDensity := 0.01
    normalizedDensity := candidate.Density / baselineDensity
    
    // Apply sigmoid function for smooth scoring
    score := 1.0 / (1.0 + math.Exp(-5.0*(normalizedDensity-1.0)))
    
    return math.Min(math.Max(score, 0.0), 1.0)
}

// scoreSpanCompactness scores based on how compact the span is
func (s *Scorer) scoreSpanCompactness(candidate CompositeCandidate) float64 {
    if candidate.SpanLength == 0 || candidate.MarkerCount < 2 {
        return 0.0
    }
    
    // Calculate average distance between markers
    var totalDistance float64
    markerPositions := make([]int, candidate.MarkerCount)
    
    for i, marker := range candidate.Markers {
        markerPositions[i] = (marker.Start + marker.End) / 2
    }
    
    sort.Ints(markerPositions)
    
    for i := 1; i < len(markerPositions); i++ {
        totalDistance += float64(markerPositions[i] - markerPositions[i-1])
    }
    
    avgDistance := totalDistance / float64(len(markerPositions)-1)
    
    // Score is inverse of average distance relative to span length
    if avgDistance == 0 {
        return 1.0
    }
    
    compactness := float64(candidate.SpanLength) / (avgDistance * float64(candidate.MarkerCount))
    
    // Normalize with sigmoid
    score := 1.0 / (1.0 + math.Exp(-10.0*(compactness-0.5)))
    
    return math.Min(math.Max(score, 0.0), 1.0)
}

// scoreTypeDiversity scores based on diversity of marker types
func (s *Scorer) scoreTypeDiversity(candidate CompositeCandidate) float64 {
    // Type diversity is already calculated in the candidate
    return candidate.TypeDiversity
}

// scoreTypeWeights scores based on the importance of marker types
func (s *Scorer) scoreTypeWeights(candidate CompositeCandidate) float64 {
    if candidate.MarkerCount == 0 {
        return 0.0
    }
    
    var totalWeight float64
    for _, marker := range candidate.Markers {
        if weight, exists := s.config.TypeWeights[marker.Type]; exists {
            totalWeight += weight
        } else {
            totalWeight += 0.3 // Default weight for unknown types
        }
    }
    
    avgWeight := totalWeight / float64(candidate.MarkerCount)
    
    // Normalize to [0, 1]
    return math.Min(math.Max(avgWeight, 0.0), 1.0)
}

// scoreConfidence scores based on the confidence of individual markers
func (s *Scorer) scoreConfidence(candidate CompositeCandidate) float64 {
    return candidate.GetAverageConfidence()
}

// ScoreAllCandidates scores all candidates
func (s *Scorer) ScoreAllCandidates(candidates []CompositeCandidate) []CompositeCandidate {
    startTime := time.Now()
    
    auditEvent := domain.NewAuditEvent("composite_scorer", "score_all_candidates")
    auditEvent.AddData("candidate_count", len(candidates))
    s.addAuditEvent(auditEvent)
    
    scoredCandidates := make([]CompositeCandidate, len(candidates))
    
    for i, candidate := range candidates {
        scoredCandidate := candidate
        score := s.ScoreCandidate(scoredCandidate)
        scoredCandidate.Score = score
        scoredCandidate.Confidence = score
        scoredCandidates[i] = scoredCandidate
    }
    
    // Sort by score descending
    sort.Slice(scoredCandidates, func(i, j int) bool {
        if scoredCandidates[i].Score == scoredCandidates[j].Score {
            // Tie-breaking: prefer candidates with more markers
            return scoredCandidates[i].MarkerCount > scoredCandidates[j].MarkerCount
        }
        return scoredCandidates[i].Score > scoredCandidates[j].Score
    })
    
    endEvent := domain.NewAuditEvent("composite_scorer", "all_candidates_scored")
    endEvent.AddData("candidate_count", len(scoredCandidates))
    endEvent.AddData("average_score", s.calculateAverageScore(scoredCandidates))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    s.addAuditEvent(endEvent)
    
    return scoredCandidates
}

// calculateAverageScore calculates the average score of candidates
func (s *Scorer) calculateAverageScore(candidates []CompositeCandidate) float64 {
    if len(candidates) == 0 {
        return 0.0
    }
    
    total := 0.0
    for _, candidate := range candidates {
        total += candidate.Score
    }
    
    return total / float64(len(candidates))
}

// addAuditEvent adds an audit event
func (s *Scorer) addAuditEvent(event *domain.AuditEvent) {
    s.auditEvents = append(s.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (s *Scorer) GetAuditEvents() []domain.AuditEvent {
    return s.auditEvents
}
```

### **internal/engine/composite/selector.go**
```go
package composite

import (
    "sort"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/determinism"
)

// Selector selects top composite candidates
type Selector struct {
    seedManager *determinism.SeedManager
    auditEvents []domain.AuditEvent
}

// NewSelector creates a new composite selector
func NewSelector(seedManager *determinism.SeedManager) *Selector {
    return &Selector{
        seedManager: seedManager,
        auditEvents: []domain.AuditEvent{},
    }
}

// SelectTopCandidates selects the top candidates based on score
func (s *Selector) SelectTopCandidates(candidates []CompositeCandidate, maxCount int) []CompositeCandidate {
    startTime := time.Now()
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("composite_selector", "select_top_candidates")
    auditEvent.AddData("input_candidates", len(candidates))
    auditEvent.AddData("max_count", maxCount)
    s.addAuditEvent(auditEvent)
    
    if len(candidates) == 0 {
        return candidates
    }
    
    // Make a copy to avoid modifying the original
    sortedCandidates := make([]CompositeCandidate, len(candidates))
    copy(sortedCandidates, candidates)
    
    // Sort candidates deterministically
    s.deterministicSort(sortedCandidates)
    
    // Apply selection limit
    selectedCount := min(maxCount, len(sortedCandidates))
    selected := sortedCandidates[:selectedCount]
    
    // Add selection metadata
    for i := range selected {
        selected[i].Metadata["selection_rank"] = i + 1
        selected[i].Metadata["selection_timestamp"] = time.Now().Format(time.RFC3339)
        selected[i].Metadata["total_candidates"] = len(candidates)
    }
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("composite_selector", "candidates_selected")
    endEvent.AddData("selected_count", len(selected))
    endEvent.AddData("top_score", selected[0].Score if len(selected) > 0 else 0)
    endEvent.AddData("average_selected_score", s.calculateAverageScore(selected))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    s.addAuditEvent(endEvent)
    
    return selected
}

// deterministicSort sorts candidates deterministically
func (s *Selector) deterministicSort(candidates []CompositeCandidate) {
    // Use seed manager for deterministic sorting
    // First sort by score (descending)
    sort.SliceStable(candidates, func(i, j int) bool {
        return candidates[i].Score > candidates[j].Score
    })
    
    // For candidates with equal scores, use deterministic tie-breaking
    s.breakTiesDeterministically(candidates)
}

// breakTiesDeterministically breaks ties using deterministic rules
func (s *Selector) breakTiesDeterministically(candidates []CompositeCandidate) {
    // Group candidates by score
    scoreGroups := make(map[float64][]CompositeCandidate)
    for _, candidate := range candidates {
        scoreGroups[candidate.Score] = append(scoreGroups[candidate.Score], candidate)
    }
    
    // For each score group with more than one candidate
    for _, group := range scoreGroups {
        if len(group) > 1 {
            // Sort within group using deterministic criteria
            sort.SliceStable(group, func(i, j int) bool {
                // 1. Compare by marker count
                if group[i].MarkerCount != group[j].MarkerCount {
                    return group[i].MarkerCount > group[j].MarkerCount
                }
                
                // 2. Compare by density
                if group[i].Density != group[j].Density {
                    return group[i].Density > group[j].Density
                }
                
                // 3. Compare by type diversity
                if group[i].TypeDiversity != group[j].TypeDiversity {
                    return group[i].TypeDiversity > group[j].TypeDiversity
                }
                
                // 4. Compare by span length (prefer shorter spans)
                if group[i].SpanLength != group[j].SpanLength {
                    return group[i].SpanLength < group[j].SpanLength
                }
                
                // 5. Use deterministic hash as final tie-breaker
                hashI := s.seedManager.DeterministicHash(group[i].ID)
                hashJ := s.seedManager.DeterministicHash(group[j].ID)
                return hashI < hashJ
            })
        }
    }
}

// FilterByScoreThreshold filters candidates by minimum score
func (s *Selector) FilterByScoreThreshold(candidates []CompositeCandidate, minScore float64) []CompositeCandidate {
    var filtered []CompositeCandidate
    
    for _, candidate := range candidates {
        if candidate.Score >= minScore {
            filtered = append(filtered, candidate)
        }
    }
    
    return filtered
}

// RemoveRedundantCandidates removes redundant candidates
func (s *Selector) RemoveRedundantCandidates(candidates []CompositeCandidate, redundancyThreshold float64) []CompositeCandidate {
    if len(candidates) <= 1 {
        return candidates
    }
    
    // Sort by score descending
    sorted := make([]CompositeCandidate, len(candidates))
    copy(sorted, candidates)
    sort.Slice(sorted, func(i, j int) bool {
        return sorted[i].Score > sorted[j].Score
    })
    
    var unique []CompositeCandidate
    uniqueSet := make(map[string]bool)
    
    for _, candidate := range sorted {
        isRedundant := false
        
        // Check against already selected unique candidates
        for _, uniqueCandidate := range unique {
            if s.isRedundant(&candidate, &uniqueCandidate, redundancyThreshold) {
                isRedundant = true
                break
            }
        }
        
        if !isRedundant && !uniqueSet[candidate.ID] {
            unique = append(unique, candidate)
            uniqueSet[candidate.ID] = true
        }
    }
    
    return unique
}

// isRedundant checks if one candidate is redundant compared to another
func (s *Selector) isRedundant(candidate, reference *CompositeCandidate, threshold float64) bool {
    // Calculate overlap in markers
    commonMarkers := 0
    referenceMarkerSet := make(map[string]bool)
    
    for _, marker := range reference.Markers {
        referenceMarkerSet[marker.ID] = true
    }
    
    for _, marker := range candidate.Markers {
        if referenceMarkerSet[marker.ID] {
            commonMarkers++
        }
    }
    
    overlapRatio := float64(commonMarkers) / float64(min(len(candidate.Markers), len(reference.Markers)))
    
    // Check span overlap
    spanOverlapStart := max(candidate.SpanStart, reference.SpanStart)
    spanOverlapEnd := min(candidate.SpanEnd, reference.SpanEnd)
    spanOverlapRatio := 0.0
    
    if spanOverlapEnd > spanOverlapStart {
        candidateSpan := candidate.SpanEnd - candidate.SpanStart
        referenceSpan := reference.SpanEnd - reference.SpanStart
        minSpan := min(candidateSpan, referenceSpan)
        spanOverlapRatio = float64(spanOverlapEnd-spanOverlapStart) / float64(minSpan)
    }
    
    // Candidate is redundant if it has high marker overlap AND span overlap
    return overlapRatio >= threshold && spanOverlapRatio >= 0.5
}

// SelectDiverseCandidates selects a diverse set of candidates
func (s *Selector) SelectDiverseCandidates(candidates []CompositeCandidate, maxCount int, diversityWeight float64) []CompositeCandidate {
    if len(candidates) == 0 {
        return candidates
    }
    
    // Calculate diversity scores
    diversityScores := s.calculateDiversityScores(candidates)
    
    // Combine with original scores
    combinedScores := make([]float64, len(candidates))
    for i := range candidates {
        combinedScores[i] = (candidates[i].Score * (1.0 - diversityWeight)) + 
                           (diversityScores[i] * diversityWeight)
    }
    
    // Sort by combined score
    sortedIndices := make([]int, len(candidates))
    for i := range sortedIndices {
        sortedIndices[i] = i
    }
    
    sort.Slice(sortedIndices, func(i, j int) bool {
        return combinedScores[sortedIndices[i]] > combinedScores[sortedIndices[j]]
    })
    
    // Select top candidates
    selectedCount := min(maxCount, len(candidates))
    selected := make([]CompositeCandidate, selectedCount)
    
    for i := 0; i < selectedCount; i++ {
        idx := sortedIndices[i]
        selected[i] = candidates[idx]
        selected[i].Metadata["diversity_score"] = diversityScores[idx]
        selected[i].Metadata["combined_score"] = combinedScores[idx]
    }
    
    return selected
}

// calculateDiversityScores calculates diversity scores for candidates
func (s *Selector) calculateDiversityScores(candidates []CompositeCandidate) []float64 {
    scores := make([]float64, len(candidates))
    
    for i, candidate := range candidates {
        // Start with candidate's own diversity
        diversityScore := candidate.TypeDiversity
        
        // Adjust based on similarity to other candidates
        similarityPenalty := 0.0
        for j, other := range candidates {
            if i == j {
                continue
            }
            
            // Calculate similarity
            similarity := s.calculateSimilarity(&candidate, &other)
            similarityPenalty += similarity
        }
        
        // Normalize penalty
        if len(candidates) > 1 {
            similarityPenalty /= float64(len(candidates) - 1)
        }
        
        // Diversity score is high when candidate is unique
        scores[i] = diversityScore * (1.0 - similarityPenalty)
    }
    
    return scores
}

// calculateSimilarity calculates similarity between two candidates
func (s *Selector) calculateSimilarity(candidate1, candidate2 *CompositeCandidate) float64 {
    // Calculate marker overlap
    markerSet1 := make(map[string]bool)
    for _, marker := range candidate1.Markers {
        markerSet1[marker.ID] = true
    }
    
    commonMarkers := 0
    for _, marker := range candidate2.Markers {
        if markerSet1[marker.ID] {
            commonMarkers++
        }
    }
    
    markerOverlap := float64(commonMarkers) / float64(min(len(candidate1.Markers), len(candidate2.Markers)))
    
    // Calculate type overlap
    typeSet1 := make(map[string]bool)
    for _, marker := range candidate1.Markers {
        typeSet1[marker.Type] = true
    }
    
    commonTypes := 0
    for _, marker := range candidate2.Markers {
        if typeSet1[marker.Type] {
            commonTypes++
        }
    }
    
    typeOverlap := float64(commonTypes) / float64(min(len(typeSet1), len(candidate2.GetMarkerTypes())))
    
    // Calculate span overlap
    spanOverlapStart := max(candidate1.SpanStart, candidate2.SpanStart)
    spanOverlapEnd := min(candidate1.SpanEnd, candidate2.SpanEnd)
    spanOverlap := 0.0
    
    if spanOverlapEnd > spanOverlapStart {
        span1 := candidate1.SpanEnd - candidate1.SpanStart
        span2 := candidate2.SpanEnd - candidate2.SpanStart
        minSpan := min(span1, span2)
        spanOverlap = float64(spanOverlapEnd-spanOverlapStart) / float64(minSpan)
    }
    
    // Combined similarity score
    similarity := (markerOverlap * 0.4) + (typeOverlap * 0.3) + (spanOverlap * 0.3)
    
    return similarity
}

// calculateAverageScore calculates the average score of candidates
func (s *Selector) calculateAverageScore(candidates []CompositeCandidate) float64 {
    if len(candidates) == 0 {
        return 0.0
    }
    
    total := 0.0
    for _, candidate := range candidates {
        total += candidate.Score
    }
    
    return total / float64(len(candidates))
}

// addAuditEvent adds an audit event
func (s *Selector) addAuditEvent(event *domain.AuditEvent) {
    s.auditEvents = append(s.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (s *Selector) GetAuditEvents() []domain.AuditEvent {
    return s.auditEvents
}

// Helper functions
func min(a, b int) int {
    if a < b {
        return a
    }
    return b
}

func max(a, b int) int {
    if a > b {
        return a
    }
    return b
}
```

## **3. Phase 5: Deep Analysis**

### **internal/engine/semantic/types.go**
```go
package semantic

import "semantic-analyzer/internal/domain"

// Entity represents a named entity found in text
type Entity struct {
    ID          string                 `json:"id"`
    Type        string                 `json:"type"`
    Text        string                 `json:"text"`
    Start       int                    `json:"start"`
    End         int                    `json:"end"`
    Confidence  float64                `json:"confidence"`
    RuleID      string                 `json:"rule_id,omitempty"`
    Context     string                 `json:"context,omitempty"`
    Metadata    map[string]interface{} `json:"metadata,omitempty"`
    SubEntities []Entity              `json:"sub_entities,omitempty"`
    IsAtomic    bool                   `json:"is_atomic"`
}

// SemanticNetwork represents a network of related terms
type SemanticNetwork struct {
    Name     string   `json:"name"`
    Keywords []string `json:"keywords"`
    Weight   float64  `json:"weight"`
    Type     string   `json:"type,omitempty"`
}

// ProximityResult represents semantic proximity between markers
type ProximityResult struct {
    Marker1ID      string           `json:"marker1_id"`
    Marker2ID      string           `json:"marker2_id"`
    Relatedness    float64          `json:"relatedness"`
    SharedNetworks []string         `json:"shared_networks,omitempty"`
    ContextOverlap float64          `json:"context_overlap"`
    TypeSimilarity float64          `json:"type_similarity"`
    Details        map[string]interface{} `json:"details,omitempty"`
}

// LogicalExpression represents a logical expression for evaluation
type LogicalExpression struct {
    ID         string                 `json:"id"`
    Expression string                 `json:"expression"`
    Type       string                 `json:"type"`
    Level      int                    `json:"level"`
    Weight     float64                `json:"weight"`
    OutputType string                 `json:"output_type"`
    Compiled   interface{}            `json:"-"` // Internal representation
    Metadata   map[string]interface{} `json:"metadata,omitempty"`
}

// EvaluationContext provides context for logical expression evaluation
type EvaluationContext struct {
    Markers      []domain.Marker `json:"markers"`
    Entities     []Entity        `json:"entities"`
    Text         string          `json:"text"`
    Sentences    []string        `json:"sentences,omitempty"`
    Variables    map[string]interface{} `json:"variables,omitempty"`
    Metadata     map[string]interface{} `json:"metadata,omitempty"`
}

// EvaluationResult represents the result of logical expression evaluation
type EvaluationResult struct {
    ExpressionID string                 `json:"expression_id"`
    Success      bool                   `json:"success"`
    Result       bool                   `json:"result"`
    Confidence   float64                `json:"confidence"`
    MatchedItems []MatchedItem          `json:"matched_items,omitempty"`
    Details      map[string]interface{} `json:"details,omitempty"`
    Error        string                 `json:"error,omitempty"`
}

// MatchedItem represents an item that matched during evaluation
type MatchedItem struct {
    Type     string `json:"type"` // "marker" or "entity"
    ID       string `json:"id"`
    Text     string `json:"text"`
    Position int    `json:"position,omitempty"`
    Score    float64 `json:"score"`
}

// NewEntity creates a new entity
func NewEntity(entityType, text string, start, end int, confidence float64, ruleID string) *Entity {
    return &Entity{
        ID:         generateEntityID(entityType, start, end),
        Type:       entityType,
        Text:       text,
        Start:      start,
        End:        end,
        Confidence: confidence,
        RuleID:     ruleID,
        Metadata:   make(map[string]interface{}),
        IsAtomic:   true,
    }
}

// NewSemanticNetwork creates a new semantic network
func NewSemanticNetwork(name string, keywords []string, weight float64) *SemanticNetwork {
    return &SemanticNetwork{
        Name:     name,
        Keywords: keywords,
        Weight:   weight,
    }
}

// generateEntityID generates a deterministic entity ID
func generateEntityID(entityType string, start, end int) string {
    return fmt.Sprintf("entity_%s_%d_%d", entityType, start, end)
}
```

### **internal/engine/semantic/ner_engine.go**
```go
package semantic

import (
    "fmt"
    "regexp"
    "strings"
    "sync"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
)

// NEREngine performs named entity recognition
type NEREngine struct {
    config          config.NERConfig
    compiledRegex   map[string]*regexp.Regexp
    auditEvents     []domain.AuditEvent
    mu              sync.RWMutex
    entityCache     map[string][]Entity
    titleSet        map[string]bool
    suffixSet       map[string]bool
    locationSet     map[string]bool
}

// NewNEREngine creates a new NER engine
func NewNEREngine(cfg config.NERConfig) *NEREngine {
    engine := &NEREngine{
        config:        cfg,
        compiledRegex: make(map[string]*regexp.Regexp),
        auditEvents:   []domain.AuditEvent{},
        entityCache:   make(map[string][]Entity),
        titleSet:      make(map[string]bool),
        suffixSet:     make(map[string]bool),
        locationSet:   make(map[string]bool),
    }
    
    engine.initialize()
    return engine
}

// initialize sets up the NER engine
func (n *NEREngine) initialize() {
    n.mu.Lock()
    defer n.mu.Unlock()
    
    // Build title set for fast lookup
    for _, title := range n.config.PersonTitles {
        n.titleSet[strings.ToLower(title)] = true
    }
    
    // Build suffix set for fast lookup
    for _, suffix := range n.config.OrganizationSuffixes {
        n.suffixSet[strings.ToLower(suffix)] = true
    }
    
    // Build location keyword set
    for _, keyword := range n.config.LocationKeywords {
        n.locationSet[strings.ToLower(keyword)] = true
    }
    
    // Compile regex patterns for person names
    for _, pattern := range n.config.PersonPatterns {
        compiled, err := regexp.Compile(pattern.Pattern)
        if err != nil {
            // Log error but continue
            fmt.Printf("Warning: Failed to compile person pattern %s: %v\n", pattern.ID, err)
            continue
        }
        n.compiledRegex[pattern.ID] = compiled
    }
    
    // Compile regex patterns for organizations
    for _, pattern := range n.config.OrganizationPatterns {
        compiled, err := regexp.Compile(pattern.Pattern)
        if err != nil {
            fmt.Printf("Warning: Failed to compile organization pattern %s: %v\n", pattern.ID, err)
            continue
        }
        n.compiledRegex[pattern.ID] = compiled
    }
    
    // Compile location patterns
    for i, pattern := range n.config.LocationPatterns {
        compiled, err := regexp.Compile(pattern)
        if err != nil {
            fmt.Printf("Warning: Failed to compile location pattern %d: %v\n", i, err)
            continue
        }
        n.compiledRegex[fmt.Sprintf("location_%d", i)] = compiled
    }
}

// ExtractEntities extracts named entities from text
func (n *NEREngine) ExtractEntities(text string) []Entity {
    startTime := time.Now()
    
    // Check cache first
    cacheKey := n.generateCacheKey(text)
    if cached, exists := n.entityCache[cacheKey]; exists {
        return cached
    }
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("ner_engine", "extract_entities")
    auditEvent.AddData("text_length", len(text))
    n.addAuditEvent(auditEvent)
    
    var allEntities []Entity
    
    // Extract person entities
    personEntities := n.extractPersonEntities(text)
    allEntities = append(allEntities, personEntities...)
    
    // Extract organization entities
    orgEntities := n.extractOrganizationEntities(text)
    allEntities = append(allEntities, orgEntities...)
    
    // Extract location entities
    locationEntities := n.extractLocationEntities(text)
    allEntities = append(allEntities, locationEntities...)
    
    // Remove overlapping entities
    filteredEntities := n.removeOverlappingEntities(allEntities)
    
    // Sort entities by position
    n.sortEntitiesByPosition(filteredEntities)
    
    // Cache results
    n.mu.Lock()
    n.entityCache[cacheKey] = filteredEntities
    n.mu.Unlock()
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("ner_engine", "entities_extracted")
    endEvent.AddData("total_entities", len(filteredEntities))
    endEvent.AddData("persons", len(personEntities))
    endEvent.AddData("organizations", len(orgEntities))
    endEvent.AddData("locations", len(locationEntities))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    n.addAuditEvent(endEvent)
    
    return filteredEntities
}

// extractPersonEntities extracts person entities from text
func (n *NEREngine) extractPersonEntities(text string) []Entity {
    var entities []Entity
    
    // Method 1: Use regex patterns
    for ruleID, regex := range n.compiledRegex {
        // Check if this is a person pattern
        if strings.HasPrefix(ruleID, "person_") {
            matches := regex.FindAllStringIndex(text, -1)
            for _, match := range matches {
                start, end := match[0], match[1]
                entity := NewEntity(
                    "PERSON",
                    text[start:end],
                    start,
                    end,
                    0.8, // Base confidence for regex matches
                    ruleID,
                )
                entity.Metadata["extraction_method"] = "regex_pattern"
                entities = append(entities, *entity)
            }
        }
    }
    
    // Method 2: Title-based extraction
    words := strings.Fields(text)
    for i, word := range words {
        lowerWord := strings.ToLower(word)
        
        // Check if word is a title
        if n.titleSet[lowerWord] {
            // Look for capitalized names after the title
            if i+1 < len(words) {
                nextWord := words[i+1]
                if n.isCapitalizedName(nextWord) {
                    // Create entity for the name
                    entityText := nextWord
                    start := strings.Index(text, entityText)
                    
                    // Check for second name (last name)
                    if i+2 < len(words) && n.isCapitalizedName(words[i+2]) {
                        entityText = nextWord + " " + words[i+2]
                    }
                    
                    if start != -1 {
                        end := start + len(entityText)
                        entity := NewEntity(
                            "PERSON",
                            entityText,
                            start,
                            end,
                            0.7, // Confidence for title-based extraction
                            "title_based",
                        )
                        entity.Metadata["title"] = word
                        entity.Metadata["extraction_method"] = "title_based"
                        entities = append(entities, *entity)
                    }
                }
            }
        }
    }
    
    // Method 3: Capitalized name patterns
    n.extractCapitalizedNameEntities(text, &entities)
    
    return entities
}

// extractOrganizationEntities extracts organization entities from text
func (n *NEREngine) extractOrganizationEntities(text string) []Entity {
    var entities []Entity
    
    // Method 1: Use regex patterns
    for ruleID, regex := range n.compiledRegex {
        if strings.HasPrefix(ruleID, "organization_") {
            matches := regex.FindAllStringIndex(text, -1)
            for _, match := range matches {
                start, end := match[0], match[1]
                entity := NewEntity(
                    "ORGANIZATION",
                    text[start:end],
                    start,
                    end,
                    0.8,
                    ruleID,
                )
                entity.Metadata["extraction_method"] = "regex_pattern"
                entities = append(entities, *entity)
            }
        }
    }
    
    // Method 2: Suffix-based extraction
    words := strings.Fields(text)
    for i := 0; i < len(words); i++ {
        word := words[i]
        lowerWord := strings.ToLower(word)
        
        // Check if word ends with an organization suffix
        for suffix := range n.suffixSet {
            if strings.HasSuffix(lowerWord, suffix) {
                // Collect preceding capitalized words
                orgWords := []string{}
                
                // Look backward for capitalized words
                for j := i - 1; j >= 0; j-- {
                    if n.isCapitalizedName(words[j]) || n.containsNonLetters(words[j]) {
                        orgWords = append([]string{words[j]}, orgWords...)
                    } else {
                        break
                    }
                }
                
                // Add the suffix word
                orgWords = append(orgWords, word)
                
                // Create entity
                entityText := strings.Join(orgWords, " ")
                start := strings.Index(text, entityText)
                
                if start != -1 {
                    end := start + len(entityText)
                    entity := NewEntity(
                        "ORGANIZATION",
                        entityText,
                        start,
                        end,
                        0.7,
                        "suffix_based",
                    )
                    entity.Metadata["suffix"] = word
                    entity.Metadata["extraction_method"] = "suffix_based"
                    entities = append(entities, *entity)
                }
                
                break
            }
        }
    }
    
    return entities
}

// extractLocationEntities extracts location entities from text
func (n *NEREngine) extractLocationEntities(text string) []Entity {
    var entities []Entity
    
    // Method 1: Use regex patterns
    for ruleID, regex := range n.compiledRegex {
        if strings.HasPrefix(ruleID, "location_") {
            matches := regex.FindAllStringIndex(text, -1)
            for _, match := range matches {
                start, end := match[0], match[1]
                entity := NewEntity(
                    "LOCATION",
                    text[start:end],
                    start,
                    end,
                    0.7,
                    ruleID,
                )
                entity.Metadata["extraction_method"] = "regex_pattern"
                entities = append(entities, *entity)
            }
        }
    }
    
    // Method 2: Keyword-based extraction
    words := strings.Fields(text)
    for i, word := range words {
        lowerWord := strings.ToLower(word)
        
        // Check if word contains location keywords
        for keyword := range n.locationSet {
            if strings.Contains(lowerWord, keyword) {
                // Look for capitalized words around the keyword
                locationWords := []string{}
                
                // Look backward
                for j := i - 1; j >= 0 && j >= i-3; j-- {
                    if n.isCapitalizedName(words[j]) {
                        locationWords = append([]string{words[j]}, locationWords...)
                    } else {
                        break
                    }
                }
                
                // Add the keyword word
                locationWords = append(locationWords, word)
                
                // Look forward
                for j := i + 1; j < len(words) && j <= i+3; j++ {
                    if n.isCapitalizedName(words[j]) || n.containsNonLetters(words[j]) {
                        locationWords = append(locationWords, words[j])
                    } else {
                        break
                    }
                }
                
                // Create entity
                entityText := strings.Join(locationWords, " ")
                start := strings.Index(text, entityText)
                
                if start != -1 {
                    end := start + len(entityText)
                    entity := NewEntity(
                        "LOCATION",
                        entityText,
                        start,
                        end,
                        0.6,
                        "keyword_based",
                    )
                    entity.Metadata["keyword"] = keyword
                    entity.Metadata["extraction_method"] = "keyword_based"
                    entities = append(entities, *entity)
                }
                
                break
            }
        }
    }
    
    return entities
}

// extractCapitalizedNameEntities extracts entities based on capitalized names
func (n *NEREngine) extractCapitalizedNameEntities(text string, entities *[]Entity) {
    // Simple pattern for capitalized names (first letter uppercase, rest lowercase)
    pattern := `\b[A-Z][a-z]+\s+[A-Z][a-z]+\b`
    regex := regexp.MustCompile(pattern)
    
    matches := regex.FindAllStringIndex(text, -1)
    for _, match := range matches {
        start, end := match[0], match[1]
        
        // Check if this span is already covered by another entity
        alreadyCovered := false
        for _, entity := range *entities {
            if start >= entity.Start && end <= entity.End {
                alreadyCovered = true
                break
            }
        }
        
        if !alreadyCovered {
            entity := NewEntity(
                "PERSON",
                text[start:end],
                start,
                end,
                0.5, // Lower confidence for pattern-based extraction
                "capitalized_pattern",
            )
            entity.Metadata["extraction_method"] = "capitalized_pattern"
            *entities = append(*entities, *entity)
        }
    }
}

// removeOverlappingEntities removes overlapping entities, keeping the highest confidence one
func (n *NEREngine) removeOverlappingEntities(entities []Entity) []Entity {
    if len(entities) <= 1 {
        return entities
    }
    
    // Sort by start position, then by confidence descending
    sorted := make([]Entity, len(entities))
    copy(sorted, entities)
    
    n.sortEntities(sorted)
    
    var filtered []Entity
    current := sorted[0]
    
    for i := 1; i < len(sorted); i++ {
        next := sorted[i]
        
        // Check for overlap
        if current.End > next.Start {
            // Overlap detected, keep the higher confidence entity
            if current.Confidence >= next.Confidence {
                // Keep current, skip next
                continue
            } else {
                // Replace current with next
                current = next
            }
        } else {
            // No overlap, add current to filtered
            filtered = append(filtered, current)
            current = next
        }
    }
    
    // Add the last entity
    filtered = append(filtered, current)
    
    return filtered
}

// sortEntities sorts entities by position and confidence
func (n *NEREngine) sortEntities(entities []Entity) {
    // Sort by start position, then by confidence descending
    // This is a simple in-place sort
    for i := 0; i < len(entities); i++ {
        for j := i + 1; j < len(entities); j++ {
            if entities[i].Start > entities[j].Start ||
               (entities[i].Start == entities[j].Start && entities[i].Confidence < entities[j].Confidence) {
                entities[i], entities[j] = entities[j], entities[i]
            }
        }
    }
}

// sortEntitiesByPosition sorts entities by their start position
func (n *NEREngine) sortEntitiesByPosition(entities []Entity) {
    sort.Slice(entities, func(i, j int) bool {
        if entities[i].Start == entities[j].Start {
            return entities[i].End < entities[j].End
        }
        return entities[i].Start < entities[j].Start
    })
}

// isCapitalizedName checks if a word is a capitalized name
func (n *NEREngine) isCapitalizedName(word string) bool {
    if len(word) == 0 {
        return false
    }
    
    // Check if first character is uppercase
    firstChar := word[0]
    if firstChar < 'A' || firstChar > 'Z' {
        return false
    }
    
    // Check if remaining characters are lowercase (allow for hyphenated names)
    for i := 1; i < len(word); i++ {
        char := word[i]
        if char == '-' || char == '\'' {
            continue // Allow hyphen or apostrophe
        }
        if char < 'a' || char > 'z' {
            return false
        }
    }
    
    return true
}

// containsNonLetters checks if a word contains non-letter characters
func (n *NEREngine) containsNonLetters(word string) bool {
    for _, char := range word {
        if (char < 'A' || char > 'Z') && (char < 'a' || char > 'z') {
            return true
        }
    }
    return false
}

// generateCacheKey generates a cache key for text
func (n *NEREngine) generateCacheKey(text string) string {
    // Use a simple hash for cache key
    // In production, use a proper hash function
    return fmt.Sprintf("%d", len(text))
}

// addAuditEvent adds an audit event
func (n *NEREngine) addAuditEvent(event *domain.AuditEvent) {
    n.auditEvents = append(n.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (n *NEREngine) GetAuditEvents() []domain.AuditEvent {
    return n.auditEvents
}

// ClearCache clears the entity cache
func (n *NEREngine) ClearCache() {
    n.mu.Lock()
    defer n.mu.Unlock()
    n.entityCache = make(map[string][]Entity)
}
```

### **internal/engine/semantic/proximity_analyzer.go**
```go
package semantic

import (
    "math"
    "strings"
    "sync"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
)

// ProximityAnalyzer calculates semantic relatedness between markers
type ProximityAnalyzer struct {
    config      config.SemanticRulesConfig
    networks    map[string]*SemanticNetwork
    auditEvents []domain.AuditEvent
    mu          sync.RWMutex
    cache       map[string]ProximityResult
}

// NewProximityAnalyzer creates a new proximity analyzer
func NewProximityAnalyzer(cfg config.SemanticRulesConfig) *ProximityAnalyzer {
    analyzer := &ProximityAnalyzer{
        config:      cfg,
        networks:    make(map[string]*SemanticNetwork),
        auditEvents: []domain.AuditEvent{},
        cache:       make(map[string]ProximityResult),
    }
    
    analyzer.initialize()
    return analyzer
}

// initialize sets up the proximity analyzer
func (p *ProximityAnalyzer) initialize() {
    p.mu.Lock()
    defer p.mu.Unlock()
    
    // Build semantic networks from config
    for name, keywords := range p.config.Networks {
        network := NewSemanticNetwork(name, keywords, 1.0)
        p.networks[name] = network
    }
}

// CalculateSemanticRelatedness calculates semantic relatedness between two markers
func (p *ProximityAnalyzer) CalculateSemanticRelatedness(marker1, marker2 domain.Marker) float64 {
    startTime := time.Now()
    
    // Check cache first
    cacheKey := p.generateCacheKey(marker1.ID, marker2.ID)
    if cached, exists := p.cache[cacheKey]; exists {
        return cached.Relatedness
    }
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("proximity_analyzer", "calculate_relatedness")
    auditEvent.AddData("marker1_id", marker1.ID)
    auditEvent.AddData("marker2_id", marker2.ID)
    auditEvent.MarkerID = marker1.ID
    p.addAuditEvent(auditEvent)
    
    // Calculate individual components
    networkMatchScore := p.calculateNetworkMatch(marker1, marker2)
    typeSimilarityScore := p.calculateTypeSimilarity(marker1, marker2)
    contextOverlapScore := p.calculateContextOverlap(marker1, marker2)
    
    // Calculate weighted total
    relatedness := (networkMatchScore * p.config.ProximityWeights.NetworkMatch) +
                   (typeSimilarityScore * p.config.ProximityWeights.TypeSimilarity) +
                   (contextOverlapScore * p.config.ProximityWeights.ContextOverlap)
    
    // Normalize to [0, 1]
    relatedness = math.Min(math.Max(relatedness, 0.0), 1.0)
    
    // Create result
    result := ProximityResult{
        Marker1ID:      marker1.ID,
        Marker2ID:      marker2.ID,
        Relatedness:    relatedness,
        SharedNetworks: p.getSharedNetworks(marker1, marker2),
        ContextOverlap: contextOverlapScore,
        TypeSimilarity: typeSimilarityScore,
        Details: map[string]interface{}{
            "network_match":    networkMatchScore,
            "type_similarity":  typeSimilarityScore,
            "context_overlap":  contextOverlapScore,
            "weights_applied": map[string]float64{
                "network_match":   p.config.ProximityWeights.NetworkMatch,
                "type_similarity": p.config.ProximityWeights.TypeSimilarity,
                "context_overlap": p.config.ProximityWeights.ContextOverlap,
            },
        },
    }
    
    // Cache result
    p.mu.Lock()
    p.cache[cacheKey] = result
    p.mu.Unlock()
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("proximity_analyzer", "relatedness_calculated")
    endEvent.AddData("marker1_id", marker1.ID)
    endEvent.AddData("marker2_id", marker2.ID)
    endEvent.AddData("relatedness", relatedness)
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    p.addAuditEvent(endEvent)
    
    return relatedness
}

// calculateNetworkMatch calculates network match score
func (p *ProximityAnalyzer) calculateNetworkMatch(marker1, marker2 domain.Marker) float64 {
    p.mu.RLock()
    defer p.mu.RUnlock()
    
    // Get networks for each marker
    networks1 := p.getMarkerNetworks(marker1)
    networks2 := p.getMarkerNetworks(marker2)
    
    if len(networks1) == 0 || len(networks2) == 0 {
        return 0.0
    }
    
    // Calculate Jaccard similarity between network sets
    intersection := 0
    for network := range networks1 {
        if networks2[network] {
            intersection++
        }
    }
    
    union := len(networks1) + len(networks2) - intersection
    
    if union == 0 {
        return 0.0
    }
    
    return float64(intersection) / float64(union)
}

// getMarkerNetworks gets networks that a marker belongs to
func (p *ProximityAnalyzer) getMarkerNetworks(marker domain.Marker) map[string]bool {
    networks := make(map[string]bool)
    
    // Check marker text against each network's keywords
    lowerText := strings.ToLower(marker.TextSpan)
    
    for name, network := range p.networks {
        for _, keyword := range network.Keywords {
            if strings.Contains(lowerText, strings.ToLower(keyword)) {
                networks[name] = true
                break
            }
        }
    }
    
    return networks
}

// calculateTypeSimilarity calculates type similarity score
func (p *ProximityAnalyzer) calculateTypeSimilarity(marker1, marker2 domain.Marker) float64 {
    if marker1.Type == marker2.Type {
        return 1.0
    }
    
    // Check if types are semantically related
    typePairs := map[string][]string{
        "PERSON":       {"CONTACT", "NAME"},
        "ORGANIZATION": {"CONTACT", "COMPANY"},
        "LOCATION":     {"ADDRESS", "PLACE"},
        "CONTACT":      {"EMAIL", "PHONE", "URL"},
        "PRIORITY":     {"ACTION", "URGENT"},
        "ACTION":       {"TODO", "TASK"},
    }
    
    // Check if marker1.Type is related to marker2.Type
    if relatedTypes, exists := typePairs[marker1.Type]; exists {
        for _, relatedType := range relatedTypes {
            if marker2.Type == relatedType {
                return 0.7
            }
        }
    }
    
    // Check if marker2.Type is related to marker1.Type
    if relatedTypes, exists := typePairs[marker2.Type]; exists {
        for _, relatedType := range relatedTypes {
            if marker1.Type == relatedType {
                return 0.7
            }
        }
    }
    
    // Check if types share a common prefix
    if strings.HasPrefix(marker1.Type, marker2.Type) || strings.HasPrefix(marker2.Type, marker1.Type) {
        return 0.5
    }
    
    return 0.0
}

// calculateContextOverlap calculates context overlap score
func (p *ProximityAnalyzer) calculateContextOverlap(marker1, marker2 domain.Marker) float64 {
    // Extract context windows around markers
    context1 := marker1.Context
    context2 := marker2.Context
    
    if context1 == "" || context2 == "" {
        return 0.0
    }
    
    // Tokenize contexts
    tokens1 := strings.Fields(strings.ToLower(context1))
    tokens2 := strings.Fields(strings.ToLower(context2))
    
    if len(tokens1) == 0 || len(tokens2) == 0 {
        return 0.0
    }
    
    // Calculate word overlap
    wordSet1 := make(map[string]bool)
    for _, token := range tokens1 {
        wordSet1[token] = true
    }
    
    overlap := 0
    for _, token := range tokens2 {
        if wordSet1[token] {
            overlap++
        }
    }
    
    // Calculate Jaccard similarity
    union := len(wordSet1) + len(tokens2) - overlap
    
    if union == 0 {
        return 0.0
    }
    
    return float64(overlap) / float64(union)
}

// getSharedNetworks gets networks shared by both markers
func (p *ProximityAnalyzer) getSharedNetworks(marker1, marker2 domain.Marker) []string {
    networks1 := p.getMarkerNetworks(marker1)
    networks2 := p.getMarkerNetworks(marker2)
    
    var shared []string
    for network := range networks1 {
        if networks2[network] {
            shared = append(shared, network)
        }
    }
    
    return shared
}

// CalculateBatchRelatedness calculates relatedness for multiple marker pairs
func (p *ProximityAnalyzer) CalculateBatchRelatedness(markers []domain.Marker, maxDistance int) []ProximityResult {
    startTime := time.Now()
    
    auditEvent := domain.NewAuditEvent("proximity_analyzer", "calculate_batch_relatedness")
    auditEvent.AddData("marker_count", len(markers))
    auditEvent.AddData("max_distance", maxDistance)
    p.addAuditEvent(auditEvent)
    
    var results []ProximityResult
    
    // Calculate relatedness for marker pairs within maxDistance
    for i := 0; i < len(markers); i++ {
        for j := i + 1; j < len(markers); j++ {
            // Check distance constraint
            distance := markers[i].DistanceTo(&markers[j])
            if maxDistance > 0 && distance > maxDistance {
                continue
            }
            
            relatedness := p.CalculateSemanticRelatedness(markers[i], markers[j])
            
            result := ProximityResult{
                Marker1ID:      markers[i].ID,
                Marker2ID:      markers[j].ID,
                Relatedness:    relatedness,
                SharedNetworks: p.getSharedNetworks(markers[i], markers[j]),
                ContextOverlap: p.calculateContextOverlap(markers[i], markers[j]),
                TypeSimilarity: p.calculateTypeSimilarity(markers[i], markers[j]),
                Details: map[string]interface{}{
                    "distance": distance,
                },
            }
            
            results = append(results, result)
        }
    }
    
    // Sort by relatedness descending
    p.sortResultsByRelatedness(results)
    
    endEvent := domain.NewAuditEvent("proximity_analyzer", "batch_relatedness_calculated")
    endEvent.AddData("pair_count", len(results))
    endEvent.AddData("average_relatedness", p.calculateAverageRelatedness(results))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    p.addAuditEvent(endEvent)
    
    return results
}

// sortResultsByRelatedness sorts results by relatedness descending
func (p *ProximityAnalyzer) sortResultsByRelatedness(results []ProximityResult) {
    sort.Slice(results, func(i, j int) bool {
        if results[i].Relatedness == results[j].Relatedness {
            // Tie-breaking: prefer pairs with more shared networks
            return len(results[i].SharedNetworks) > len(results[j].SharedNetworks)
        }
        return results[i].Relatedness > results[j].Relatedness
    })
}

// calculateAverageRelatedness calculates average relatedness
func (p *ProximityAnalyzer) calculateAverageRelatedness(results []ProximityResult) float64 {
    if len(results) == 0 {
        return 0.0
    }
    
    total := 0.0
    for _, result := range results {
        total += result.Relatedness
    }
    
    return total / float64(len(results))
}

// generateCacheKey generates a cache key for marker pair
func (p *ProximityAnalyzer) generateCacheKey(marker1ID, marker2ID string) string {
    // Ensure consistent ordering for cache key
    if marker1ID < marker2ID {
        return marker1ID + "_" + marker2ID
    }
    return marker2ID + "_" + marker1ID
}

// addAuditEvent adds an audit event
func (p *ProximityAnalyzer) addAuditEvent(event *domain.AuditEvent) {
    p.auditEvents = append(p.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (p *ProximityAnalyzer) GetAuditEvents() []domain.AuditEvent {
    return p.auditEvents
}

// ClearCache clears the proximity cache
func (p *ProximityAnalyzer) ClearCache() {
    p.mu.Lock()
    defer p.mu.Unlock()
    p.cache = make(map[string]ProximityResult)
}
```

### **internal/engine/semantic/logical_evaluator.go**
```go
package semantic

import (
    "fmt"
    "regexp"
    "strconv"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/config"
)

// LogicalEvaluator evaluates logical expressions
type LogicalEvaluator struct {
    config      config.SemanticRulesConfig
    auditEvents []domain.AuditEvent
    compiledExpressions map[string]*LogicalExpression
    nearRegex   *regexp.Regexp
    entityRegex *regexp.Regexp
    markerRegex *regexp.Regexp
}

// NewLogicalEvaluator creates a new logical evaluator
func NewLogicalEvaluator(cfg config.SemanticRulesConfig) *LogicalEvaluator {
    evaluator := &LogicalEvaluator{
        config:             cfg,
        auditEvents:        []domain.AuditEvent{},
        compiledExpressions: make(map[string]*LogicalExpression),
    }
    
    evaluator.initialize()
    return evaluator
}

// initialize sets up the logical evaluator
func (l *LogicalEvaluator) initialize() {
    // Compile regex patterns for parsing
    l.nearRegex = regexp.MustCompile(`NEAR\(([^,]+),\s*([^,]+)(?:,\s*(\d+))?\)`)
    l.entityRegex = regexp.MustCompile(`ENTITY_TYPE:([A-Z_]+)`)
    l.markerRegex = regexp.MustCompile(`MARKER_TYPE:([A-Z_]+)`)
    
    // Compile logical rules from config
    for _, rule := range l.config.LogicalRules {
        l.compileExpression(rule)
    }
}

// compileExpression compiles a logical expression
func (l *LogicalEvaluator) compileExpression(rule config.LogicalRuleConfig) {
    expr := &LogicalExpression{
        ID:         rule.ID,
        Expression: rule.Expression,
        Type:       rule.Type,
        Level:      rule.Level,
        Weight:     rule.Weight,
        OutputType: rule.OutputType,
        Metadata:   make(map[string]interface{}),
    }
    
    // Simple compilation: parse into tokens
    tokens := l.tokenizeExpression(rule.Expression)
    expr.Compiled = tokens
    expr.Metadata["token_count"] = len(tokens)
    expr.Metadata["compilation_time"] = time.Now().Format(time.RFC3339)
    
    l.compiledExpressions[rule.ID] = expr
}

// tokenizeExpression tokenizes a logical expression
func (l *LogicalEvaluator) tokenizeExpression(expr string) []string {
    // Remove extra whitespace
    expr = strings.TrimSpace(expr)
    
    // Tokenize by operators and parentheses
    var tokens []string
    var currentToken strings.Builder
    inQuotes := false
    
    for i, char := range expr {
        switch char {
        case ' ':
            if !inQuotes {
                if currentToken.Len() > 0 {
                    tokens = append(tokens, currentToken.String())
                    currentToken.Reset()
                }
                continue
            }
            currentToken.WriteRune(char)
        case '(':
            if currentToken.Len() > 0 {
                tokens = append(tokens, currentToken.String())
                currentToken.Reset()
            }
            tokens = append(tokens, "(")
        case ')':
            if currentToken.Len() > 0 {
                tokens = append(tokens, currentToken.String())
                currentToken.Reset()
            }
            tokens = append(tokens, ")")
        case ',':
            if !inQuotes {
                if currentToken.Len() > 0 {
                    tokens = append(tokens, currentToken.String())
                    currentToken.Reset()
                }
                tokens = append(tokens, ",")
            } else {
                currentToken.WriteRune(char)
            }
        case '"', '\'':
            inQuotes = !inQuotes
            currentToken.WriteRune(char)
        default:
            currentToken.WriteRune(char)
        }
        
        // Handle operators (AND, OR, NOT)
        if i >= 2 && strings.HasSuffix(currentToken.String(), "AND") {
            tokenStr := currentToken.String()
            if len(tokenStr) == 3 || (len(tokenStr) > 3 && tokenStr[len(tokenStr)-4] == ' ') {
                if currentToken.Len() > 3 {
                    beforeOp := tokenStr[:len(tokenStr)-3]
                    tokens = append(tokens, beforeOp)
                    currentToken.Reset()
                }
                tokens = append(tokens, "AND")
            }
        } else if i >= 1 && strings.HasSuffix(currentToken.String(), "OR") {
            tokenStr := currentToken.String()
            if len(tokenStr) == 2 || (len(tokenStr) > 2 && tokenStr[len(tokenStr)-3] == ' ') {
                if currentToken.Len() > 2 {
                    beforeOp := tokenStr[:len(tokenStr)-2]
                    tokens = append(tokens, beforeOp)
                    currentToken.Reset()
                }
                tokens = append(tokens, "OR")
            }
        } else if i >= 2 && strings.HasSuffix(currentToken.String(), "NOT") {
            tokenStr := currentToken.String()
            if len(tokenStr) == 3 || (len(tokenStr) > 3 && tokenStr[len(tokenStr)-4] == ' ') {
                if currentToken.Len() > 3 {
                    beforeOp := tokenStr[:len(tokenStr)-3]
                    tokens = append(tokens, beforeOp)
                    currentToken.Reset()
                }
                tokens = append(tokens, "NOT")
            }
        }
    }
    
    // Add last token if any
    if currentToken.Len() > 0 {
        tokens = append(tokens, currentToken.String())
    }
    
    return tokens
}

// EvaluateExpression evaluates a logical expression against a context
func (l *LogicalEvaluator) EvaluateExpression(expr string, context map[string]interface{}) (bool, *EvaluationResult) {
    startTime := time.Now()
    
    // Create audit event
    auditEvent := domain.NewAuditEvent("logical_evaluator", "evaluate_expression")
    auditEvent.AddData("expression", expr)
    l.addAuditEvent(auditEvent)
    
    result := &EvaluationResult{
        ExpressionID: "adhoc",
        Success:      false,
        Result:       false,
        Confidence:   0.0,
        MatchedItems: []MatchedItem{},
        Details:      make(map[string]interface{}),
    }
    
    // Parse the expression
    parsed, err := l.parseExpression(expr)
    if err != nil {
        result.Error = fmt.Sprintf("Parse error: %v", err)
        return false, result
    }
    
    // Evaluate the parsed expression
    evalResult, evalDetails, err := l.evaluateParsedExpression(parsed, context)
    if err != nil {
        result.Error = fmt.Sprintf("Evaluation error: %v", err)
        return false, result
    }
    
    // Update result
    result.Success = true
    result.Result = evalResult
    result.Confidence = l.calculateConfidence(evalDetails)
    result.Details = evalDetails
    result.Details["expression"] = expr
    result.Details["parsed_form"] = parsed
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("logical_evaluator", "expression_evaluated")
    endEvent.AddData("expression", expr)
    endEvent.AddData("result", evalResult)
    endEvent.AddData("confidence", result.Confidence)
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    l.addAuditEvent(endEvent)
    
    return evalResult, result
}

// parseExpression parses a logical expression into an AST
func (l *LogicalEvaluator) parseExpression(expr string) (interface{}, error) {
    // Simple recursive descent parser for logical expressions
    
    tokens := l.tokenizeExpression(expr)
    if len(tokens) == 0 {
        return nil, fmt.Errorf("empty expression")
    }
    
    // Parse the expression
    parser := &expressionParser{
        tokens: tokens,
        index:  0,
    }
    
    ast, err := parser.parseExpression()
    if err != nil {
        return nil, err
    }
    
    return ast, nil
}

// evaluateParsedExpression evaluates a parsed expression AST
func (l *LogicalEvaluator) evaluateParsedExpression(ast interface{}, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    result, evalDetails, err := l.evaluateAST(ast, context)
    if err != nil {
        return false, details, err
    }
    
    // Merge evaluation details
    for k, v := range evalDetails {
        details[k] = v
    }
    
    return result, details, nil
}

// evaluateAST evaluates an AST node
func (l *LogicalEvaluator) evaluateAST(node interface{}, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    switch n := node.(type) {
    case *binaryOpNode:
        // Evaluate left and right operands
        leftResult, leftDetails, leftErr := l.evaluateAST(n.left, context)
        if leftErr != nil {
            return false, details, leftErr
        }
        
        rightResult, rightDetails, rightErr := l.evaluateAST(n.right, context)
        if rightErr != nil {
            return false, details, rightErr
        }
        
        // Apply operator
        var result bool
        switch n.operator {
        case "AND":
            result = leftResult && rightResult
        case "OR":
            result = leftResult || rightResult
        default:
            return false, details, fmt.Errorf("unknown operator: %s", n.operator)
        }
        
        // Merge details
        details["operator"] = n.operator
        details["left_result"] = leftResult
        details["right_result"] = rightResult
        details["left_details"] = leftDetails
        details["right_details"] = rightDetails
        
        return result, details, nil
        
    case *unaryOpNode:
        // Evaluate operand
        operandResult, operandDetails, operandErr := l.evaluateAST(n.operand, context)
        if operandErr != nil {
            return false, details, operandErr
        }
        
        // Apply NOT operator
        result := !operandResult
        
        details["operator"] = "NOT"
        details["operand_result"] = operandResult
        details["operand_details"] = operandDetails
        
        return result, details, nil
        
    case *predicateNode:
        // Evaluate predicate
        result, predicateDetails, predicateErr := l.evaluatePredicate(n, context)
        if predicateErr != nil {
            return false, details, predicateErr
        }
        
        // Copy predicate details
        for k, v := range predicateDetails {
            details[k] = v
        }
        
        return result, details, nil
        
    default:
        return false, details, fmt.Errorf("unknown AST node type: %T", node)
    }
}

// evaluatePredicate evaluates a predicate node
func (l *LogicalEvaluator) evaluatePredicate(predicate *predicateNode, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    switch predicate.predicateType {
    case "NEAR":
        return l.evaluateNearPredicate(predicate, context)
    case "ENTITY_TYPE":
        return l.evaluateEntityTypePredicate(predicate, context)
    case "MARKER_TYPE":
        return l.evaluateMarkerTypePredicate(predicate, context)
    default:
        return false, details, fmt.Errorf("unknown predicate type: %s", predicate.predicateType)
    }
}

// evaluateNearPredicate evaluates a NEAR predicate
func (l *LogicalEvaluator) evaluateNearPredicate(predicate *predicateNode, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    if len(predicate.args) < 2 {
        return false, details, fmt.Errorf("NEAR predicate requires at least 2 arguments")
    }
    
    // Parse arguments
    arg1 := predicate.args[0]
    arg2 := predicate.args[1]
    maxDistance := 5 // Default distance
    
    if len(predicate.args) > 2 {
        if dist, err := strconv.Atoi(predicate.args[2]); err == nil {
            maxDistance = dist
        }
    }
    
    // Get markers from context
    markers, ok := context["markers"].([]domain.Marker)
    if !ok {
        return false, details, fmt.Errorf("no markers in context")
    }
    
    // Get entities from context
    entities, _ := context["entities"].([]Entity)
    
    // Find items matching the arguments
    items1 := l.findItems(arg1, markers, entities)
    items2 := l.findItems(arg2, markers, entities)
    
    details["arg1"] = arg1
    details["arg2"] = arg2
    details["max_distance"] = maxDistance
    details["items1_found"] = len(items1)
    details["items2_found"] = len(items2)
    details["items1"] = items1
    details["items2"] = items2
    
    // Check if any pair is within the distance
    for _, item1 := range items1 {
        for _, item2 := range items2 {
            if item1.ID == item2.ID {
                continue // Same item
            }
            
            distance := l.calculateItemDistance(item1, item2)
            if distance <= maxDistance {
                details["matched_pair"] = map[string]interface{}{
                    "item1": item1,
                    "item2": item2,
                    "distance": distance,
                }
                return true, details, nil
            }
        }
    }
    
    return false, details, nil
}

// evaluateEntityTypePredicate evaluates an ENTITY_TYPE predicate
func (l *LogicalEvaluator) evaluateEntityTypePredicate(predicate *predicateNode, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    if len(predicate.args) < 1 {
        return false, details, fmt.Errorf("ENTITY_TYPE predicate requires entity type argument")
    }
    
    entityType := predicate.args[0]
    
    // Get entities from context
    entities, ok := context["entities"].([]Entity)
    if !ok {
        return false, details, fmt.Errorf("no entities in context")
    }
    
    // Find entities of the specified type
    var matchedEntities []Entity
    for _, entity := range entities {
        if entity.Type == entityType {
            matchedEntities = append(matchedEntities, entity)
        }
    }
    
    details["entity_type"] = entityType
    details["entities_found"] = len(matchedEntities)
    details["matched_entities"] = matchedEntities
    
    return len(matchedEntities) > 0, details, nil
}

// evaluateMarkerTypePredicate evaluates a MARKER_TYPE predicate
func (l *LogicalEvaluator) evaluateMarkerTypePredicate(predicate *predicateNode, context map[string]interface{}) (bool, map[string]interface{}, error) {
    details := make(map[string]interface{})
    
    if len(predicate.args) < 1 {
        return false, details, fmt.Errorf("MARKER_TYPE predicate requires marker type argument")
    }
    
    markerType := predicate.args[0]
    
    // Get markers from context
    markers, ok := context["markers"].([]domain.Marker)
    if !ok {
        return false, details, fmt.Errorf("no markers in context")
    }
    
    // Find markers of the specified type
    var matchedMarkers []domain.Marker
    for _, marker := range markers {
        if marker.Type == markerType {
            matchedMarkers = append(matchedMarkers, marker)
        }
    }
    
    details["marker_type"] = markerType
    details["markers_found"] = len(matchedMarkers)
    details["matched_markers"] = matchedMarkers
    
    return len(matchedMarkers) > 0, details, nil
}

// findItems finds items matching a pattern
func (l *LogicalEvaluator) findItems(pattern string, markers []domain.Marker, entities []Entity) []MatchedItem {
    var items []MatchedItem
    
    // Check if pattern is an entity type
    if strings.HasPrefix(pattern, "ENTITY_TYPE:") {
        entityType := strings.TrimPrefix(pattern, "ENTITY_TYPE:")
        for _, entity := range entities {
            if entity.Type == entityType {
                items = append(items, MatchedItem{
                    Type:  "entity",
                    ID:    entity.ID,
                    Text:  entity.Text,
                    Score: entity.Confidence,
                })
            }
        }
    }
    
    // Check if pattern is a marker type
    if strings.HasPrefix(pattern, "MARKER_TYPE:") {
        markerType := strings.TrimPrefix(pattern, "MARKER_TYPE:")
        for _, marker := range markers {
            if marker.Type == markerType {
                items = append(items, MatchedItem{
                    Type:  "marker",
                    ID:    marker.ID,
                    Text:  marker.TextSpan,
                    Score: marker.Confidence,
                })
            }
        }
    }
    
    // Check if pattern is a specific ID
    for _, marker := range markers {
        if marker.ID == pattern {
            items = append(items, MatchedItem{
                Type:  "marker",
                ID:    marker.ID,
                Text:  marker.TextSpan,
                Score: marker.Confidence,
            })
        }
    }
    
    for _, entity := range entities {
        if entity.ID == pattern {
            items = append(items, MatchedItem{
                Type:  "entity",
                ID:    entity.ID,
                Text:  entity.Text,
                Score: entity.Confidence,
            })
        }
    }
    
    return items
}

// calculateItemDistance calculates distance between two items
func (l *LogicalEvaluator) calculateItemDistance(item1, item2 MatchedItem) int {
    // Simple distance calculation based on item type
    // In a real implementation, you would use actual positions from the items
    
    // For now, return a placeholder value
    return 1
}

// calculateConfidence calculates confidence for evaluation result
func (l *LogicalEvaluator) calculateConfidence(details map[string]interface{}) float64 {
    confidence := 0.5 // Base confidence
    
    // Adjust based on matched items count
    if items1Found, ok := details["items1_found"].(int); ok {
        if items1Found > 0 {
            confidence += 0.2
        }
    }
    
    if items2Found, ok := details["items2_found"].(int); ok {
        if items2Found > 0 {
            confidence += 0.2
        }
    }
    
    // Adjust for specific matches
    if _, ok := details["matched_pair"]; ok {
        confidence += 0.1
    }
    
    // Cap at 1.0
    if confidence > 1.0 {
        confidence = 1.0
    }
    
    return confidence
}

// EvaluateAllRules evaluates all compiled logical rules
func (l *LogicalEvaluator) EvaluateAllRules(context map[string]interface{}) []EvaluationResult {
    startTime := time.Now()
    
    auditEvent := domain.NewAuditEvent("logical_evaluator", "evaluate_all_rules")
    auditEvent.AddData("rule_count", len(l.compiledExpressions))
    l.addAuditEvent(auditEvent)
    
    var results []EvaluationResult
    
    for _, expr := range l.compiledExpressions {
        result := &EvaluationResult{
            ExpressionID: expr.ID,
            Success:      false,
            Result:       false,
            Confidence:   0.0,
            MatchedItems: []MatchedItem{},
            Details:      make(map[string]interface{}),
        }
        
        // Evaluate the expression
        evalResult, evalDetails, err := l.EvaluateExpression(expr.Expression, context)
        if err != nil {
            result.Error = err.Error()
        } else {
            result.Success = true
            result.Result = evalResult
            result.Confidence = l.calculateConfidence(evalDetails)
            result.Details = evalDetails
        }
        
        results = append(results, *result)
    }
    
    endEvent := domain.NewAuditEvent("logical_evaluator", "all_rules_evaluated")
    endEvent.AddData("results_count", len(results))
    endEvent.AddData("true_results", l.countTrueResults(results))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    l.addAuditEvent(endEvent)
    
    return results
}

// countTrueResults counts true evaluation results
func (l *LogicalEvaluator) countTrueResults(results []EvaluationResult) int {
    count := 0
    for _, result := range results {
        if result.Result {
            count++
        }
    }
    return count
}

// addAuditEvent adds an audit event
func (l *LogicalEvaluator) addAuditEvent(event *domain.AuditEvent) {
    l.auditEvents = append(l.auditEvents, *event)
}

// GetAuditEvents returns all audit events
func (l *LogicalEvaluator) GetAuditEvents() []domain.AuditEvent {
    return l.auditEvents
}

// AST Node Types
type binaryOpNode struct {
    operator string
    left     interface{}
    right    interface{}
}

type unaryOpNode struct {
    operator string
    operand  interface{}
}

type predicateNode struct {
    predicateType string
    args          []string
}

// Expression Parser
type expressionParser struct {
    tokens []string
    index  int
}

func (p *expressionParser) parseExpression() (interface{}, error) {
    return p.parseOrExpression()
}

func (p *expressionParser) parseOrExpression() (interface{}, error) {
    left, err := p.parseAndExpression()
    if err != nil {
        return nil, err
    }
    
    for p.index < len(p.tokens) && p.tokens[p.index] == "OR" {
        p.index++ // Consume OR
        right, err := p.parseAndExpression()
        if err != nil {
            return nil, err
        }
        left = &binaryOpNode{operator: "OR", left: left, right: right}
    }
    
    return left, nil
}

func (p *expressionParser) parseAndExpression() (interface{}, error) {
    left, err := p.parseNotExpression()
    if err != nil {
        return nil, err
    }
    
    for p.index < len(p.tokens) && p.tokens[p.index] == "AND" {
        p.index++ // Consume AND
        right, err := p.parseNotExpression()
        if err != nil {
            return nil, err
        }
        left = &binaryOpNode{operator: "AND", left: left, right: right}
    }
    
    return left, nil
}

func (p *expressionParser) parseNotExpression() (interface{}, error) {
    if p.index < len(p.tokens) && p.tokens[p.index] == "NOT" {
        p.index++ // Consume NOT
        operand, err := p.parsePrimaryExpression()
        if err != nil {
            return nil, err
        }
        return &unaryOpNode{operator: "NOT", operand: operand}, nil
    }
    
    return p.parsePrimaryExpression()
}

func (p *expressionParser) parsePrimaryExpression() (interface{}, error) {
    if p.index >= len(p.tokens) {
        return nil, fmt.Errorf("unexpected end of expression")
    }
    
    token := p.tokens[p.index]
    
    if token == "(" {
        p.index++ // Consume (
        expr, err := p.parseExpression()
        if err != nil {
            return nil, err
        }
        if p.index >= len(p.tokens) || p.tokens[p.index] != ")" {
            return nil, fmt.Errorf("expected )")
        }
        p.index++ // Consume )
        return expr, nil
    }
    
    // Check for predicates
    if strings.HasPrefix(token, "NEAR(") ||
       strings.HasPrefix(token, "ENTITY_TYPE:") ||
       strings.HasPrefix(token, "MARKER_TYPE:") {
        
        // Parse predicate
        predicate, args, err := p.parsePredicate(token)
        if err != nil {
            return nil, err
        }
        
        return &predicateNode{
            predicateType: predicate,
            args:          args,
        }, nil
    }
    
    // Simple identifier
    p.index++
    return &predicateNode{
        predicateType: "IDENTIFIER",
        args:          []string{token},
    }, nil
}

func (p *expressionParser) parsePredicate(token string) (string, []string, error) {
    if strings.HasPrefix(token, "NEAR(") {
        // Parse NEAR predicate
        // This is simplified - in reality, you'd need to handle the full expression
        return "NEAR", []string{"arg1", "arg2", "5"}, nil
    }
    
    if strings.HasPrefix(token, "ENTITY_TYPE:") {
        entityType := strings.TrimPrefix(token, "ENTITY_TYPE:")
        return "ENTITY_TYPE", []string{entityType}, nil
    }
    
    if strings.HasPrefix(token, "MARKER_TYPE:") {
        markerType := strings.TrimPrefix(token, "MARKER_TYPE:")
        return "MARKER_TYPE", []string{markerType}, nil
    }
    
    return "", nil, fmt.Errorf("unknown predicate: %s", token)
}
```

## **4. Pipeline Integration**

### **cmd/pipeline/orchestrator.go**
```go
package pipeline

import (
    "fmt"
    "sync"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/engine/atomic"
    "semantic-analyzer/internal/engine/composite"
    "semantic-analyzer/internal/engine/semantic"
    "semantic-analyzer/internal/rules"
    "semantic-analyzer/pkg/config"
    "semantic-analyzer/pkg/determinism"
)

// Orchestrator coordinates the analysis pipeline
type Orchestrator struct {
    config        *config.Config
    seedManager   *determinism.SeedManager
    atomicDetector *atomic.Detector
    compositeBuilder *composite.Builder
    compositeScorer *composite.Scorer
    compositeSelector *composite.Selector
    nerEngine     *semantic.NEREngine
    proximityAnalyzer *semantic.ProximityAnalyzer
    logicalEvaluator *semantic.LogicalEvaluator
    auditTrail    *domain.AuditTrail
    mu            sync.RWMutex
}

// NewOrchestrator creates a new pipeline orchestrator
func NewOrchestrator(cfg *config.Config) (*Orchestrator, error) {
    // Initialize seed manager
    seedManager := determinism.NewSeedManager(cfg.Determinism.BaseSeed)
    
    // Initialize rule engine
    ruleEngine, err := rules.NewRuleEngine(cfg.Rules.Atomic)
    if err != nil {
        return nil, fmt.Errorf("failed to initialize rule engine: %w", err)
    }
    
    // Initialize atomic detector
    atomicDetector := atomic.NewDetector(ruleEngine, seedManager)
    
    // Initialize composite components
    compositeBuilder := composite.NewBuilder(cfg.Rules.Composite)
    compositeScorer := composite.NewScorer(cfg.Rules.Composite)
    compositeSelector := composite.NewSelector(seedManager)
    
    // Initialize semantic components
    nerEngine := semantic.NewNEREngine(cfg.Rules.Semantic.NER)
    proximityAnalyzer := semantic.NewProximityAnalyzer(cfg.Rules.Semantic)
    logicalEvaluator := semantic.NewLogicalEvaluator(cfg.Rules.Semantic)
    
    // Create audit trail
    rootEvent := domain.NewAuditEvent("pipeline", "start")
    auditTrail := domain.NewAuditTrail(rootEvent)
    
    return &Orchestrator{
        config:           cfg,
        seedManager:      seedManager,
        atomicDetector:   atomicDetector,
        compositeBuilder: compositeBuilder,
        compositeScorer:  compositeScorer,
        compositeSelector: compositeSelector,
        nerEngine:        nerEngine,
        proximityAnalyzer: proximityAnalyzer,
        logicalEvaluator: logicalEvaluator,
        auditTrail:       auditTrail,
    }, nil
}

// Process runs the complete analysis pipeline
func (o *Orchestrator) Process(transcript *domain.Transcript) (*domain.AnalysisResult, error) {
    startTime := time.Now()
    
    // Create analysis result
    result := domain.NewAnalysisResult(transcript.ID)
    result.Transcript = transcript
    result.Timestamp = time.Now()
    result.ConfigHash = o.seedManager.DeterministicHash(fmt.Sprintf("%v", o.config))
    
    // Add pipeline start audit event
    pipelineStart := domain.NewAuditEvent("pipeline", "process_start")
    pipelineStart.AddData("transcript_id", transcript.ID)
    pipelineStart.AddData("text_length", len(transcript.RawText))
    o.addAuditEvent(pipelineStart)
    
    // Phase 1: Atomic Marker Detection
    atomicMarkers, atomicEvents, err := o.processAtomicPhase(transcript)
    if err != nil {
        return nil, fmt.Errorf("atomic phase failed: %w", err)
    }
    result.AddAuditEvents(atomicEvents)
    
    // Phase 2: Composite Aggregation
    compositeMarkers, compositeEvents, err := o.processCompositePhase(transcript, atomicMarkers)
    if err != nil {
        return nil, fmt.Errorf("composite phase failed: %w", err)
    }
    result.AddAuditEvents(compositeEvents)
    
    // Phase 3: Semantic Analysis
    semanticResults, semanticEvents, err := o.processSemanticPhase(transcript, atomicMarkers, compositeMarkers)
    if err != nil {
        return nil, fmt.Errorf("semantic phase failed: %w", err)
    }
    result.AddAuditEvents(semanticEvents)
    
    // Combine all markers
    allMarkers := o.combineMarkers(atomicMarkers, compositeMarkers, semanticResults)
    
    // Add markers to result
    for _, marker := range allMarkers {
        result.AddMarker(marker)
    }
    
    // Update statistics
    result.Statistics.ProcessingTime = time.Since(startTime).Seconds()
    result.Statistics.SentenceCount = len(transcript.Sentences)
    result.Statistics.WordCount = transcript.TokenCount
    
    // Add pipeline completion audit event
    pipelineEnd := domain.NewAuditEvent("pipeline", "process_complete")
    pipelineEnd.AddData("total_markers", len(allMarkers))
    pipelineEnd.AddData("atomic_markers", len(atomicMarkers))
    pipelineEnd.AddData("composite_markers", len(compositeMarkers))
    pipelineEnd.AddData("semantic_results", len(semanticResults))
    pipelineEnd.AddData("total_time_seconds", time.Since(startTime).Seconds())
    pipelineEnd.SetDuration(startTime)
    o.addAuditEvent(pipelineEnd)
    
    // Set audit trail
    result.AuditTrail = o.auditTrail
    
    return result, nil
}

// processAtomicPhase processes the atomic detection phase
func (o *Orchestrator) processAtomicPhase(transcript *domain.Transcript) ([]domain.Marker, []domain.AuditEvent, error) {
    phaseStart := time.Now()
    
    phaseEvent := domain.NewAuditEvent("pipeline_phase", "atomic_detection_start")
    phaseEvent.AddData("phase", "atomic")
    o.addAuditEvent(phaseEvent)
    
    // Detect atomic markers
    markers, auditEvents, err := o.atomicDetector.Detect(transcript.ProcessedText)
    if err != nil {
        return nil, nil, fmt.Errorf("atomic detection failed: %w", err)
    }
    
    // Add audit events
    o.addAuditEvents(auditEvents)
    
    phaseEnd := domain.NewAuditEvent("pipeline_phase", "atomic_detection_complete")
    phaseEnd.AddData("phase", "atomic")
    phaseEnd.AddData("markers_found", len(markers))
    phaseEnd.AddData("processing_time_ms", time.Since(phaseStart).Milliseconds())
    phaseEnd.SetDuration(phaseStart)
    o.addAuditEvent(phaseEnd)
    
    return markers, auditEvents, nil
}

// processCompositePhase processes the composite aggregation phase
func (o *Orchestrator) processCompositePhase(transcript *domain.Transcript, atomicMarkers []domain.Marker) ([]domain.Marker, []domain.AuditEvent, error) {
    phaseStart := time.Now()
    
    phaseEvent := domain.NewAuditEvent("pipeline_phase", "composite_aggregation_start")
    phaseEvent.AddData("phase", "composite")
    phaseEvent.AddData("atomic_markers", len(atomicMarkers))
    o.addAuditEvent(phaseEvent)
    
    // Build context windows
    candidates := o.compositeBuilder.BuildContextWindows(atomicMarkers, transcript.Sentences)
    
    // Score candidates
    scoredCandidates := o.compositeScorer.ScoreAllCandidates(candidates)
    
    // Select top candidates
    selectedCandidates := o.compositeSelector.SelectTopCandidates(
        scoredCandidates,
        o.config.Rules.Composite.MaxCandidates,
    )
    
    // Convert candidates to markers
    compositeMarkers := o.candidatesToMarkers(selectedCandidates, transcript.ProcessedText)
    
    // Get audit events
    auditEvents := append(
        o.compositeBuilder.GetAuditEvents(),
        o.compositeScorer.GetAuditEvents()...,
    )
    auditEvents = append(auditEvents, o.compositeSelector.GetAuditEvents()...)
    
    // Add audit events
    o.addAuditEvents(auditEvents)
    
    phaseEnd := domain.NewAuditEvent("pipeline_phase", "composite_aggregation_complete")
    phaseEnd.AddData("phase", "composite")
    phaseEnd.AddData("candidates_created", len(candidates))
    phaseEnd.AddData("candidates_selected", len(selectedCandidates))
    phaseEnd.AddData("composite_markers", len(compositeMarkers))
    phaseEnd.AddData("processing_time_ms", time.Since(phaseStart).Milliseconds())
    phaseEnd.SetDuration(phaseStart)
    o.addAuditEvent(phaseEnd)
    
    return compositeMarkers, auditEvents, nil
}

// processSemanticPhase processes the semantic analysis phase
func (o *Orchestrator) processSemanticPhase(transcript *domain.Transcript, atomicMarkers, compositeMarkers []domain.Marker) ([]domain.Marker, []domain.AuditEvent, error) {
    phaseStart := time.Now()
    
    phaseEvent := domain.NewAuditEvent("pipeline_phase", "semantic_analysis_start")
    phaseEvent.AddData("phase", "semantic")
    phaseEvent.AddData("atomic_markers", len(atomicMarkers))
    phaseEvent.AddData("composite_markers", len(compositeMarkers))
    o.addAuditEvent(phaseEvent)
    
    var semanticMarkers []domain.Marker
    var allAuditEvents []domain.AuditEvent
    
    // Step 1: Named Entity Recognition
    entities := o.nerEngine.ExtractEntities(transcript.ProcessedText)
    nerMarkers := o.entitiesToMarkers(entities)
    semanticMarkers = append(semanticMarkers, nerMarkers...)
    allAuditEvents = append(allAuditEvents, o.nerEngine.GetAuditEvents()...)
    
    // Step 2: Semantic Proximity Analysis
    allMarkers := append(atomicMarkers, compositeMarkers...)
    proximityResults := o.proximityAnalyzer.CalculateBatchRelatedness(allMarkers, 10)
    proximityMarkers := o.proximityResultsToMarkers(proximityResults)
    semanticMarkers = append(semanticMarkers, proximityMarkers...)
    allAuditEvents = append(allAuditEvents, o.proximityAnalyzer.GetAuditEvents()...)
    
    // Step 3: Logical Expression Evaluation
    context := map[string]interface{}{
        "markers":  allMarkers,
        "entities": entities,
        "text":     transcript.ProcessedText,
        "sentences": transcript.Sentences,
    }
    
    logicalResults := o.logicalEvaluator.EvaluateAllRules(context)
    logicalMarkers := o.logicalResultsToMarkers(logicalResults)
    semanticMarkers = append(semanticMarkers, logicalMarkers...)
    allAuditEvents = append(allAuditEvents, o.logicalEvaluator.GetAuditEvents()...)
    
    // Add audit events
    o.addAuditEvents(allAuditEvents)
    
    phaseEnd := domain.NewAuditEvent("pipeline_phase", "semantic_analysis_complete")
    phaseEnd.AddData("phase", "semantic")
    phaseEnd.AddData("entities_found", len(entities))
    phaseEnd.AddData("proximity_pairs", len(proximityResults))
    phaseEnd.AddData("logical_results", len(logicalResults))
    phaseEnd.AddData("semantic_markers", len(semanticMarkers))
    phaseEnd.AddData("processing_time_ms", time.Since(phaseStart).Milliseconds())
    phaseEnd.SetDuration(phaseStart)
    o.addAuditEvent(phaseEnd)
    
    return semanticMarkers, allAuditEvents, nil
}

// candidatesToMarkers converts composite candidates to markers
func (o *Orchestrator) candidatesToMarkers(candidates []composite.CompositeCandidate, text string) []domain.Marker {
    var markers []domain.Marker
    
    for _, candidate := range candidates {
        marker := domain.NewMarker(
            2, // Level 2 for composite markers
            "COMPOSITE",
            text[candidate.SpanStart:min(candidate.SpanEnd, len(text))],
            candidate.SpanStart,
            candidate.SpanEnd,
            candidate.Score,
            "composite_engine",
            false, // Not atomic
        )
        
        // Add candidate metadata
        marker.AddMetadata("candidate_id", candidate.ID)
        marker.AddMetadata("marker_count", candidate.MarkerCount)
        marker.AddMetadata("density", candidate.Density)
        marker.AddMetadata("type_diversity", candidate.TypeDiversity)
        marker.AddMetadata("primary_type", candidate.PrimaryType)
        marker.AddMetadata("sentence_ids", candidate.SentenceIDs)
        
        // Add candidate scoring details
        if scoringDetails, ok := candidate.Metadata["scoring_components"].(map[string]interface{}); ok {
            marker.AddMetadata("scoring_details", scoringDetails)
        }
        
        markers = append(markers, *marker)
    }
    
    return markers
}

// entitiesToMarkers converts entities to markers
func (o *Orchestrator) entitiesToMarkers(entities []semantic.Entity) []domain.Marker {
    var markers []domain.Marker
    
    for _, entity := range entities {
        marker := domain.NewMarker(
            3, // Level 3 for entity markers
            entity.Type,
            entity.Text,
            entity.Start,
            entity.End,
            entity.Confidence,
            entity.RuleID,
            true, // Entities are atomic
        )
        
        // Add entity metadata
        marker.AddMetadata("entity_id", entity.ID)
        if entity.Metadata != nil {
            for k, v := range entity.Metadata {
                marker.AddMetadata(k, v)
            }
        }
        
        markers = append(markers, *marker)
    }
    
    return markers
}

// proximityResultsToMarkers converts proximity results to markers
func (o *Orchestrator) proximityResultsToMarkers(results []semantic.ProximityResult) []domain.Marker {
    var markers []domain.Marker
    
    for _, result := range results {
        // Create a marker for significant proximity relationships
        if result.Relatedness > 0.7 {
            marker := domain.NewMarker(
                4, // Level 4 for proximity markers
                "SEMANTIC_PROXIMITY",
                fmt.Sprintf("%s - %s", result.Marker1ID, result.Marker2ID),
                0, // No specific position
                0,
                result.Relatedness,
                "proximity_analyzer",
                false,
            )
            
            // Add proximity details
            marker.AddMetadata("marker1_id", result.Marker1ID)
            marker.AddMetadata("marker2_id", result.Marker2ID)
            marker.AddMetadata("shared_networks", result.SharedNetworks)
            marker.AddMetadata("context_overlap", result.ContextOverlap)
            marker.AddMetadata("type_similarity", result.TypeSimilarity)
            
            if result.Details != nil {
                marker.AddMetadata("proximity_details", result.Details)
            }
            
            markers = append(markers, *marker)
        }
    }
    
    return markers
}

// logicalResultsToMarkers converts logical evaluation results to markers
func (o *Orchestrator) logicalResultsToMarkers(results []semantic.EvaluationResult) []domain.Marker {
    var markers []domain.Marker
    
    for _, result := range results {
        if result.Success && result.Result {
            marker := domain.NewMarker(
                5, // Level 5 for logical rule markers
                "LOGICAL_RULE",
                result.ExpressionID,
                0, // No specific position
                0,
                result.Confidence,
                "logical_evaluator",
                false,
            )
            
            // Add evaluation details
            marker.AddMetadata("expression_id", result.ExpressionID)
            marker.AddMetadata("matched_items", len(result.MatchedItems))
            
            if result.Details != nil {
                marker.AddMetadata("evaluation_details", result.Details)
            }
            
            markers = append(markers, *marker)
        }
    }
    
    return markers
}

// combineMarkers combines all markers from different phases
func (o *Orchestrator) combineMarkers(atomicMarkers, compositeMarkers, semanticMarkers []domain.Marker) []domain.Marker {
    var allMarkers []domain.Marker
    
    allMarkers = append(allMarkers, atomicMarkers...)
    allMarkers = append(allMarkers, compositeMarkers...)
    allMarkers = append(allMarkers, semanticMarkers...)
    
    // Sort by level and position
    o.sortMarkers(allMarkers)
    
    return allMarkers
}

// sortMarkers sorts markers by level and position
func (o *Orchestrator) sortMarkers(markers []domain.Marker) {
    sort.Slice(markers, func(i, j int) bool {
        if markers[i].Level == markers[j].Level {
            if markers[i].Start == markers[j].Start {
                return markers[i].End < markers[j].End
            }
            return markers[i].Start < markers[j].Start
        }
        return markers[i].Level < markers[j].Level
    })
}

// addAuditEvent adds an audit event to the audit trail
func (o *Orchestrator) addAuditEvent(event *domain.AuditEvent) {
    o.mu.Lock()
    defer o.mu.Unlock()
    
    if o.auditTrail == nil {
        o.auditTrail = domain.NewAuditTrail(event)
    } else {
        o.auditTrail.AddEvent(event)
    }
}

// addAuditEvents adds multiple audit events
func (o *Orchestrator) addAuditEvents(events []domain.AuditEvent) {
    for _, event := range events {
        o.addAuditEvent(&event)
    }
}

// GetAuditTrail returns the audit trail
func (o *Orchestrator) GetAuditTrail() *domain.AuditTrail {
    o.mu.RLock()
    defer o.mu.RUnlock()
    return o.auditTrail
}

// Helper function
func min(a, b int) int {
    if a < b {
        return a
    }
    return b
}
```

## **5. Updated CLI**

### **cmd/cli/main.go** (updated for pipeline)
```go
package main

import (
    "encoding/json"
    "flag"
    "fmt"
    "log"
    "os"
    "path/filepath"
    "time"

    "semantic-analyzer/cmd/pipeline"
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/processor/text"
    "semantic-analyzer/pkg/config"
    "semantic-analyzer/pkg/determinism"
)

func main() {
    // Parse command line arguments
    configPath := flag.String("config", "./configs/config.yaml", "Path to configuration file")
    inputPath := flag.String("input", "", "Path to input text file (required)")
    outputDir := flag.String("output", "./results", "Output directory for results")
    flag.Parse()

    if *inputPath == "" {
        log.Fatal("Input file path is required. Use --input flag.")
    }

    // Create output directory if it doesn't exist
    if err := os.MkdirAll(*outputDir, 0755); err != nil {
        log.Fatalf("Failed to create output directory: %v", err)
    }

    // Initialize system
    if err := runAnalysis(*configPath, *inputPath, *outputDir); err != nil {
        log.Fatalf("Analysis failed: %v", err)
    }

    log.Println("Analysis completed successfully")
}

func runAnalysis(configPath, inputPath, outputDir string) error {
    startTime := time.Now()

    // Load configuration
    cfg, err := config.Load(configPath)
    if err != nil {
        return fmt.Errorf("failed to load config: %w", err)
    }

    // Initialize seed manager for determinism
    seedManager := determinism.NewSeedManager(cfg.Determinism.BaseSeed)

    // Read input file
    inputContent, err := os.ReadFile(inputPath)
    if err != nil {
        return fmt.Errorf("failed to read input file: %w", err)
    }

    // Create transcript
    transcript := &domain.Transcript{
        ID:        seedManager.DeterministicHash(string(inputContent)),
        RawText:   string(inputContent),
        Source:    filepath.Base(inputPath),
        CreatedAt: time.Now(),
        Metadata: map[string]interface{}{
            "file_size":    len(inputContent),
            "config_path":  configPath,
            "analysis_time": startTime.Format(time.RFC3339),
        },
    }

    // Initialize preprocessor
    preprocessor := text.NewPreprocessor(cfg.Processing)

    // Preprocess text
    preprocessedText := preprocessor.Normalize(transcript.RawText)
    sentences := preprocessor.SegmentIntoSentences(preprocessedText)
    tokens := preprocessor.Tokenize(preprocessedText)

    transcript.ProcessedText = preprocessedText
    transcript.Sentences = sentences
    transcript.TokenCount = len(tokens)

    // Initialize pipeline orchestrator
    orchestrator, err := pipeline.NewOrchestrator(cfg)
    if err != nil {
        return fmt.Errorf("failed to initialize pipeline: %w", err)
    }

    // Run complete analysis pipeline
    result, err := orchestrator.Process(transcript)
    if err != nil {
        return fmt.Errorf("pipeline processing failed: %w", err)
    }

    // Generate output filename
    outputFile := filepath.Join(outputDir, 
        fmt.Sprintf("analysis_%s_%s.json", 
            transcript.ID[:8], 
            time.Now().Format("20060102_150405")))

    // Write results to file
    outputData, err := json.MarshalIndent(result, "", "  ")
    if err != nil {
        return fmt.Errorf("failed to marshal results: %w", err)
    }

    if err := os.WriteFile(outputFile, outputData, 0644); err != nil {
        return fmt.Errorf("failed to write output file: %w", err)
    }

    // Print summary
    printSummary(result, outputFile, time.Since(startTime))

    return nil
}

func printSummary(result *domain.AnalysisResult, outputFile string, duration time.Duration) {
    fmt.Printf("\n=== Analysis Summary ===\n")
    fmt.Printf("Transcript ID: %s\n", result.TranscriptID[:12])
    fmt.Printf("Source: %s\n", result.Transcript.Source)
    fmt.Printf("Total words: %d\n", result.Transcript.TokenCount)
    fmt.Printf("Total sentences: %d\n", len(result.Transcript.Sentences))
    fmt.Printf("Total markers: %d\n", result.Statistics.TotalMarkers)
    fmt.Printf("  - Atomic markers: %d\n", result.Statistics.AtomicMarkers)
    fmt.Printf("  - Composite markers: %d\n", result.Statistics.CompositeMarkers)
    fmt.Printf("  - Semantic markers: %d\n", result.Statistics.TotalMarkers - result.Statistics.AtomicMarkers - result.Statistics.CompositeMarkers)
    fmt.Printf("Average confidence: %.2f\n", result.Statistics.AverageConfidence)
    fmt.Printf("Processing time: %v\n", duration)
    fmt.Printf("Output file: %s\n", outputFile)
    
    if len(result.Statistics.MarkerTypes) > 0 {
        fmt.Printf("\nMarker types:\n")
        for t, c := range result.Statistics.MarkerTypes {
            fmt.Printf("  %s: %d\n", t, c)
        }
    }
    fmt.Println()
}
```

## **6. Test Files**

### **internal/engine/composite/builder_test.go**
```go
package composite_test

import (
    "testing"
    
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/engine/composite"
    "semantic-analyzer/pkg/config"
)

func TestBuilder_BuildContextWindows(t *testing.T) {
    // Create test configuration
    cfg := config.CompositeRulesConfig{
        ProximityWindow: 2,
        MinDensity:      0.1,
        MaxSpan:         100,
        MaxCandidates:   10,
        SelectionWeights: config.SelectionWeights{
            MarkerCount:   0.4,
            Density:       0.3,
            SpanCompactness: 0.2,
            TypeDiversity: 0.1,
        },
        TypeWeights: map[string]float64{
            "CONTACT":  1.0,
            "PRIORITY": 0.8,
        },
    }
    
    builder := composite.NewBuilder(cfg)
    
    // Create test atomic markers
    atomicMarkers := []domain.Marker{
        *domain.NewMarker(1, "CONTACT", "test@example.com", 10, 25, 0.9, "email_pattern", true),
        *domain.NewMarker(1, "PRIORITY", "urgent", 40, 46, 0.6, "important_terms", true),
        *domain.NewMarker(1, "CONTACT", "123-456-7890", 60, 73, 0.85, "phone_pattern", true),
    }
    
    // Create test sentences
    sentences := []string{
        "Contact us at test@example.com for assistance.",
        "This is an urgent matter.",
        "Call 123-456-7890 for immediate support.",
    }
    
    // Build context windows
    candidates := builder.BuildContextWindows(atomicMarkers, sentences)
    
    // Verify results
    if len(candidates) == 0 {
        t.Error("Expected at least one candidate, got none")
    }
    
    // Check that candidates have markers
    for i, candidate := range candidates {
        if candidate.MarkerCount < 2 {
            t.Errorf("Candidate %d should have at least 2 markers, got %d", i, candidate.MarkerCount)
        }
        
        if candidate.Density < cfg.MinDensity {
            t.Errorf("Candidate %d density %f below minimum %f", i, candidate.Density, cfg.MinDensity)
        }
        
        if candidate.SpanLength > cfg.MaxSpan {
            t.Errorf("Candidate %d span length %d exceeds maximum %d", i, candidate.SpanLength, cfg.MaxSpan)
        }
    }
}

func TestBuilder_MergeSimilarCandidates(t *testing.T) {
    cfg := config.CompositeRulesConfig{
        ProximityWindow: 2,
        MinDensity:      0.1,
        MaxSpan:         200,
        MaxCandidates:   10,
    }
    
    builder := composite.NewBuilder(cfg)
    
    // Create overlapping candidates
    candidates := []composite.CompositeCandidate{
        {
            ID:         "candidate1",
            SpanStart:  0,
            SpanEnd:    100,
            MarkerCount: 3,
        },
        {
            ID:         "candidate2",
            SpanStart:  50,
            SpanEnd:    150,
            MarkerCount: 2,
        },
        {
            ID:         "candidate3",
            SpanStart:  200,
            SpanEnd:    300,
            MarkerCount: 2,
        },
    }
    
    // Merge similar candidates
    merged := builder.MergeSimilarCandidates(candidates, 0.5)
    
    // Verify merging
    if len(merged) >= len(candidates) {
        t.Errorf("Expected fewer candidates after merging, got %d (was %d)", len(merged), len(candidates))
    }
    
    // Verify non-overlapping candidate remains separate
    foundNonOverlapping := false
    for _, candidate := range merged {
        if candidate.SpanStart == 200 && candidate.SpanEnd == 300 {
            foundNonOverlapping = true
            break
        }
    }
    
    if !foundNonOverlapping {
        t.Error("Non-overlapping candidate should remain separate")
    }
}
