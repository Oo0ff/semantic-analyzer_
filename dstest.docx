## **2. Phase 6: Final Processing & Filtering**

### **internal/engine/postprocess/types.go**
```go
package postprocess

import "semantic-analyzer/internal/domain"

// SuppressionPattern defines a pattern for suppressing false positives
type SuppressionPattern struct {
    Pattern     string  `json:"pattern"`
    Reason      string  `json:"reason"`
    Weight      float64 `json:"weight"`
    Compiled    interface{} `json:"-"`
}

// DeduplicationConfig contains deduplication settings
type DeduplicationConfig struct {
    OverlapThreshold   float64 `json:"overlap_threshold"`
    MergeSameType      bool    `json:"merge_same_type"`
    MaxGapForMerge     int     `json:"max_gap_for_merge"`
    EnableCrossLevel   bool    `json:"enable_cross_level_dedup"`
}

// ConflictResolutionConfig contains conflict resolution settings
type ConflictResolutionConfig struct {
    PriorityWeights PriorityWeights `json:"priority_weights"`
    Hierarchy       []int           `json:"hierarchy"`
}

// PriorityWeights defines weights for conflict resolution
type PriorityWeights struct {
    Level        []float64 `json:"level"`
    Confidence   float64   `json:"confidence"`
    SpanLength   float64   `json:"span_length"`
    RulePriority float64   `json:"rule_priority"`
}

// OutputFormattingConfig contains output formatting settings
type OutputFormattingConfig struct {
    IncludeContext          bool `json:"include_context"`
    ContextSentences        int  `json:"context_sentences"`
    IncludeParagraph        bool `json:"include_paragraph"`
    MaxContextChars         int  `json:"max_context_chars"`
    GenerateDeterministicIDs bool `json:"generate_deterministic_ids"`
}

// Conflict represents a marker conflict
type Conflict struct {
    ID           string               `json:"id"`
    Marker1ID    string               `json:"marker1_id"`
    Marker2ID    string               `json:"marker2_id"`
    OverlapRatio float64              `json:"overlap_ratio"`
    Resolution   string               `json:"resolution"`
    WinnerID     string               `json:"winner_id,omitempty"`
    Reason       string               `json:"reason"`
    Timestamp    int64                `json:"timestamp"`
    Metadata     map[string]interface{} `json:"metadata,omitempty"`
}

// FilterStats contains filtering statistics
type FilterStats struct {
    TotalInputMarkers   int `json:"total_input_markers"`
    SuppressedMarkers   int `json:"suppressed_markers"`
    DeduplicatedMarkers int `json:"deduplicated_markers"`
    MergedMarkers       int `json:"merged_markers"`
    ConflictsResolved   int `json:"conflicts_resolved"`
    FinalMarkers        int `json:"final_markers"`
    ProcessingTimeMS    int64 `json:"processing_time_ms"`
}
```

### **internal/engine/postprocess/filter.go**
```go
package postprocess

import (
    "fmt"
    "regexp"
    "sort"
    "strings"
    "sync"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/determinism"
)

// Filter implements post-processing filters
type Filter struct {
    suppressionPatterns []SuppressionPattern
    dedupConfig        DeduplicationConfig
    seedManager        *determinism.SeedManager
    auditEvents        []domain.AuditEvent
    compiledRegex      map[string]*regexp.Regexp
    stats              FilterStats
    mu                 sync.RWMutex
}

// NewFilter creates a new post-processing filter
func NewFilter(
    suppressionPatterns []SuppressionPattern,
    dedupConfig DeduplicationConfig,
    seedManager *determinism.SeedManager,
) *Filter {
    
    f := &Filter{
        suppressionPatterns: suppressionPatterns,
        dedupConfig:        dedupConfig,
        seedManager:        seedManager,
        auditEvents:        []domain.AuditEvent{},
        compiledRegex:      make(map[string]*regexp.Regexp),
        stats:              FilterStats{},
    }
    
    f.compileSuppressionPatterns()
    return f
}

// compileSuppressionPatterns compiles all regex patterns
func (f *Filter) compileSuppressionPatterns() {
    f.mu.Lock()
    defer f.mu.Unlock()
    
    for _, pattern := range f.suppressionPatterns {
        compiled, err := regexp.Compile(pattern.Pattern)
        if err != nil {
            // Log error but continue with other patterns
            continue
        }
        f.compiledRegex[pattern.Pattern] = compiled
    }
}

// ApplyAllFilters applies all post-processing filters
func (f *Filter) ApplyAllFilters(markers []domain.Marker, text string) ([]domain.Marker, []domain.AuditEvent, FilterStats) {
    startTime := time.Now()
    
    // Create audit event for filter start
    startEvent := domain.NewAuditEvent("postprocessing", "start")
    startEvent.AddData("input_markers", len(markers))
    startEvent.AddData("text_length", len(text))
    f.addAuditEvent(startEvent)
    
    f.stats.TotalInputMarkers = len(markers)
    
    // Apply filters in sequence
    filtered := markers
    
    // 1. Suppression filter
    filtered, suppressed := f.applySuppressionFilter(filtered, text)
    f.stats.SuppressedMarkers = suppressed
    
    // 2. Deduplication filter
    filtered, dedupCount := f.applyDeduplicationFilter(filtered)
    f.stats.DeduplicatedMarkers = dedupCount
    
    // 3. Span consolidation
    if f.dedupConfig.MergeSameType {
        filtered, mergedCount := f.applySpanConsolidation(filtered)
        f.stats.MergedMarkers = mergedCount
    }
    
    // Update final count
    f.stats.FinalMarkers = len(filtered)
    f.stats.ProcessingTimeMS = time.Since(startTime).Milliseconds()
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("postprocessing", "complete")
    endEvent.AddData("final_markers", f.stats.FinalMarkers)
    endEvent.AddData("suppressed_markers", f.stats.SuppressedMarkers)
    endEvent.AddData("deduplicated_markers", f.stats.DeduplicatedMarkers)
    endEvent.AddData("merged_markers", f.stats.MergedMarkers)
    endEvent.AddData("processing_time_ms", f.stats.ProcessingTimeMS)
    endEvent.SetDuration(startTime)
    f.addAuditEvent(endEvent)
    
    return filtered, f.auditEvents, f.stats
}

// applySuppressionFilter removes markers matching suppression patterns
func (f *Filter) applySuppressionFilter(markers []domain.Marker, text string) ([]domain.Marker, int) {
    startTime := time.Now()
    
    event := domain.NewAuditEvent("suppression_filter", "start")
    event.AddData("patterns_count", len(f.suppressionPatterns))
    f.addAuditEvent(event)
    
    var filtered []domain.Marker
    suppressedCount := 0
    
    for _, marker := range markers {
        shouldSuppress := false
        suppressionReason := ""
        
        // Check against all suppression patterns
        for _, pattern := range f.suppressionPatterns {
            compiled, exists := f.compiledRegex[pattern.Pattern]
            if !exists {
                continue
            }
            
            if compiled.MatchString(marker.TextSpan) {
                shouldSuppress = true
                suppressionReason = pattern.Reason
                
                // Create audit event for suppression
                suppEvent := domain.NewAuditEvent("suppression_filter", "suppress_marker")
                suppEvent.MarkerID = marker.ID
                suppEvent.AddData("pattern", pattern.Pattern)
                suppEvent.AddData("reason", pattern.Reason)
                suppEvent.AddData("weight", pattern.Weight)
                suppEvent.AddData("marker_text", marker.TextSpan)
                f.addAuditEvent(suppEvent)
                
                break
            }
        }
        
        if !shouldSuppress {
            filtered = append(filtered, marker)
        } else {
            suppressedCount++
            
            // Add suppression metadata to marker
            marker.AddMetadata("suppressed", true)
            marker.AddMetadata("suppression_reason", suppressionReason)
            marker.Confidence = marker.Confidence * 0.1 // Drastically reduce confidence
        }
    }
    
    event = domain.NewAuditEvent("suppression_filter", "complete")
    event.AddData("suppressed_count", suppressedCount)
    event.AddData("remaining_markers", len(filtered))
    event.SetDuration(startTime)
    f.addAuditEvent(event)
    
    return filtered, suppressedCount
}

// applyDeduplicationFilter removes duplicate markers
func (f *Filter) applyDeduplicationFilter(markers []domain.Marker) ([]domain.Marker, int) {
    startTime := time.Now()
    
    event := domain.NewAuditEvent("deduplication_filter", "start")
    event.AddData("overlap_threshold", f.dedupConfig.OverlapThreshold)
    f.addAuditEvent(event)
    
    if len(markers) <= 1 {
        return markers, 0
    }
    
    // Sort markers by start position for deterministic processing
    sortedMarkers := make([]domain.Marker, len(markers))
    copy(sortedMarkers, markers)
    f.deterministicSortByPosition(sortedMarkers)
    
    var unique []domain.Marker
    dedupCount := 0
    
    for i := 0; i < len(sortedMarkers); i++ {
        current := sortedMarkers[i]
        keepCurrent := true
        
        // Check against already kept markers
        for j := 0; j < len(unique); j++ {
            existing := unique[j]
            
            // Calculate overlap
            overlapRatio := f.calculateOverlapRatio(&current, &existing)
            
            if overlapRatio >= f.dedupConfig.OverlapThreshold {
                // Determine which marker to keep
                keepCurrent = f.shouldKeepMarker(&current, &existing, overlapRatio)
                
                if !keepCurrent {
                    dedupCount++
                    
                    // Create audit event for deduplication
                    dedupEvent := domain.NewAuditEvent("deduplication_filter", "remove_duplicate")
                    dedupEvent.MarkerID = current.ID
                    dedupEvent.AddData("overlap_ratio", overlapRatio)
                    dedupEvent.AddData("kept_marker_id", existing.ID)
                    dedupEvent.AddData("reason", "high_overlap")
                    f.addAuditEvent(dedupEvent)
                    
                    break
                } else {
                    // Remove existing and keep current
                    unique = append(unique[:j], unique[j+1:]...)
                    dedupCount++
                    
                    dedupEvent := domain.NewAuditEvent("deduplication_filter", "remove_duplicate")
                    dedupEvent.MarkerID = existing.ID
                    dedupEvent.AddData("overlap_ratio", overlapRatio)
                    dedupEvent.AddData("kept_marker_id", current.ID)
                    dedupEvent.AddData("reason", "current_marker_better")
                    f.addAuditEvent(dedupEvent)
                    
                    j-- // Adjust index after removal
                }
            }
        }
        
        if keepCurrent {
            unique = append(unique, current)
        }
    }
    
    event = domain.NewAuditEvent("deduplication_filter", "complete")
    event.AddData("deduplicated_count", dedupCount)
    event.AddData("unique_markers", len(unique))
    event.SetDuration(startTime)
    f.addAuditEvent(event)
    
    return unique, dedupCount
}

// applySpanConsolidation merges adjacent markers of same type
func (f *Filter) applySpanConsolidation(markers []domain.Marker) ([]domain.Marker, int) {
    startTime := time.Now()
    
    event := domain.NewAuditEvent("span_consolidation", "start")
    event.AddData("max_gap", f.dedupConfig.MaxGapForMerge)
    f.addAuditEvent(event)
    
    if len(markers) <= 1 {
        return markers, 0
    }
    
    // Group markers by type
    markersByType := make(map[string][]domain.Marker)
    for _, marker := range markers {
        markersByType[marker.Type] = append(markersByType[marker.Type], marker)
    }
    
    var consolidated []domain.Marker
    mergedCount := 0
    
    for markerType, typeMarkers := range markersByType {
        if len(typeMarkers) <= 1 {
            consolidated = append(consolidated, typeMarkers...)
            continue
        }
        
        // Sort markers of this type by position
        f.deterministicSortByPosition(typeMarkers)
        
        // Merge adjacent markers
        var merged []domain.Marker
        currentGroup := []domain.Marker{typeMarkers[0]}
        
        for i := 1; i < len(typeMarkers); i++ {
            current := typeMarkers[i]
            lastInGroup := currentGroup[len(currentGroup)-1]
            
            // Check if markers are close enough to merge
            gap := current.Start - lastInGroup.End
            
            if gap <= f.dedupConfig.MaxGapForMerge && 
               current.Type == lastInGroup.Type &&
               current.RuleID == lastInGroup.RuleID {
                
                // Add to current group
                currentGroup = append(currentGroup, current)
            } else {
                // Merge current group
                mergedGroup := f.mergeMarkerGroup(currentGroup)
                merged = append(merged, mergedGroup)
                mergedCount += len(currentGroup) - 1
                
                // Start new group
                currentGroup = []domain.Marker{current}
            }
        }
        
        // Merge last group
        if len(currentGroup) > 0 {
            mergedGroup := f.mergeMarkerGroup(currentGroup)
            merged = append(merged, mergedGroup)
            if len(currentGroup) > 1 {
                mergedCount += len(currentGroup) - 1
            }
        }
        
        consolidated = append(consolidated, merged...)
    }
    
    event = domain.NewAuditEvent("span_consolidation", "complete")
    event.AddData("merged_count", mergedCount)
    event.AddData("consolidated_markers", len(consolidated))
    event.SetDuration(startTime)
    f.addAuditEvent(event)
    
    return consolidated, mergedCount
}

// mergeMarkerGroup merges a group of markers into one
func (f *Filter) mergeMarkerGroup(group []domain.Marker) domain.Marker {
    if len(group) == 0 {
        return domain.Marker{}
    }
    
    if len(group) == 1 {
        return group[0]
    }
    
    // Find span boundaries
    start := group[0].Start
    end := group[len(group)-1].End
    
    // Combine text spans
    var textSpans []string
    for _, marker := range group {
        textSpans = append(textSpans, marker.TextSpan)
    }
    combinedText := strings.Join(textSpans, " ")
    
    // Calculate average confidence
    totalConfidence := 0.0
    for _, marker := range group {
        totalConfidence += marker.Confidence
    }
    avgConfidence := totalConfidence / float64(len(group))
    
    // Create merged marker
    merged := domain.NewMarker(
        group[0].Level,
        group[0].Type,
        combinedText,
        start,
        end,
        avgConfidence,
        group[0].RuleID + "_merged",
        false,
    )
    
    // Add metadata about merging
    merged.AddMetadata("merged_from", len(group))
    merged.AddMetadata("original_marker_ids", func() []string {
        ids := make([]string, len(group))
        for i, m := range group {
            ids[i] = m.ID
        }
        return ids
    }())
    merged.AddMetadata("merge_timestamp", time.Now().UnixNano())
    
    return merged
}

// calculateOverlapRatio calculates overlap ratio between two markers
func (f *Filter) calculateOverlapRatio(m1, m2 *domain.Marker) float64 {
    overlapStart := max(m1.Start, m2.Start)
    overlapEnd := min(m1.End, m2.End)
    
    if overlapStart >= overlapEnd {
        return 0.0
    }
    
    overlapLength := overlapEnd - overlapStart
    minSpan := min(m1.End-m1.Start, m2.End-m2.Start)
    
    return float64(overlapLength) / float64(minSpan)
}

// shouldKeepMarker determines which marker to keep during deduplication
func (f *Filter) shouldKeepMarker(current, existing *domain.Marker, overlapRatio float64) bool {
    // Higher level wins
    if current.Level != existing.Level {
        return current.Level > existing.Level
    }
    
    // Higher confidence wins
    if current.Confidence != existing.Confidence {
        return current.Confidence > existing.Confidence
    }
    
    // Longer span wins (for same level and confidence)
    currentSpan := current.End - current.Start
    existingSpan := existing.End - existing.Start
    if currentSpan != existingSpan {
        return currentSpan > existingSpan
    }
    
    // Deterministic tie-breaking using seed manager
    currentHash := f.seedManager.DeterministicHash(current.ID)
    existingHash := f.seedManager.DeterministicHash(existing.ID)
    return currentHash > existingHash
}

// deterministicSortByPosition sorts markers deterministically
func (f *Filter) deterministicSortByPosition(markers []domain.Marker) {
    // Use seed manager's stable sort
    f.seedManager.StableSort(markers)
}

// addAuditEvent adds an audit event
func (f *Filter) addAuditEvent(event *domain.AuditEvent) {
    f.mu.Lock()
    defer f.mu.Unlock()
    f.auditEvents = append(f.auditEvents, *event)
}

// Helper functions
func min(a, b int) int {
    if a < b {
        return a
    }
    return b
}

func max(a, b int) int {
    if a > b {
        return a
    }
    return b
}
```

### **internal/engine/postprocess/conflict_resolver.go**
```go
package postprocess

import (
    "fmt"
    "sort"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/determinism"
)

// ConflictResolver resolves conflicts between overlapping markers
type ConflictResolver struct {
    config      ConflictResolutionConfig
    seedManager *determinism.SeedManager
    auditEvents []domain.AuditEvent
    stats       struct {
        conflictsDetected  int
        conflictsResolved  int
        markersRemoved     int
        processingTimeMS   int64
    }
}

// NewConflictResolver creates a new conflict resolver
func NewConflictResolver(config ConflictResolutionConfig, seedManager *determinism.SeedManager) *ConflictResolver {
    return &ConflictResolver{
        config:      config,
        seedManager: seedManager,
        auditEvents: []domain.AuditEvent{},
    }
}

// ResolveConflicts resolves all conflicts in the marker list
func (cr *ConflictResolver) ResolveConflicts(markers []domain.Marker) ([]domain.Marker, []domain.AuditEvent, []Conflict) {
    startTime := time.Now()
    
    // Create audit event
    startEvent := domain.NewAuditEvent("conflict_resolution", "start")
    startEvent.AddData("input_markers", len(markers))
    cr.addAuditEvent(startEvent)
    
    if len(markers) <= 1 {
        return markers, cr.auditEvents, []Conflict{}
    }
    
    // Sort markers by start position for deterministic processing
    sortedMarkers := make([]domain.Marker, len(markers))
    copy(sortedMarkers, markers)
    cr.deterministicSort(sortedMarkers)
    
    // Detect conflicts
    conflicts := cr.detectConflicts(sortedMarkers)
    cr.stats.conflictsDetected = len(conflicts)
    
    // Resolve conflicts
    resolvedMarkers := cr.resolveDetectedConflicts(sortedMarkers, conflicts)
    cr.stats.conflictsResolved = len(conflicts)
    cr.stats.markersRemoved = len(markers) - len(resolvedMarkers)
    cr.stats.processingTimeMS = time.Since(startTime).Milliseconds()
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("conflict_resolution", "complete")
    endEvent.AddData("conflicts_detected", cr.stats.conflictsDetected)
    endEvent.AddData("conflicts_resolved", cr.stats.conflictsResolved)
    endEvent.AddData("markers_removed", cr.stats.markersRemoved)
    endEvent.AddData("final_markers", len(resolvedMarkers))
    endEvent.AddData("processing_time_ms", cr.stats.processingTimeMS)
    endEvent.SetDuration(startTime)
    cr.addAuditEvent(endEvent)
    
    return resolvedMarkers, cr.auditEvents, conflicts
}

// detectConflicts detects all conflicts between markers
func (cr *ConflictResolver) detectConflicts(markers []domain.Marker) []Conflict {
    var conflicts []Conflict
    
    for i := 0; i < len(markers); i++ {
        for j := i + 1; j < len(markers); j++ {
            m1 := &markers[i]
            m2 := &markers[j]
            
            // Check if markers overlap
            if m1.Overlaps(m2) {
                conflict := Conflict{
                    ID:           fmt.Sprintf("conflict_%d_%d_%d", i, j, time.Now().UnixNano()),
                    Marker1ID:    m1.ID,
                    Marker2ID:    m2.ID,
                    OverlapRatio: m1.Overlaps(m2) ? 1.0 : 0.0,
                    Timestamp:    time.Now().UnixNano(),
                    Metadata:     make(map[string]interface{}),
                }
                
                // Calculate detailed overlap
                overlapStart := max(m1.Start, m2.Start)
                overlapEnd := min(m1.End, m2.End)
                overlapLength := overlapEnd - overlapStart
                
                m1Length := m1.End - m1.Start
                m2Length := m2.End - m2.Start
                
                conflict.Metadata["overlap_start"] = overlapStart
                conflict.Metadata["overlap_end"] = overlapEnd
                conflict.Metadata["overlap_length"] = overlapLength
                conflict.Metadata["marker1_length"] = m1Length
                conflict.Metadata["marker2_length"] = m2Length
                conflict.Metadata["marker1_type"] = m1.Type
                conflict.Metadata["marker2_type"] = m2.Type
                conflict.Metadata["marker1_level"] = m1.Level
                conflict.Metadata["marker2_level"] = m2.Level
                
                conflicts = append(conflicts, conflict)
                
                // Create audit event for detected conflict
                event := domain.NewAuditEvent("conflict_detection", "conflict_detected")
                event.MarkerID = m1.ID
                event.AddData("conflict_id", conflict.ID)
                event.AddData("other_marker_id", m2.ID)
                event.AddData("overlap_ratio", conflict.OverlapRatio)
                event.AddData("marker1_level", m1.Level)
                event.AddData("marker2_level", m2.Level)
                cr.addAuditEvent(event)
            }
        }
    }
    
    return conflicts
}

// resolveDetectedConflicts resolves all detected conflicts
func (cr *ConflictResolver) resolveDetectedConflicts(markers []domain.Marker, conflicts []Conflict) []domain.Marker {
    // Create a map to track which markers to keep
    keepMarker := make(map[string]bool)
    for _, marker := range markers {
        keepMarker[marker.ID] = true
    }
    
    // Resolve each conflict
    for _, conflict := range conflicts {
        // Find the markers involved in this conflict
        var m1, m2 *domain.Marker
        for i := range markers {
            if markers[i].ID == conflict.Marker1ID {
                m1 = &markers[i]
            }
            if markers[i].ID == conflict.Marker2ID {
                m2 = &markers[i]
            }
        }
        
        if m1 == nil || m2 == nil {
            continue
        }
        
        // Determine which marker wins
        winner, loser, resolution, reason := cr.determineWinner(m1, m2)
        
        // Update conflict with resolution
        conflict.Resolution = resolution
        conflict.WinnerID = winner.ID
        conflict.Reason = reason
        
        // Mark loser for removal
        keepMarker[loser.ID] = false
        
        // Create audit event for resolution
        event := domain.NewAuditEvent("conflict_resolution", "conflict_resolved")
        event.MarkerID = winner.ID
        event.AddData("conflict_id", conflict.ID)
        event.AddData("winner_id", winner.ID)
        event.AddData("loser_id", loser.ID)
        event.AddData("resolution", resolution)
        event.AddData("reason", reason)
        event.AddData("winner_score", cr.calculateMarkerScore(winner))
        event.AddData("loser_score", cr.calculateMarkerScore(loser))
        cr.addAuditEvent(event)
        
        // Add conflict history to winner
        winner.AddMetadata("resolved_conflicts", append(
            winner.GetMetadata("resolved_conflicts", []string{}).([]string),
            conflict.ID,
        ))
    }
    
    // Filter out markers marked for removal
    var resolved []domain.Marker
    for _, marker := range markers {
        if keepMarker[marker.ID] {
            resolved = append(resolved, marker)
        }
    }
    
    return resolved
}

// determineWinner determines which marker wins in a conflict
func (cr *ConflictResolver) determineWinner(m1, m2 *domain.Marker) (*domain.Marker, *domain.Marker, string, string) {
    // Calculate scores for both markers
    score1 := cr.calculateMarkerScore(m1)
    score2 := cr.calculateMarkerScore(m2)
    
    if score1 > score2 {
        return m1, m2, "MARKER1_WINS", fmt.Sprintf("Higher score: %.3f > %.3f", score1, score2)
    } else if score2 > score1 {
        return m2, m1, "MARKER2_WINS", fmt.Sprintf("Higher score: %.3f > %.3f", score2, score1)
    }
    
    // Tie - use deterministic tie-breaking
    hash1 := cr.seedManager.DeterministicHash(m1.ID)
    hash2 := cr.seedManager.DeterministicHash(m2.ID)
    
    if hash1 > hash2 {
        return m1, m2, "MARKER1_WINS", fmt.Sprintf("Deterministic tie-break: %s > %s", hash1[:8], hash2[:8])
    } else {
        return m2, m1, "MARKER2_WINS", fmt.Sprintf("Deterministic tie-break: %s > %s", hash2[:8], hash1[:8])
    }
}

// calculateMarkerScore calculates a score for conflict resolution
func (cr *ConflictResolver) calculateMarkerScore(marker *domain.Marker) float64 {
    // Level score (higher level = higher priority)
    levelIndex := 5 - marker.Level // Convert to 0-4 index
    levelWeight := cr.config.PriorityWeights.Level[levelIndex]
    
    // Confidence score
    confidenceScore := marker.Confidence * cr.config.PriorityWeights.Confidence
    
    // Span length score (longer spans get higher score)
    spanLength := marker.End - marker.Start
    spanScore := float64(spanLength) * cr.config.PriorityWeights.SpanLength / 1000.0 // Normalize
    
    // Rule priority (extracted from rule ID or metadata)
    rulePriority := cr.extractRulePriority(marker.RuleID)
    ruleScore := rulePriority * cr.config.PriorityWeights.RulePriority
    
    // Total score
    totalScore := levelWeight + confidenceScore + spanScore + ruleScore
    
    return totalScore
}

// extractRulePriority extracts priority from rule ID
func (cr *ConflictResolver) extractRulePriority(ruleID string) float64 {
    // Simple heuristic: rules with "important", "critical", "urgent" get higher priority
    priorityKeywords := map[string]float64{
        "urgent":    1.0,
        "critical":  0.9,
        "important": 0.8,
        "priority":  0.7,
        "action":    0.6,
        "contact":   0.5,
    }
    
    for keyword, priority := range priorityKeywords {
        if contains(ruleID, keyword) {
            return priority
        }
    }
    
    return 0.5 // Default priority
}

// deterministicSort sorts markers deterministically
func (cr *ConflictResolver) deterministicSort(markers []domain.Marker) {
    // Sort by start position, then end position, then ID for determinism
    sort.SliceStable(markers, func(i, j int) bool {
        if markers[i].Start != markers[j].Start {
            return markers[i].Start < markers[j].Start
        }
        if markers[i].End != markers[j].End {
            return markers[i].End < markers[j].End
        }
        return markers[i].ID < markers[j].ID
    })
}

// addAuditEvent adds an audit event
func (cr *ConflictResolver) addAuditEvent(event *domain.AuditEvent) {
    cr.auditEvents = append(cr.auditEvents, *event)
}

// Helper function
func contains(s, substr string) bool {
    return len(s) >= len(substr) && (s == substr || len(s) > len(substr) && (s[:len(substr)] == substr || contains(s[1:], substr)))
}
```

### **internal/engine/postprocess/output_formatter.go**
```go
package postprocess

import (
    "fmt"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/pkg/determinism"
)

// OutputFormatter formats and enriches final output
type OutputFormatter struct {
    config      OutputFormattingConfig
    seedManager *determinism.SeedManager
    auditEvents []domain.AuditEvent
}

// NewOutputFormatter creates a new output formatter
func NewOutputFormatter(config OutputFormattingConfig, seedManager *determinism.SeedManager) *OutputFormatter {
    return &OutputFormatter{
        config:      config,
        seedManager: seedManager,
        auditEvents: []domain.AuditEvent{},
    }
}

// FormatOutput formats and enriches the final marker list
func (of *OutputFormatter) FormatOutput(
    markers []domain.Marker,
    transcript *domain.Transcript,
    previousPhasesEvents []domain.AuditEvent,
) ([]domain.Marker, []domain.AuditEvent) {
    
    startTime := time.Now()
    
    // Create audit event
    startEvent := domain.NewAuditEvent("output_formatting", "start")
    startEvent.AddData("input_markers", len(markers))
    of.addAuditEvent(startEvent)
    
    formatted := make([]domain.Marker, len(markers))
    
    for i, marker := range markers {
        formatted[i] = marker
        
        // 1. Generate deterministic ID if configured
        if of.config.GenerateDeterministicIDs {
            formatted[i].ID = of.generateDeterministicID(&marker, transcript)
        }
        
        // 2. Add context if configured
        if of.config.IncludeContext {
            of.addContext(&formatted[i], transcript)
        }
        
        // 3. Calculate cohesion score
        cohesionScore := of.calculateCohesionScore(&formatted[i], markers, transcript)
        formatted[i].AddMetadata("cohesion_score", cohesionScore)
        
        // 4. Add previous phase audit events as metadata
        of.addPhaseHistory(&formatted[i], previousPhasesEvents)
        
        // 5. Add formatting timestamp
        formatted[i].AddMetadata("formatted_at", time.Now().Format(time.RFC3339))
    }
    
    // 6. Sort markers deterministically for final output
    of.deterministicSort(formatted)
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("output_formatting", "complete")
    endEvent.AddData("formatted_markers", len(formatted))
    endEvent.AddData("processing_time_ms", time.Since(startTime).Milliseconds())
    endEvent.SetDuration(startTime)
    of.addAuditEvent(endEvent)
    
    return formatted, of.auditEvents
}

// generateDeterministicID generates a deterministic ID for a marker
func (of *OutputFormatter) generateDeterministicID(marker *domain.Marker, transcript *domain.Transcript) string {
    // Create a deterministic hash based on marker properties and transcript ID
    components := []string{
        transcript.ID,
        marker.Type,
        fmt.Sprintf("%d", marker.Start),
        fmt.Sprintf("%d", marker.End),
        marker.TextSpan,
        fmt.Sprintf("%.3f", marker.Confidence),
        marker.RuleID,
    }
    
    input := strings.Join(components, "|")
    hash := of.seedManager.DeterministicHash(input)
    
    return fmt.Sprintf("marker_%s_%s", transcript.ID[:8], hash[:16])
}

// addContext adds context to a marker
func (of *OutputFormatter) addContext(marker *domain.Marker, transcript *domain.Transcript) {
    // Get surrounding sentences
    sentences := transcript.Sentences
    if len(sentences) == 0 {
        return
    }
    
    // Find which sentence contains the marker
    markerSentenceIdx := -1
    for i, sentence := range sentences {
        if strings.Contains(sentence, marker.TextSpan) {
            markerSentenceIdx = i
            break
        }
    }
    
    if markerSentenceIdx == -1 {
        return
    }
    
    // Add previous sentences
    if of.config.IncludeContext && markerSentenceIdx > 0 {
        startIdx := max(0, markerSentenceIdx-of.config.ContextSentences)
        previousSentences := sentences[startIdx:markerSentenceIdx]
        marker.AddMetadata("previous_sentences", previousSentences)
    }
    
    // Add next sentences
    if of.config.IncludeContext && markerSentenceIdx < len(sentences)-1 {
        endIdx := min(len(sentences), markerSentenceIdx+of.config.ContextSentences+1)
        nextSentences := sentences[markerSentenceIdx+1:endIdx]
        marker.AddMetadata("next_sentences", nextSentences)
    }
    
    // Add paragraph context if available
    if of.config.IncludeParagraph {
        paragraphs := of.extractParagraphs(transcript.RawText)
        for _, paragraph := range paragraphs {
            if strings.Contains(paragraph, marker.TextSpan) {
                // Limit paragraph size
                if len(paragraph) > of.config.MaxContextChars {
                    paragraph = paragraph[:of.config.MaxContextChars] + "..."
                }
                marker.AddMetadata("paragraph_context", paragraph)
                break
            }
        }
    }
    
    // Add surrounding text
    start := max(0, marker.Start-of.config.MaxContextChars/2)
    end := min(len(transcript.ProcessedText), marker.End+of.config.MaxContextChars/2)
    
    if start < marker.Start {
        marker.AddMetadata("text_before", transcript.ProcessedText[start:marker.Start])
    }
    if end > marker.End {
        marker.AddMetadata("text_after", transcript.ProcessedText[marker.End:end])
    }
}

// extractParagraphs extracts paragraphs from text
func (of *OutputFormatter) extractParagraphs(text string) []string {
    paragraphs := strings.Split(text, "\n\n")
    var result []string
    
    for _, para := range paragraphs {
        trimmed := strings.TrimSpace(para)
        if trimmed != "" {
            result = append(result, trimmed)
        }
    }
    
    return result
}

// calculateCohesionScore calculates how well the marker fits with surrounding markers
func (of *OutputFormatter) calculateCohesionScore(
    marker *domain.Marker,
    allMarkers []domain.Marker,
    transcript *domain.Transcript,
) float64 {
    
    if len(allMarkers) <= 1 {
        return 1.0 // Only marker, perfect cohesion
    }
    
    var nearbyMarkers []domain.Marker
    proximityWindow := 500 // characters
    
    // Find markers near this one
    for _, other := range allMarkers {
        if other.ID == marker.ID {
            continue
        }
        
        distance := marker.DistanceTo(&other)
        if distance <= proximityWindow && distance >= 0 {
            nearbyMarkers = append(nearbyMarkers, other)
        }
    }
    
    if len(nearbyMarkers) == 0 {
        return 0.5 // No nearby markers, neutral cohesion
    }
    
    // Calculate type cohesion (how many markers of same type are nearby)
    sameTypeCount := 0
    for _, other := range nearbyMarkers {
        if other.Type == marker.Type {
            sameTypeCount++
        }
    }
    
    typeCohesion := float64(sameTypeCount) / float64(len(nearbyMarkers))
    
    // Calculate proximity cohesion (how close are nearby markers)
    totalDistance := 0
    for _, other := range nearbyMarkers {
        totalDistance += marker.DistanceTo(&other)
    }
    
    avgDistance := float64(totalDistance) / float64(len(nearbyMarkers))
    proximityCohesion := 1.0 - min(avgDistance/float64(proximityWindow), 1.0)
    
    // Combined cohesion score
    cohesion := (typeCohesion * 0.6) + (proximityCohesion * 0.4)
    
    return cohesion
}

// addPhaseHistory adds phase history to marker metadata
func (of *OutputFormatter) addPhaseHistory(marker *domain.Marker, phaseEvents []domain.AuditEvent) {
    var markerEvents []domain.AuditEvent
    
    for _, event := range phaseEvents {
        if event.MarkerID == marker.ID {
            markerEvents = append(markerEvents, event)
        }
    }
    
    if len(markerEvents) > 0 {
        // Limit the number of events stored
        maxEvents := min(len(markerEvents), of.config.MaxContextChars/100) // Rough estimate
        marker.AddMetadata("phase_history", markerEvents[:maxEvents])
    }
}

// deterministicSort sorts markers for final output
func (of *OutputFormatter) deterministicSort(markers []domain.Marker) {
    // Sort by multiple criteria for deterministic output
    sort.SliceStable(markers, func(i, j int) bool {
        // Primary: by level (descending)
        if markers[i].Level != markers[j].Level {
            return markers[i].Level > markers[j].Level
        }
        
        // Secondary: by confidence (descending)
        if markers[i].Confidence != markers[j].Confidence {
            return markers[i].Confidence > markers[j].Confidence
        }
        
        // Tertiary: by start position (ascending)
        if markers[i].Start != markers[j].Start {
            return markers[i].Start < markers[j].Start
        }
        
        // Quaternary: by deterministic hash
        hashI := of.seedManager.DeterministicHash(markers[i].ID)
        hashJ := of.seedManager.DeterministicHash(markers[j].ID)
        return hashI < hashJ
    })
}

// addAuditEvent adds an audit event
func (of *OutputFormatter) addAuditEvent(event *domain.AuditEvent) {
    of.auditEvents = append(of.auditEvents, *event)
}

// Helper functions
func min(a, b int) int {
    if a < b {
        return a
    }
    return b
}

func max(a, b int) int {
    if a > b {
        return a
    }
    return b
}
```

## **3. Phase 7: Quality Control & Audit**

### **internal/quality/types.go**
```go
package quality

import "semantic-analyzer/internal/domain"

// ConfidenceConfig contains confidence scoring configuration
type ConfidenceConfig struct {
    MinThreshold    float64            `json:"min_threshold"`
    ReviewThreshold float64            `json:"review_threshold"`
    WarningThreshold float64           `json:"warning_threshold"`
    Weights         ConfidenceWeights  `json:"weights"`
    Bayesian        BayesianConfig     `json:"bayesian"`
}

// ConfidenceWeights contains weights for confidence calculation
type ConfidenceWeights struct {
    RuleCertainty    float64 `json:"rule_certainty"`
    EvidenceDepth    float64 `json:"evidence_depth"`
    ContextCoherence float64 `json:"context_coherence"`
    ConflictHistory  float64 `json:"conflict_history"`
}

// BayesianConfig contains Bayesian inference configuration
type BayesianConfig struct {
    PriorProbability float64 `json:"prior_probability"`
    EvidenceWeight   float64 `json:"evidence_weight"`
    ConflictPenalty  float64 `json:"conflict_penalty"`
}

// Evidence represents supporting evidence for a marker
type Evidence struct {
    Type      string  `json:"type"`
    Source    string  `json:"source"`
    Strength  float64 `json:"strength"`
    Timestamp int64   `json:"timestamp,omitempty"`
    Metadata  map[string]interface{} `json:"metadata,omitempty"`
}

// QualityFlag represents a quality issue with a marker
type QualityFlag struct {
    Code        string `json:"code"`
    Description string `json:"description"`
    Severity    string `json:"severity"` // INFO, WARNING, ERROR
    Suggestion  string `json:"suggestion,omitempty"`
    Timestamp   int64  `json:"timestamp"`
}

// ConfidenceScore contains detailed confidence scoring
type ConfidenceScore struct {
    FinalScore          float64     `json:"final_score"`
    BaseConfidence      float64     `json:"base_confidence"`
    EvidenceBonus       float64     `json:"evidence_bonus"`
    ConflictPenalty     float64     `json:"conflict_penalty"`
    RuleCertainty       float64     `json:"rule_certainty"`
    ContextCoherence    float64     `json:"context_coherence"`
    QualityFlags        []QualityFlag `json:"quality_flags"`
    NeedsReview         bool        `json:"needs_review"`
    Recommendation      string      `json:"recommendation,omitempty"`
}

// QualityReport contains overall quality assessment
type QualityReport struct {
    TranscriptID     string                 `json:"transcript_id"`
    TotalMarkers     int                    `json:"total_markers"`
    HighConfidence   int                    `json:"high_confidence"`
    MediumConfidence int                    `json:"medium_confidence"`
    LowConfidence    int                    `json:"low_confidence"`
    NeedsReview      int                    `json:"needs_review"`
    AverageConfidence float64               `json:"average_confidence"`
    QualityIssues    map[string]int         `json:"quality_issues"`
    ProcessingTimeMS int64                  `json:"processing_time_ms"`
    Timestamp        int64                  `json:"timestamp"`
    Summary          string                 `json:"summary,omitempty"`
    Metadata         map[string]interface{} `json:"metadata,omitempty"`
}
```

### **internal/quality/confidence_scorer.go**
```go
package quality

import (
    "fmt"
    "sort"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
)

// ConfidenceScorer calculates final confidence scores for markers
type ConfidenceScorer struct {
    config      ConfidenceConfig
    auditEvents []domain.AuditEvent
    stats       QualityReport
}

// NewConfidenceScorer creates a new confidence scorer
func NewConfidenceScorer(config ConfidenceConfig) *ConfidenceScorer {
    return &ConfidenceScorer{
        config:      config,
        auditEvents: []domain.AuditEvent{},
        stats: QualityReport{
            QualityIssues: make(map[string]int),
            Timestamp:     time.Now().Unix(),
        },
    }
}

// ScoreAllMarkers calculates confidence scores for all markers
func (cs *ConfidenceScorer) ScoreAllMarkers(
    markers []domain.Marker,
    transcript *domain.Transcript,
    phaseEvents []domain.AuditEvent,
) ([]domain.Marker, []domain.AuditEvent, QualityReport) {
    
    startTime := time.Now()
    
    // Create audit event
    startEvent := domain.NewAuditEvent("confidence_scoring", "start")
    startEvent.AddData("marker_count", len(markers))
    cs.addAuditEvent(startEvent)
    
    cs.stats.TotalMarkers = len(markers)
    cs.stats.TranscriptID = transcript.ID
    
    scoredMarkers := make([]domain.Marker, len(markers))
    totalConfidence := 0.0
    
    for i, marker := range markers {
        scoredMarker := marker
        
        // Calculate detailed confidence score
        confidenceScore := cs.calculateMarkerConfidence(&scoredMarker, transcript, phaseEvents)
        
        // Update marker with confidence score
        scoredMarker.Confidence = confidenceScore.FinalScore
        scoredMarker.AddMetadata("confidence_score_details", confidenceScore)
        
        // Add quality flags to marker
        if len(confidenceScore.QualityFlags) > 0 {
            scoredMarker.AddMetadata("quality_flags", confidenceScore.QualityFlags)
        }
        
        // Track statistics
        totalConfidence += confidenceScore.FinalScore
        
        if confidenceScore.FinalScore >= cs.config.WarningThreshold {
            cs.stats.HighConfidence++
        } else if confidenceScore.FinalScore >= cs.config.ReviewThreshold {
            cs.stats.MediumConfidence++
        } else {
            cs.stats.LowConfidence++
        }
        
        if confidenceScore.NeedsReview {
            cs.stats.NeedsReview++
        }
        
        // Count quality issues
        for _, flag := range confidenceScore.QualityFlags {
            cs.stats.QualityIssues[flag.Code]++
        }
        
        scoredMarkers[i] = scoredMarker
        
        // Create audit event for marker scoring
        markerEvent := domain.NewAuditEvent("confidence_scoring", "marker_scored")
        markerEvent.MarkerID = scoredMarker.ID
        markerEvent.AddData("final_confidence", confidenceScore.FinalScore)
        markerEvent.AddData("needs_review", confidenceScore.NeedsReview)
        markerEvent.AddData("quality_flags", len(confidenceScore.QualityFlags))
        cs.addAuditEvent(markerEvent)
    }
    
    // Calculate final statistics
    if cs.stats.TotalMarkers > 0 {
        cs.stats.AverageConfidence = totalConfidence / float64(cs.stats.TotalMarkers)
    }
    
    cs.stats.ProcessingTimeMS = time.Since(startTime).Milliseconds()
    cs.stats.Timestamp = time.Now().Unix()
    cs.stats.Summary = cs.generateSummary()
    
    // Create completion audit event
    endEvent := domain.NewAuditEvent("confidence_scoring", "complete")
    endEvent.AddData("average_confidence", cs.stats.AverageConfidence)
    endEvent.AddData("high_confidence_markers", cs.stats.HighConfidence)
    endEvent.AddData("needs_review_markers", cs.stats.NeedsReview)
    endEvent.AddData("processing_time_ms", cs.stats.ProcessingTimeMS)
    endEvent.SetDuration(startTime)
    cs.addAuditEvent(endEvent)
    
    return scoredMarkers, cs.auditEvents, cs.stats
}

// calculateMarkerConfidence calculates detailed confidence for a single marker
func (cs *ConfidenceScorer) calculateMarkerConfidence(
    marker *domain.Marker,
    transcript *domain.Transcript,
    phaseEvents []domain.AuditEvent,
) ConfidenceScore {
    
    score := ConfidenceScore{
        BaseConfidence: marker.Confidence,
        QualityFlags:   []QualityFlag{},
    }
    
    // 1. Rule certainty
    ruleCertainty := cs.calculateRuleCertainty(marker)
    score.RuleCertainty = ruleCertainty
    
    // 2. Evidence depth
    evidenceBonus := cs.calculateEvidenceBonus(marker, phaseEvents)
    score.EvidenceBonus = evidenceBonus
    
    // 3. Context coherence
    contextCoherence := cs.calculateContextCoherence(marker, transcript)
    score.ContextCoherence = contextCoherence
    
    // 4. Conflict penalty
    conflictPenalty := cs.calculateConflictPenalty(marker)
    score.ConflictPenalty = conflictPenalty
    
    // 5. Apply Bayesian weighting
    finalScore := cs.applyBayesianWeighting(score)
    score.FinalScore = finalScore
    
    // 6. Check thresholds and add quality flags
    cs.addQualityFlags(&score, marker)
    
    // 7. Determine if review is needed
    score.NeedsReview = score.FinalScore < cs.config.ReviewThreshold
    
    // 8. Generate recommendation
    score.Recommendation = cs.generateRecommendation(score)
    
    return score
}

// calculateRuleCertainty calculates certainty based on rule properties
func (cs *ConfidenceScorer) calculateRuleCertainty(marker *domain.Marker) float64 {
    // Base certainty from rule weight
    certainty := marker.Confidence * cs.config.Weights.RuleCertainty
    
    // Adjust based on rule type
    ruleType := marker.Type
    switch {
    case strings.Contains(ruleType, "PERSON") || strings.Contains(ruleType, "ORGANIZATION"):
        certainty *= 0.9 // NER rules have high certainty
    case strings.Contains(ruleType, "CONTACT"):
        certainty *= 1.0 // Contact rules have very high certainty
    case strings.Contains(ruleType, "PRIORITY"):
        certainty *= 0.7 // Priority rules are somewhat subjective
    default:
        certainty *= 0.8 // Default adjustment
    }
    
    // Adjust based on marker level
    levelAdjustment := 0.5 + (float64(marker.Level) * 0.1)
    certainty *= levelAdjustment
    
    return min(certainty, 1.0)
}

// calculateEvidenceBonus calculates bonus from supporting evidence
func (cs *ConfidenceScorer) calculateEvidenceBonus(marker *domain.Marker, phaseEvents []domain.AuditEvent) float64 {
    bonus := 0.0
    
    // Count supporting audit events
    supportingEvents := 0
    conflictingEvents := 0
    
    for _, event := range phaseEvents {
        if event.MarkerID == marker.ID {
            if strings.Contains(event.Action, "detected") || strings.Contains(event.Action, "confirmed") {
                supportingEvents++
            } else if strings.Contains(event.Action, "conflict") || strings.Contains(event.Action, "rejected") {
                conflictingEvents++
            }
        }
    }
    
    // Calculate evidence strength
    if supportingEvents > 0 {
        evidenceStrength := float64(supportingEvents) / float64(supportingEvents+conflictingEvents+1)
        bonus = evidenceStrength * cs.config.Weights.EvidenceDepth
        
        // Add evidence metadata
        evidence := Evidence{
            Type:     "audit_events",
            Source:   "pipeline",
            Strength: evidenceStrength,
            Metadata: map[string]interface{}{
                "supporting_events": supportingEvents,
                "conflicting_events": conflictingEvents,
            },
        }
        
        marker.AddMetadata("supporting_evidence", append(
            marker.GetMetadata("supporting_evidence", []Evidence{}).([]Evidence),
            evidence,
        ))
    }
    
    return bonus
}

// calculateContextCoherence calculates how well marker fits in context
func (cs *ConfidenceScorer) calculateContextCoherence(marker *domain.Marker, transcript *domain.Transcript) float64 {
    coherence := 0.5 // Default neutral coherence
    
    // Check if marker appears in complete sentences
    sentences := transcript.Sentences
    for _, sentence := range sentences {
        if strings.Contains(sentence, marker.TextSpan) {
            // Check if the sentence looks complete
            if strings.HasSuffix(strings.TrimSpace(sentence), ".") ||
               strings.HasSuffix(strings.TrimSpace(sentence), "!") ||
               strings.HasSuffix(strings.TrimSpace(sentence), "?") {
                coherence = 0.8 // Good coherence in complete sentence
            }
            break
        }
    }
    
    // Adjust based on marker position in text
    textLength := len(transcript.ProcessedText)
    if textLength > 0 {
        positionRatio := float64(marker.Start) / float64(textLength)
        
        // Markers in middle of text (30-70%) tend to be more coherent
        if positionRatio >= 0.3 && positionRatio <= 0.7 {
            coherence *= 1.1
        }
    }
    
    return min(coherence * cs.config.Weights.ContextCoherence, 1.0)
}

// calculateConflictPenalty calculates penalty from conflicts
func (cs *ConfidenceScorer) calculateConflictPenalty(marker *domain.Marker) float64 {
    penalty := 0.0
    
    // Check for conflict history in metadata
    if conflicts, exists := marker.GetMetadata("resolved_conflicts"); exists {
        conflictList := conflicts.([]string)
        if len(conflictList) > 0 {
            penalty = float64(len(conflictList)) * cs.config.Bayesian.ConflictPenalty
        }
    }
    
    // Check for suppression history
    if suppressed, exists := marker.GetMetadata("suppressed"); exists {
        if suppressed.(bool) {
            penalty += 0.3
        }
    }
    
    return min(penalty * cs.config.Weights.ConflictHistory, 0.5) // Cap at 50% penalty
}

// applyBayesianWeighting applies Bayesian inference to confidence
func (cs *ConfidenceScorer) applyBayesianWeighting(score ConfidenceScore) float64 {
    // Prior probability from base confidence
    prior := cs.config.Bayesian.PriorProbability
    
    // Evidence likelihood
    evidenceLikelihood := (score.RuleCertainty + score.EvidenceBonus) / 2.0
    
    // Apply Bayes' theorem (simplified)
    numerator := evidenceLikelihood * prior
    denominator := evidenceLikelihood*prior + (1-evidenceLikelihood)*(1-prior)
    
    if denominator == 0 {
        return 0.0
    }
    
    posterior := numerator / denominator
    
    // Adjust with context coherence and conflict penalty
    adjusted := posterior * (1 + score.ContextCoherence - score.ConflictPenalty)
    
    // Apply evidence weight
    final := prior + (adjusted-prior)*cs.config.Bayesian.EvidenceWeight
    
    return clamp(final, 0.0, 1.0)
}

// addQualityFlags adds quality flags based on confidence score
func (cs *ConfidenceScorer) addQualityFlags(score *ConfidenceScore, marker *domain.Marker) {
    now := time.Now().Unix()
    
    // Low confidence flag
    if score.FinalScore < cs.config.MinThreshold {
        flag := QualityFlag{
            Code:        "LOW_CONFIDENCE",
            Description: fmt.Sprintf("Confidence score %.2f below minimum threshold %.2f", 
                score.FinalScore, cs.config.MinThreshold),
            Severity:   "ERROR",
            Suggestion: "Consider reviewing or removing this marker",
            Timestamp:  now,
        }
        score.QualityFlags = append(score.QualityFlags, flag)
    }
    
    // Needs review flag
    if score.NeedsReview {
        flag := QualityFlag{
            Code:        "NEEDS_REVIEW",
            Description: fmt.Sprintf("Confidence score %.2f below review threshold %.2f", 
                score.FinalScore, cs.config.ReviewThreshold),
            Severity:   "WARNING",
            Suggestion: "Human review recommended",
            Timestamp:  now,
        }
        score.QualityFlags = append(score.QualityFlags, flag)
    }
    
    // High conflict penalty flag
    if score.ConflictPenalty > 0.3 {
        flag := QualityFlag{
            Code:        "HIGH_CONFLICT",
            Description: fmt.Sprintf("High conflict penalty: %.2f", score.ConflictPenalty),
            Severity:   "WARNING",
            Suggestion: "Marker had conflicts with other markers",
            Timestamp:  now,
        }
        score.QualityFlags = append(score.QualityFlags, flag)
    }
    
    // Low evidence flag
    if score.EvidenceBonus < 0.1 {
        flag := QualityFlag{
            Code:        "LOW_EVIDENCE",
            Description: "Limited supporting evidence",
            Severity:   "INFO",
            Suggestion: "Consider additional verification",
            Timestamp:  now,
        }
        score.QualityFlags = append(score.QualityFlags, flag)
    }
}

// generateRecommendation generates recommendation based on confidence score
func (cs *ConfidenceScorer) generateRecommendation(score ConfidenceScore) string {
    if score.FinalScore >= cs.config.WarningThreshold {
        return "High confidence marker - suitable for automated processing"
    } else if score.FinalScore >= cs.config.ReviewThreshold {
        return "Medium confidence marker - consider human verification for critical applications"
    } else if score.FinalScore >= cs.config.MinThreshold {
        return "Low confidence marker - human review recommended"
    } else {
        return "Very low confidence marker - consider removal"
    }
}

// generateSummary generates a summary of quality assessment
func (cs *ConfidenceScorer) generateSummary() string {
    return fmt.Sprintf(
        "Quality Assessment: %d markers analyzed. "+
        "High confidence: %d (%.1f%%), "+
        "Needs review: %d (%.1f%%), "+
        "Average confidence: %.2f",
        cs.stats.TotalMarkers,
        cs.stats.HighConfidence,
        float64(cs.stats.HighConfidence)/float64(cs.stats.TotalMarkers)*100,
        cs.stats.NeedsReview,
        float64(cs.stats.NeedsReview)/float64(cs.stats.TotalMarkers)*100,
        cs.stats.AverageConfidence,
    )
}

// addAuditEvent adds an audit event
func (cs *ConfidenceScorer) addAuditEvent(event *domain.AuditEvent) {
    cs.auditEvents = append(cs.auditEvents, *event)
}

// Helper functions
func min(a, b float64) float64 {
    if a < b {
        return a
    }
    return b
}

func clamp(value, minVal, maxVal float64) float64 {
    if value < minVal {
        return minVal
    }
    if value > maxVal {
        return maxVal
    }
    return value
}
```

### **internal/audit/trail_generator.go**
```go
package audit

import (
    "encoding/json"
    "fmt"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
)

// TrailGenerator generates audit trails from audit events
type TrailGenerator struct {
    config      AuditConfig
    trails      map[string]*domain.AuditTrail
    events      map[string]*domain.AuditEvent
}

// AuditConfig contains audit trail configuration
type AuditConfig struct {
    EnableTrail         bool     `json:"enable_trail"`
    MaxEventsPerMarker  int      `json:"max_events_per_marker"`
    ExportFormats       []string `json:"export_formats"`
    IncludeDecisionTree bool     `json:"include_decision_tree"`
    CompressAuditLog    bool     `json:"compress_audit_log"`
}

// NewTrailGenerator creates a new audit trail generator
func NewTrailGenerator(config AuditConfig) *TrailGenerator {
    return &TrailGenerator{
        config: config,
        trails: make(map[string]*domain.AuditTrail),
        events: make(map[string]*domain.AuditEvent),
    }
}

// GenerateTrail generates an audit trail from all events
func (tg *TrailGenerator) GenerateTrail(
    transcriptID string,
    allEvents []domain.AuditEvent,
    markers []domain.Marker,
) (*domain.AuditTrail, map[string]*domain.AuditTrail, error) {
    
    if !tg.config.EnableTrail {
        return nil, nil, nil
    }
    
    // Store all events
    for _, event := range allEvents {
        tg.events[event.ID] = &event
    }
    
    // Create main audit trail
    mainTrail := tg.createMainTrail(transcriptID, allEvents)
    
    // Create marker-specific trails
    markerTrails := tg.createMarkerTrails(markers, allEvents)
    
    // Build decision trees if configured
    if tg.config.IncludeDecisionTree {
        tg.buildDecisionTrees(mainTrail, markerTrails)
    }
    
    return mainTrail, markerTrails, nil
}

// createMainTrail creates the main audit trail
func (tg *TrailGenerator) createMainTrail(transcriptID string, allEvents []domain.AuditEvent) *domain.AuditTrail {
    // Find the root event (usually the first event)
    var rootEvent *domain.AuditEvent
    if len(allEvents) > 0 {
        rootEvent = &allEvents[0]
    } else {
        rootEvent = domain.NewAuditEvent("pipeline", "start")
        rootEvent.AddData("transcript_id", transcriptID)
        rootEvent.AddData("timestamp", time.Now().Format(time.RFC3339))
    }
    
    trail := domain.NewAuditTrail(rootEvent)
    trail.TranscriptID = transcriptID
    
    // Add all events to trail
    for _, event := range allEvents {
        trail.AddEvent(&event)
    }
    
    // Organize events into hierarchical structure
    tg.organizeEventsHierarchically(trail)
    
    tg.trails["main"] = trail
    return trail
}

// createMarkerTrails creates audit trails for each marker
func (tg *TrailGenerator) createMarkerTrails(
    markers []domain.Marker,
    allEvents []domain.AuditEvent,
) map[string]*domain.AuditTrail {
    
    markerTrails := make(map[string]*domain.AuditTrail)
    
    for _, marker := range markers {
        // Collect events related to this marker
        var markerEvents []domain.AuditEvent
        
        for _, event := range allEvents {
            if event.MarkerID == marker.ID {
                markerEvents = append(markerEvents, event)
            }
        }
        
        // Limit events if configured
        if tg.config.MaxEventsPerMarker > 0 && len(markerEvents) > tg.config.MaxEventsPerMarker {
            markerEvents = markerEvents[:tg.config.MaxEventsPerMarker]
        }
        
        // Create trail for this marker
        if len(markerEvents) > 0 {
            rootEvent := tg.createMarkerRootEvent(&marker, markerEvents[0])
            trail := domain.NewAuditTrail(rootEvent)
            trail.TranscriptID = marker.ID
            
            for _, event := range markerEvents {
                trail.AddEvent(&event)
            }
            
            markerTrails[marker.ID] = trail
        }
    }
    
    return markerTrails
}

// createMarkerRootEvent creates a root event for a marker trail
func (tg *TrailGenerator) createMarkerRootEvent(marker *domain.Marker, firstEvent domain.AuditEvent) *domain.AuditEvent {
    rootEvent := domain.NewAuditEvent("marker_trail", "start")
    rootEvent.MarkerID = marker.ID
    rootEvent.AddData("marker_type", marker.Type)
    rootEvent.AddData("marker_level", marker.Level)
    rootEvent.AddData("confidence", marker.Confidence)
    rootEvent.AddData("text_span", marker.TextSpan)
    rootEvent.AddData("first_event_id", firstEvent.ID)
    rootEvent.AddData("first_event_stage", firstEvent.Stage)
    
    return rootEvent
}

// organizeEventsHierarchically organizes events into a hierarchical structure
func (tg *TrailGenerator) organizeEventsHierarchically(trail *domain.AuditTrail) {
    // Group events by stage
    eventsByStage := make(map[string][]*domain.AuditEvent)
    
    for _, event := range trail.Events {
        eventsByStage[event.Stage] = append(eventsByStage[event.Stage], event)
    }
    
    // Create hierarchical relationships between events
    // This is a simplified version - in production, you'd use more sophisticated logic
    for stage, events := range eventsByStage {
        if len(events) > 1 {
            // Sort events by timestamp within stage
            tg.sortEventsByTimestamp(events)
            
            // Create parent-child relationships
            for i := 1; i < len(events); i++ {
                events[i].ParentID = events[i-1].ID
                events[i-1].AddChild(events[i].ID)
            }
        }
    }
}

// buildDecisionTrees builds decision trees for audit trails
func (tg *TrailGenerator) buildDecisionTrees(mainTrail *domain.AuditTrail, markerTrails map[string]*domain.AuditTrail) {
    // Build decision tree for main trail
    tg.buildTrailDecisionTree(mainTrail)
    
    // Build decision trees for marker trails
    for _, trail := range markerTrails {
        tg.buildTrailDecisionTree(trail)
    }
}

// buildTrailDecisionTree builds a decision tree for a trail
func (tg *TrailGenerator) buildTrailDecisionTree(trail *domain.AuditTrail) {
    // This would create a tree structure showing decision paths
    // For simplicity, we'll add metadata about the tree structure
    
    decisionTree := map[string]interface{}{
        "root_event_id": trail.RootEventID,
        "total_events":  len(trail.Events),
        "event_stages":  tg.getUniqueStages(trail),
        "decision_paths": tg.extractDecisionPaths(trail),
    }
    
    // Add decision tree to trail metadata
    trail.Events[trail.RootEventID].AddMetadata("decision_tree", decisionTree)
}

// getUniqueStages gets unique stages from a trail
func (tg *TrailGenerator) getUniqueStages(trail *domain.AuditTrail) []string {
    stages := make(map[string]bool)
    
    for _, event := range trail.Events {
        stages[event.Stage] = true
    }
    
    var result []string
    for stage := range stages {
        result = append(result, stage)
    }
    
    return result
}

// extractDecisionPaths extracts decision paths from a trail
func (tg *TrailGenerator) extractDecisionPaths(trail *domain.AuditTrail) []string {
    var paths []string
    
    // Find leaf events (events with no children)
    for _, event := range trail.Events {
        if len(event.Children) == 0 {
            path := tg.extractPathToRoot(event, trail)
            paths = append(paths, strings.Join(path, " → "))
        }
    }
    
    return paths
}

// extractPathToRoot extracts the path from an event to the root
func (tg *TrailGenerator) extractPathToRoot(event *domain.AuditEvent, trail *domain.AuditTrail) []string {
    var path []string
    current := event
    
    for current != nil {
        path = append([]string{fmt.Sprintf("%s:%s", current.Stage, current.Action)}, path...)
        
        if current.ParentID == "" {
            break
        }
        
        parent, exists := trail.Events[current.ParentID]
        if !exists {
            break
        }
        
        current = parent
    }
    
    return path
}

// sortEventsByTimestamp sorts events by timestamp
func (tg *TrailGenerator) sortEventsByTimestamp(events []*domain.AuditEvent) {
    for i := 0; i < len(events)-1; i++ {
        for j := 0; j < len(events)-i-1; j++ {
            if events[j].Timestamp.After(events[j+1].Timestamp) {
                events[j], events[j+1] = events[j+1], events[j]
            }
        }
    }
}

// Export exports audit trails in specified formats
func (tg *TrailGenerator) Export(
    mainTrail *domain.AuditTrail,
    markerTrails map[string]*domain.AuditTrail,
) (map[string][]byte, error) {
    
    exports := make(map[string][]byte)
    
    for _, format := range tg.config.ExportFormats {
        switch strings.ToLower(format) {
        case "json":
            data, err := tg.exportJSON(mainTrail, markerTrails)
            if err != nil {
                return nil, err
            }
            exports["audit_trail.json"] = data
            
        case "text":
            data, err := tg.exportText(mainTrail, markerTrails)
            if err != nil {
                return nil, err
            }
            exports["audit_trail.txt"] = data
            
        case "tree":
            data, err := tg.exportTree(mainTrail, markerTrails)
            if err != nil {
                return nil, err
            }
            exports["decision_tree.txt"] = data
        }
    }
    
    return exports, nil
}

// exportJSON exports audit trails as JSON
func (tg *TrailGenerator) exportJSON(
    mainTrail *domain.AuditTrail,
    markerTrails map[string]*domain.AuditTrail,
) ([]byte, error) {
    
    exportData := map[string]interface{}{
        "main_trail":     mainTrail,
        "marker_trails":  markerTrails,
        "total_trails":   len(markerTrails) + 1,
        "export_time":    time.Now().Format(time.RFC3339),
    }
    
    return json.MarshalIndent(exportData, "", "  ")
}

// exportText exports audit trails as plain text
func (tg *TrailGenerator) exportText(
    mainTrail *domain.AuditTrail,
    markerTrails map[string]*domain.AuditTrail,
) ([]byte, error) {
    
    var builder strings.Builder
    
    builder.WriteString("=== AUDIT TRAIL REPORT ===\n\n")
    builder.WriteString(fmt.Sprintf("Transcript ID: %s\n", mainTrail.TranscriptID))
    builder.WriteString(fmt.Sprintf("Total Events: %d\n", len(mainTrail.Events)))
    builder.WriteString(fmt.Sprintf("Time Range: %s to %s\n\n", 
        mainTrail.StartTime.Format(time.RFC3339),
        mainTrail.EndTime.Format(time.RFC3339)))
    
    // Write main trail events
    builder.WriteString("=== MAIN PIPELINE EVENTS ===\n")
    for _, event := range tg.getSortedEvents(mainTrail) {
        builder.WriteString(tg.formatEvent(event))
    }
    
    // Write marker trails
    builder.WriteString("\n=== MARKER-SPECIFIC TRAILS ===\n")
    for markerID, trail := range markerTrails {
        builder.WriteString(fmt.Sprintf("\nMarker: %s\n", markerID))
        for _, event := range tg.getSortedEvents(trail) {
            builder.WriteString(tg.formatEvent(event))
        }
    }
    
    return []byte(builder.String()), nil
}

// exportTree exports decision trees
func (tg *TrailGenerator) exportTree(
    mainTrail *domain.AuditTrail,
    markerTrails map[string]*domain.AuditTrail,
) ([]byte, error) {
    
    var builder strings.Builder
    
    builder.WriteString("=== DECISION TREES ===\n\n")
    
    // Main pipeline decision tree
    builder.WriteString("Main Pipeline Decision Tree:\n")
    builder.WriteString(tg.buildTreeString(mainTrail, mainTrail.RootEventID, 0))
    
    // Marker decision trees
    for markerID, trail := range markerTrails {
        builder.WriteString(fmt.Sprintf("\nMarker %s Decision Tree:\n", markerID))
        builder.WriteString(tg.buildTreeString(trail, trail.RootEventID, 0))
    }
    
    return []byte(builder.String()), nil
}

// buildTreeString builds a string representation of a decision tree
func (tg *TrailGenerator) buildTreeString(trail *domain.AuditTrail, eventID string, depth int) string {
    event, exists := trail.Events[eventID]
    if !exists {
        return ""
    }
    
    var builder strings.Builder
    
    // Add indentation
    indent := strings.Repeat("  ", depth)
    builder.WriteString(fmt.Sprintf("%s├─ %s: %s\n", indent, event.Stage, event.Action))
    
    // Add children
    for _, childID := range event.Children {
        childTree := tg.buildTreeString(trail, childID, depth+1)
        builder.WriteString(childTree)
    }
    
    return builder.String()
}

// getSortedEvents gets events sorted by timestamp
func (tg *TrailGenerator) getSortedEvents(trail *domain.AuditTrail) []*domain.AuditEvent {
    var events []*domain.AuditEvent
    
    for _, event := range trail.Events {
        events = append(events, event)
    }
    
    // Sort by timestamp
    for i := 0; i < len(events)-1; i++ {
        for j := 0; j < len(events)-i-1; j++ {
            if events[j].Timestamp.After(events[j+1].Timestamp) {
                events[j], events[j+1] = events[j+1], events[j]
            }
        }
    }
    
    return events
}

// formatEvent formats an event for text output
func (tg *TrailGenerator) formatEvent(event *domain.AuditEvent) string {
    return fmt.Sprintf("[%s] %s - %s\n", 
        event.Timestamp.Format("15:04:05"),
        event.Stage,
        event.Action)
}
```

### **internal/report/generator.go**
```go
package report

import (
    "bytes"
    "fmt"
    "html/template"
    "sort"
    "strings"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/quality"
)

// ReportGenerator generates human-readable reports
type ReportGenerator struct {
    config      ReportConfig
    templates   map[string]*template.Template
}

// ReportConfig contains report generation configuration
type ReportConfig struct {
    Formats             []string `json:"formats"`
    Sections            []string `json:"sections"`
    IncludeVisualizations bool   `json:"include_visualizations"`
    MaxMarkersPerSection int    `json:"max_markers_per_section"`
    TemplateDirectory   string   `json:"template_directory"`
}

// NewReportGenerator creates a new report generator
func NewReportGenerator(config ReportConfig) *ReportGenerator {
    rg := &ReportGenerator{
        config:    config,
        templates: make(map[string]*template.Template),
    }
    
    rg.loadTemplates()
    return rg
}

// ReportData contains data for report generation
type ReportData struct {
    Transcript      *domain.Transcript       `json:"transcript"`
    AnalysisResult  *domain.AnalysisResult   `json:"analysis_result"`
    QualityReport   *quality.QualityReport   `json:"quality_report"`
    AuditTrail      *domain.AuditTrail       `json:"audit_trail,omitempty"`
    Timestamp       time.Time                `json:"timestamp"`
    Summary         ReportSummary            `json:"summary"`
    KeyFindings     []KeyFinding             `json:"key_findings"`
    RulePerformance []RulePerformance        `json:"rule_performance"`
    Anomalies       []Anomaly                `json:"anomalies"`
    Recommendations []Recommendation         `json:"recommendations"`
}

// ReportSummary contains report summary
type ReportSummary struct {
    TotalMarkers     int     `json:"total_markers"`
    HighConfidence   int     `json:"high_confidence"`
    ProcessingTime   float64 `json:"processing_time_seconds"`
    AverageConfidence float64 `json:"average_confidence"`
    TopMarkerTypes   []MarkerTypeCount `json:"top_marker_types"`
}

// KeyFinding represents a key finding in the report
type KeyFinding struct {
    Marker       domain.Marker `json:"marker"`
    Significance string        `json:"significance"`
    Confidence   float64       `json:"confidence"`
    Context      string        `json:"context,omitempty"`
}

// RulePerformance represents rule performance metrics
type RulePerformance struct {
    RuleID      string  `json:"rule_id"`
    RuleName    string  `json:"rule_name"`
    Count       int     `json:"count"`
    AvgConfidence float64 `json:"avg_confidence"`
    SuccessRate float64 `json:"success_rate,omitempty"`
}

// Anomaly represents an anomaly or issue
type Anomaly struct {
    Type        string  `json:"type"`
    Description string  `json:"description"`
    Severity    string  `json:"severity"`
    MarkerID    string  `json:"marker_id,omitempty"`
    Recommendation string `json:"recommendation,omitempty"`
}

// Recommendation represents a recommendation
type Recommendation struct {
    Category    string `json:"category"`
    Description string `json:"description"`
    Priority    string `json:"priority"` // HIGH, MEDIUM, LOW
    Action      string `json:"action,omitempty"`
}

// MarkerTypeCount represents marker type counts
type MarkerTypeCount struct {
    Type  string `json:"type"`
    Count int    `json:"count"`
    Percentage float64 `json:"percentage"`
}

// GenerateReport generates reports in specified formats
func (rg *ReportGenerator) GenerateReport(
    transcript *domain.Transcript,
    analysisResult *domain.AnalysisResult,
    qualityReport *quality.QualityReport,
    auditTrail *domain.AuditTrail,
) (map[string][]byte, error) {
    
    reports := make(map[string][]byte)
    
    // Prepare report data
    reportData := rg.prepareReportData(transcript, analysisResult, qualityReport, auditTrail)
    
    // Generate reports in all requested formats
    for _, format := range rg.config.Formats {
        var data []byte
        var err error
        
        switch strings.ToLower(format) {
        case "markdown":
            data, err = rg.generateMarkdownReport(reportData)
            if err == nil {
                reports["report.md"] = data
            }
            
        case "html":
            data, err = rg.generateHTMLReport(reportData)
            if err == nil {
                reports["report.html"] = data
            }
            
        case "text":
            data, err = rg.generateTextReport(reportData)
            if err == nil {
                reports["report.txt"] = data
            }
            
        case "json":
            data, err = rg.generateJSONReport(reportData)
            if err == nil {
                reports["report.json"] = data
            }
        }
        
        if err != nil {
            return nil, fmt.Errorf("failed to generate %s report: %w", format, err)
        }
    }
    
    return reports, nil
}

// prepareReportData prepares data for report generation
func (rg *ReportGenerator) prepareReportData(
    transcript *domain.Transcript,
    analysisResult *domain.AnalysisResult,
    qualityReport *quality.QualityReport,
    auditTrail *domain.AuditTrail,
) ReportData {
    
    data := ReportData{
        Transcript:     transcript,
        AnalysisResult: analysisResult,
        QualityReport:  qualityReport,
        AuditTrail:     auditTrail,
        Timestamp:      time.Now(),
    }
    
    // Generate summary
    data.Summary = rg.generateSummary(analysisResult, qualityReport)
    
    // Generate key findings
    data.KeyFindings = rg.generateKeyFindings(analysisResult)
    
    // Generate rule performance
    data.RulePerformance = rg.generateRulePerformance(analysisResult)
    
    // Generate anomalies
    data.Anomalies = rg.generateAnomalies(analysisResult, qualityReport)
    
    // Generate recommendations
    data.Recommendations = rg.generateRecommendations(analysisResult, qualityReport)
    
    return data
}

// generateSummary generates report summary
func (rg *ReportGenerator) generateSummary(
    analysisResult *domain.AnalysisResult,
    qualityReport *quality.QualityReport,
) ReportSummary {
    
    summary := ReportSummary{
        TotalMarkers:     analysisResult.Statistics.TotalMarkers,
        HighConfidence:   qualityReport.HighConfidence,
        ProcessingTime:   analysisResult.Statistics.ProcessingTime,
        AverageConfidence: qualityReport.AverageConfidence,
    }
    
    // Calculate top marker types
    typeCounts := make([]MarkerTypeCount, 0, len(analysisResult.Statistics.MarkerTypes))
    totalMarkers := analysisResult.Statistics.TotalMarkers
    
    for markerType, count := range analysisResult.Statistics.MarkerTypes {
        percentage := float64(count) / float64(totalMarkers) * 100
        typeCounts = append(typeCounts, MarkerTypeCount{
            Type:       markerType,
            Count:      count,
            Percentage: percentage,
        })
    }
    
    // Sort by count descending
    sort.Slice(typeCounts, func(i, j int) bool {
        return typeCounts[i].Count > typeCounts[j].Count
    })
    
    // Take top 5
    if len(typeCounts) > 5 {
        typeCounts = typeCounts[:5]
    }
    
    summary.TopMarkerTypes = typeCounts
    
    return summary
}

// generateKeyFindings generates key findings
func (rg *ReportGenerator) generateKeyFindings(analysisResult *domain.AnalysisResult) []KeyFinding {
    var findings []KeyFinding
    
    // Get top markers by confidence
    markers := analysisResult.Markers
    
    // Sort by confidence descending
    sort.Slice(markers, func(i, j int) bool {
        return markers[i].Confidence > markers[j].Confidence
    })
    
    // Take top N markers
    maxFindings := rg.config.MaxMarkersPerSection
    if maxFindings <= 0 {
        maxFindings = 10
    }
    
    if len(markers) > maxFindings {
        markers = markers[:maxFindings]
    }
    
    for _, marker := range markers {
        finding := KeyFinding{
            Marker:     marker,
            Confidence: marker.Confidence,
        }
        
        // Determine significance based on type and confidence
        finding.Significance = rg.determineSignificance(marker)
        
        // Add context if available
        if context, exists := marker.GetMetadata("context"); exists {
            finding.Context = context.(string)
        }
        
        findings = append(findings, finding)
    }
    
    return findings
}

// determineSignificance determines significance of a marker
func (rg *ReportGenerator) determineSignificance(marker domain.Marker) string {
    switch marker.Type {
    case "PRIORITY":
        return "High priority item requiring attention"
    case "CONTACT":
        return "Contact information for follow-up"
    case "ACTION":
        return "Action item or task"
    case "PERSON":
        return "Key person identified"
    case "ORGANIZATION":
        return "Organization mentioned"
    default:
        if marker.Confidence >= 0.8 {
            return "High confidence finding"
        } else if marker.Confidence >= 0.5 {
            return "Medium confidence finding"
        } else {
            return "Finding requiring verification"
        }
    }
}

// generateRulePerformance generates rule performance metrics
func (rg *ReportGenerator) generateRulePerformance(analysisResult *domain.AnalysisResult) []RulePerformance {
    // Count markers by rule
    ruleCounts := make(map[string]int)
    ruleConfidences := make(map[string]float64)
    ruleNames := make(map[string]string)
    
    for _, marker := range analysisResult.Markers {
        ruleID := marker.RuleID
        ruleCounts[ruleID]++
        ruleConfidences[ruleID] += marker.Confidence
        
        // Extract rule name from metadata if available
        if name, exists := marker.GetMetadata("rule_name"); exists {
            ruleNames[ruleID] = name.(string)
        } else {
            ruleNames[ruleID] = ruleID
        }
    }
    
    // Calculate performance metrics
    var performance []RulePerformance
    
    for ruleID, count := range ruleCounts {
        avgConfidence := ruleConfidences[ruleID] / float64(count)
        
        perf := RulePerformance{
            RuleID:       ruleID,
            RuleName:     ruleNames[ruleID],
            Count:        count,
            AvgConfidence: avgConfidence,
            SuccessRate:  avgConfidence, // Using confidence as success rate proxy
        }
        
        performance = append(performance, perf)
    }
    
    // Sort by count descending
    sort.Slice(performance, func(i, j int) bool {
        return performance[i].Count > performance[j].Count
    })
    
    return performance
}

// generateAnomalies generates anomalies and issues
func (rg *ReportGenerator) generateAnomalies(
    analysisResult *domain.AnalysisResult,
    qualityReport *quality.QualityReport,
) []Anomaly {
    
    var anomalies []Anomaly
    
    // Check for low confidence markers
    if qualityReport.LowConfidence > 0 {
        anomalies = append(anomalies, Anomaly{
            Type:        "LOW_CONFIDENCE",
            Description: fmt.Sprintf("%d markers have low confidence (< %.1f)", 
                qualityReport.LowConfidence, qualityReport.AverageConfidence*0.5),
            Severity:    "MEDIUM",
            Recommendation: "Review low confidence markers manually",
        })
    }
    
    // Check for markers needing review
    if qualityReport.NeedsReview > 0 {
        anomalies = append(anomalies, Anomaly{
            Type:        "NEEDS_REVIEW",
            Description: fmt.Sprintf("%d markers require human review", qualityReport.NeedsReview),
            Severity:    "HIGH",
            Recommendation: "Prioritize review of these markers",
        })
    }
    
    // Check for quality issues
    for issueCode, count := range qualityReport.QualityIssues {
        if count > 0 {
            anomalies = append(anomalies, Anomaly{
                Type:        issueCode,
                Description: fmt.Sprintf("%d markers have %s issues", count, issueCode),
                Severity:    rg.determineIssueSeverity(issueCode),
                Recommendation: rg.getIssueRecommendation(issueCode),
            })
        }
    }
    
    // Check for unusual marker distributions
    if len(analysisResult.Statistics.MarkerTypes) == 0 {
        anomalies = append(anomalies, Anomaly{
            Type:        "NO_MARKERS",
            Description: "No markers were detected in the text",
            Severity:    "HIGH",
            Recommendation: "Check text content and rule configuration",
        })
    }
    
    return anomalies
}

// generateRecommendations generates recommendations
func (rg *ReportGenerator) generateRecommendations(
    analysisResult *domain.AnalysisResult,
    qualityReport *quality.QualityReport,
) []Recommendation {
    
    var recommendations []Recommendation
    
    // Based on confidence distribution
    if qualityReport.LowConfidence > qualityReport.HighConfidence {
        recommendations = append(recommendations, Recommendation{
            Category:    "QUALITY",
            Description: "Majority of markers have low confidence",
            Priority:    "HIGH",
            Action:      "Review and potentially adjust detection rules",
        })
    }
    
    // Based on marker types
    if analysisResult.Statistics.MarkerTypes["CONTACT"] > 0 {
        recommendations = append(recommendations, Recommendation{
            Category:    "DATA_PRIVACY",
            Description: "Contact information detected in text",
            Priority:    "HIGH",
            Action:      "Ensure proper handling of sensitive information",
        })
    }
    
    // Based on processing time
    if analysisResult.Statistics.ProcessingTime > 30.0 {
        recommendations = append(recommendations, Recommendation{
            Category:    "PERFORMANCE",
            Description: "Processing time exceeds 30 seconds",
            Priority:    "MEDIUM",
            Action:      "Consider optimizing pipeline or reducing text size",
        })
    }
    
    // General recommendations
    recommendations = append(recommendations, Recommendation{
        Category:    "VALIDATION",
        Description: "Validate results against known test cases",
        Priority:    "MEDIUM",
        Action:      "Run validation tests regularly",
    })
    
    return recommendations
}

// generateMarkdownReport generates markdown report
func (rg *ReportGenerator) generateMarkdownReport(data ReportData) ([]byte, error) {
    var buffer bytes.Buffer
    
    // Write header
    buffer.WriteString("# Semantic Analysis Report\n\n")
    buffer.WriteString(fmt.Sprintf("**Generated:** %s\n\n", data.Timestamp.Format(time.RFC3339)))
    
    // Executive Summary
    buffer.WriteString("## Executive Summary\n\n")
    buffer.WriteString(fmt.Sprintf("- **Transcript:** %s\n", data.Transcript.Source))
    buffer.WriteString(fmt.Sprintf("- **Total Markers:** %d\n", data.Summary.TotalMarkers))
    buffer.WriteString(fmt.Sprintf("- **High Confidence:** %d (%.1f%%)\n", 
        data.Summary.HighConfidence,
        float64(data.Summary.HighConfidence)/float64(data.Summary.TotalMarkers)*100))
    buffer.WriteString(fmt.Sprintf("- **Processing Time:** %.2f seconds\n", data.Summary.ProcessingTime))
    buffer.WriteString(fmt.Sprintf("- **Average Confidence:** %.2f\n\n", data.Summary.AverageConfidence))
    
    // Key Findings
    buffer.WriteString("## Key Findings\n\n")
    for i, finding := range data.KeyFindings {
        buffer.WriteString(fmt.Sprintf("### %d. %s\n", i+1, finding.Marker.Type))
        buffer.WriteString(fmt.Sprintf("- **Text:** %s\n", finding.Marker.TextSpan))
        buffer.WriteString(fmt.Sprintf("- **Confidence:** %.2f\n", finding.Confidence))
        buffer.WriteString(fmt.Sprintf("- **Significance:** %s\n", finding.Significance))
        if finding.Context != "" {
            buffer.WriteString(fmt.Sprintf("- **Context:** %s\n", finding.Context))
        }
        buffer.WriteString("\n")
    }
    
    // Rule Performance
    buffer.WriteString("## Rule Performance\n\n")
    buffer.WriteString("| Rule | Count | Avg Confidence |\n")
    buffer.WriteString("|------|-------|----------------|\n")
    for _, perf := range data.RulePerformance {
        buffer.WriteString(fmt.Sprintf("| %s | %d | %.2f |\n", 
            perf.RuleName, perf.Count, perf.AvgConfidence))
    }
    buffer.WriteString("\n")
    
    // Anomalies
    if len(data.Anomalies) > 0 {
        buffer.WriteString("## Anomalies & Issues\n\n")
        for _, anomaly := range data.Anomalies {
            buffer.WriteString(fmt.Sprintf("### %s: %s\n", anomaly.Severity, anomaly.Type))
            buffer.WriteString(fmt.Sprintf("- **Description:** %s\n", anomaly.Description))
            buffer.WriteString(fmt.Sprintf("- **Recommendation:** %s\n\n", anomaly.Recommendation))
        }
    }
    
    // Recommendations
    buffer.WriteString("## Recommendations\n\n")
    for _, rec := range data.Recommendations {
        buffer.WriteString(fmt.Sprintf("### %s Priority: %s\n", rec.Priority, rec.Category))
        buffer.WriteString(fmt.Sprintf("- **Description:** %s\n", rec.Description))
        if rec.Action != "" {
            buffer.WriteString(fmt.Sprintf("- **Action:** %s\n", rec.Action))
        }
        buffer.WriteString("\n")
    }
    
    return buffer.Bytes(), nil
}

// generateHTMLReport generates HTML report
func (rg *ReportGenerator) generateHTMLReport(data ReportData) ([]byte, error) {
    htmlTemplate := `
<!DOCTYPE html>
<html>
<head>
    <title>Semantic Analysis Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .header { background: #f0f0f0; padding: 20px; border-radius: 5px; }
        .section { margin: 30px 0; }
        .finding { border-left: 4px solid #007bff; padding-left: 15px; margin: 10px 0; }
        .anomaly { background: #fff3cd; padding: 10px; border-radius: 5px; margin: 10px 0; }
        .recommendation { background: #d1ecf1; padding: 10px; border-radius: 5px; margin: 10px 0; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Semantic Analysis Report</h1>
        <p>Generated: {{.Timestamp.Format "2006-01-02 15:04:05"}}</p>
    </div>
    
    <div class="section">
        <h2>Executive Summary</h2>
        <ul>
            <li><strong>Transcript:</strong> {{.Transcript.Source}}</li>
            <li><strong>Total Markers:</strong> {{.Summary.TotalMarkers}}</li>
            <li><strong>High Confidence:</strong> {{.Summary.HighConfidence}} ({{printf "%.1f" (percent .Summary.HighConfidence .Summary.TotalMarkers)}}%)</li>
            <li><strong>Processing Time:</strong> {{printf "%.2f" .Summary.ProcessingTime}} seconds</li>
            <li><strong>Average Confidence:</strong> {{printf "%.2f" .Summary.AverageConfidence}}</li>
        </ul>
    </div>
    
    <div class="section">
        <h2>Key Findings</h2>
        {{range $i, $finding := .KeyFindings}}
        <div class="finding">
            <h3>{{add $i 1}}. {{$finding.Marker.Type}}</h3>
            <p><strong>Text:</strong> {{$finding.Marker.TextSpan}}</p>
            <p><strong>Confidence:</strong> {{printf "%.2f" $finding.Confidence}}</p>
            <p><strong>Significance:</strong> {{$finding.Significance}}</p>
            {{if $finding.Context}}<p><strong>Context:</strong> {{$finding.Context}}</p>{{end}}
        </div>
        {{end}}
    </div>
    
    <div class="section">
        <h2>Rule Performance</h2>
        <table>
            <tr>
                <th>Rule</th>
                <th>Count</th>
                <th>Average Confidence</th>
            </tr>
            {{range .RulePerformance}}
            <tr>
                <td>{{.RuleName}}</td>
                <td>{{.Count}}</td>
                <td>{{printf "%.2f" .AvgConfidence}}</td>
            </tr>
            {{end}}
        </table>
    </div>
    
    {{if .Anomalies}}
    <div class="section">
        <h2>Anomalies & Issues</h2>
        {{range .Anomalies}}
        <div class="anomaly">
            <h3>{{.Severity}}: {{.Type}}</h3>
            <p>{{.Description}}</p>
            <p><strong>Recommendation:</strong> {{.Recommendation}}</p>
        </div>
        {{end}}
    </div>
    {{end}}
    
    <div class="section">
        <h2>Recommendations</h2>
        {{range .Recommendations}}
        <div class="recommendation">
            <h3>{{.Priority}} Priority: {{.Category}}</h3>
            <p>{{.Description}}</p>
            {{if .Action}}<p><strong>Action:</strong> {{.Action}}</p>{{end}}
        </div>
        {{end}}
    </div>
</body>
</html>`
    
    // Create template with helper functions
    tmpl := template.New("report")
    tmpl.Funcs(template.FuncMap{
        "percent": func(part, total int) float64 {
            if total == 0 {
                return 0
            }
            return float64(part) / float64(total) * 100
        },
        "add": func(a, b int) int {
            return a + b
        },
    })
    
    tmpl, err := tmpl.Parse(htmlTemplate)
    if err != nil {
        return nil, err
    }
    
    var buffer bytes.Buffer
    if err := tmpl.Execute(&buffer, data); err != nil {
        return nil, err
    }
    
    return buffer.Bytes(), nil
}

// generateTextReport generates plain text report
func (rg *ReportGenerator) generateTextReport(data ReportData) ([]byte, error) {
    var buffer bytes.Buffer
    
    buffer.WriteString("SEMANTIC ANALYSIS REPORT\n")
    buffer.WriteString(strings.Repeat("=", 40) + "\n\n")
    
    buffer.WriteString("Generated: " + data.Timestamp.Format(time.RFC3339) + "\n\n")
    
    buffer.WriteString("EXECUTIVE SUMMARY\n")
    buffer.WriteString(strings.Repeat("-", 40) + "\n")
    buffer.WriteString(fmt.Sprintf("Transcript: %s\n", data.Transcript.Source))
    buffer.WriteString(fmt.Sprintf("Total Markers: %d\n", data.Summary.TotalMarkers))
    buffer.WriteString(fmt.Sprintf("High Confidence: %d\n", data.Summary.HighConfidence))
    buffer.WriteString(fmt.Sprintf("Processing Time: %.2f seconds\n", data.Summary.ProcessingTime))
    buffer.WriteString(fmt.Sprintf("Average Confidence: %.2f\n\n", data.Summary.AverageConfidence))
    
    buffer.WriteString("KEY FINDINGS\n")
    buffer.WriteString(strings.Repeat("-", 40) + "\n")
    for i, finding := range data.KeyFindings {
        buffer.WriteString(fmt.Sprintf("%d. %s\n", i+1, finding.Marker.Type))
        buffer.WriteString(fmt.Sprintf("   Text: %s\n", finding.Marker.TextSpan))
        buffer.WriteString(fmt.Sprintf("   Confidence: %.2f\n", finding.Confidence))
        buffer.WriteString(fmt.Sprintf("   Significance: %s\n", finding.Significance))
        if finding.Context != "" {
            buffer.WriteString(fmt.Sprintf("   Context: %s\n", finding.Context))
        }
        buffer.WriteString("\n")
    }
    
    return buffer.Bytes(), nil
}

// generateJSONReport generates JSON report
func (rg *ReportGenerator) generateJSONReport(data ReportData) ([]byte, error) {
    return json.MarshalIndent(data, "", "  ")
}

// determineIssueSeverity determines severity of an issue
func (rg *ReportGenerator) determineIssueSeverity(issueCode string) string {
    switch issueCode {
    case "LOW_CONFIDENCE", "NEEDS_REVIEW":
        return "HIGH"
    case "HIGH_CONFLICT":
        return "MEDIUM"
    default:
        return "LOW"
    }
}

// getIssueRecommendation gets recommendation for an issue
func (rg *ReportGenerator) getIssueRecommendation(issueCode string) string {
    switch issueCode {
    case "LOW_CONFIDENCE":
        return "Review detection rules and text context"
    case "NEEDS_REVIEW":
        return "Perform manual verification"
    case "HIGH_CONFLICT":
        return "Adjust conflict resolution thresholds"
    case "LOW_EVIDENCE":
        return "Add more supporting rules"
    default:
        return "Investigate further"
    }
}

// loadTemplates loads report templates
func (rg *ReportGenerator) loadTemplates() {
    // In production, load templates from files
    // For now, we use embedded templates
}
```

## **4. Phase 8: Integration & Comprehensive Testing**

### **cmd/pipeline/orchestrator.go**
```go
package pipeline

import (
    "context"
    "errors"
    "fmt"
    "runtime"
    "sync"
    "time"

    "semantic-analyzer/internal/audit"
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/engine/atomic"
    "semantic-analyzer/internal/engine/composite"
    "semantic-analyzer/internal/engine/postprocess"
    "semantic-analyzer/internal/engine/semantic"
    "semantic-analyzer/internal/processor/text"
    "semantic-analyzer/internal/quality"
    "semantic-analyzer/internal/report"
    "semantic-analyzer/internal/rules"
    "semantic-analyzer/pkg/config"
    "semantic-analyzer/pkg/determinism"
)

// Pipeline orchestrates the complete analysis pipeline
type Pipeline struct {
    config        *config.Config
    seedManager   *determinism.SeedManager
    phases        []Phase
    auditEvents   []domain.AuditEvent
    stats         PipelineStats
    circuitBreaker *CircuitBreaker
    mu            sync.RWMutex
}

// Phase represents a pipeline phase
type Phase struct {
    ID          string
    Name        string
    Description string
    Execute     func(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error)
    Timeout     time.Duration
    Enabled     bool
}

// PipelineStats contains pipeline execution statistics
type PipelineStats struct {
    TotalPhases      int            `json:"total_phases"`
    ExecutedPhases   int            `json:"executed_phases"`
    FailedPhases     int            `json:"failed_phases"`
    TotalTimeMS      int64          `json:"total_time_ms"`
    PhaseTimes       map[string]int64 `json:"phase_times"`
    MemoryUsageMB    float64        `json:"memory_usage_mb"`
    DeterminismHash  string         `json:"determinism_hash"`
    Errors           []PhaseError   `json:"errors,omitempty"`
}

// PhaseError represents a phase execution error
type PhaseError struct {
    PhaseID   string    `json:"phase_id"`
    Error     string    `json:"error"`
    Timestamp time.Time `json:"timestamp"`
    StackTrace string   `json:"stack_trace,omitempty"`
}

// CircuitBreaker implements circuit breaker pattern
type CircuitBreaker struct {
    failureThreshold int
    failureCount     int
    resetTimeout     time.Duration
    lastFailure      time.Time
    state            string // CLOSED, OPEN, HALF_OPEN
    mu               sync.RWMutex
}

// NewPipeline creates a new pipeline
func NewPipeline(cfg *config.Config) *Pipeline {
    seedManager := determinism.NewSeedManager(cfg.Determinism.BaseSeed)
    
    p := &Pipeline{
        config:        cfg,
        seedManager:   seedManager,
        auditEvents:   []domain.AuditEvent{},
        stats: PipelineStats{
            PhaseTimes: make(map[string]int64),
        },
        circuitBreaker: &CircuitBreaker{
            failureThreshold: cfg.Performance.CircuitBreakerThreshold,
            resetTimeout:     30 * time.Second,
            state:           "CLOSED",
        },
    }
    
    p.initializePhases()
    return p
}

// initializePhases initializes all pipeline phases
func (p *Pipeline) initializePhases() {
    p.phases = []Phase{
        {
            ID:          "preprocessing",
            Name:        "Text Preprocessing",
            Description: "Normalizes and tokenizes input text",
            Execute:     p.executePreprocessing,
            Timeout:     10 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "atomic_detection",
            Name:        "Atomic Marker Detection",
            Description: "Detects atomic markers using regex and keyword rules",
            Execute:     p.executeAtomicDetection,
            Timeout:     15 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "composite_aggregation",
            Name:        "Composite Aggregation",
            Description: "Groups atomic markers into composite candidates",
            Execute:     p.executeCompositeAggregation,
            Timeout:     10 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "semantic_analysis",
            Name:        "Semantic Analysis",
            Description: "Performs NER and semantic proximity analysis",
            Execute:     p.executeSemanticAnalysis,
            Timeout:     20 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "post_processing",
            Name:        "Post Processing",
            Description: "Applies filters and resolves conflicts",
            Execute:     p.executePostProcessing,
            Timeout:     15 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "quality_control",
            Name:        "Quality Control",
            Description: "Calculates confidence scores and quality metrics",
            Execute:     p.executeQualityControl,
            Timeout:     10 * time.Second,
            Enabled:     true,
        },
        {
            ID:          "report_generation",
            Name:        "Report Generation",
            Description: "Generates human-readable reports",
            Execute:     p.executeReportGeneration,
            Timeout:     5 * time.Second,
            Enabled:     true,
        },
    }
    
    p.stats.TotalPhases = len(p.phases)
}

// Execute executes the complete pipeline
func (p *Pipeline) Execute(ctx context.Context, transcript *domain.Transcript) (*domain.AnalysisResult, error) {
    startTime := time.Now()
    
    // Check circuit breaker
    if !p.circuitBreaker.Allow() {
        return nil, errors.New("circuit breaker is open - too many failures")
    }
    
    // Create pipeline start audit event
    startEvent := domain.NewAuditEvent("pipeline", "start")
    startEvent.AddData("transcript_id", transcript.ID)
    startEvent.AddData("phases_count", len(p.phases))
    startEvent.AddData("config_hash", p.seedManager.DeterministicHash(fmt.Sprintf("%v", p.config)))
    p.addAuditEvent(startEvent)
    
    // Initialize analysis result
    result := domain.NewAnalysisResult(transcript.ID)
    result.Transcript = transcript
    
    // Execute phases sequentially
    var phaseInput interface{} = transcript
    var allMarkers []domain.Marker
    var allAuditEvents []domain.AuditEvent
    
    for _, phase := range p.phases {
        if !phase.Enabled {
            continue
        }
        
        phaseStart := time.Now()
        
        // Create phase context with timeout
        phaseCtx, cancel := context.WithTimeout(ctx, phase.Timeout)
        
        // Execute phase
        phaseOutput, phaseEvents, err := phase.Execute(phaseCtx, phaseInput)
        cancel()
        
        phaseTime := time.Since(phaseStart).Milliseconds()
        p.stats.PhaseTimes[phase.ID] = phaseTime
        
        // Handle phase result
        if err != nil {
            p.handlePhaseError(phase.ID, err)
            p.stats.FailedPhases++
            
            // Circuit breaker track
            p.circuitBreaker.RecordFailure()
            
            // If error is fatal, stop pipeline
            if p.isFatalError(err) {
                return nil, fmt.Errorf("phase %s failed: %w", phase.ID, err)
            }
            
            // Continue with partial results
        } else {
            p.stats.ExecutedPhases++
            p.circuitBreaker.RecordSuccess()
            
            // Collect audit events
            allAuditEvents = append(allAuditEvents, phaseEvents...)
            p.auditEvents = append(p.auditEvents, phaseEvents...)
            
            // Update phase input for next phase
            phaseInput = phaseOutput
            
            // Extract markers if phase produced them
            if markers, ok := phaseOutput.([]domain.Marker); ok {
                allMarkers = markers
            }
        }
        
        // Check for cancellation
        select {
        case <-ctx.Done():
            return nil, ctx.Err()
        default:
            // Continue
        }
    }
    
    // Update result with final markers and audit events
    for _, marker := range allMarkers {
        result.AddMarker(marker)
    }
    
    for _, event := range allAuditEvents {
        result.AddAuditEvent(event)
    }
    
    // Update statistics
    result.Statistics.TotalMarkers = len(allMarkers)
    result.Statistics.ProcessingTime = time.Since(startTime).Seconds()
    result.Statistics.SentenceCount = len(transcript.Sentences)
    result.Statistics.WordCount = transcript.TokenCount
    
    // Calculate memory usage
    var m runtime.MemStats
    runtime.ReadMemStats(&m)
    p.stats.MemoryUsageMB = float64(m.Alloc) / 1024 / 1024
    
    // Generate determinism hash
    p.stats.DeterminismHash = p.generateDeterminismHash(result)
    result.ConfigHash = p.stats.DeterminismHash
    
    p.stats.TotalTimeMS = time.Since(startTime).Milliseconds()
    
    // Create pipeline completion audit event
    endEvent := domain.NewAuditEvent("pipeline", "complete")
    endEvent.AddData("total_time_ms", p.stats.TotalTimeMS)
    endEvent.AddData("memory_usage_mb", p.stats.MemoryUsageMB)
    endEvent.AddData("successful_phases", p.stats.ExecutedPhases)
    endEvent.SetDuration(startTime)
    p.addAuditEvent(endEvent)
    
    // Add pipeline stats to result
    result.AddMetadata("pipeline_stats", p.stats)
    
    return result, nil
}

// executePreprocessing executes preprocessing phase
func (p *Pipeline) executePreprocessing(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    transcript, ok := input.(*domain.Transcript)
    if !ok {
        return nil, nil, errors.New("invalid input for preprocessing phase")
    }
    
    preprocessor := text.NewPreprocessor(p.config.Processing)
    
    // Normalize text
    normalized := preprocessor.Normalize(transcript.RawText)
    transcript.ProcessedText = normalized
    
    // Segment into sentences
    sentences := preprocessor.SegmentIntoSentences(normalized)
    transcript.Sentences = sentences
    
    // Tokenize
    tokens := preprocessor.Tokenize(normalized)
    transcript.TokenCount = len(tokens)
    
    // Get text statistics
    stats := preprocessor.GetTextStatistics(normalized)
    transcript.AddMetadata("text_statistics", stats)
    
    auditEvents := preprocessor.GetAuditEvents()
    
    return transcript, auditEvents, nil
}

// executeAtomicDetection executes atomic detection phase
func (p *Pipeline) executeAtomicDetection(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    transcript, ok := input.(*domain.Transcript)
    if !ok {
        return nil, nil, errors.New("invalid input for atomic detection phase")
    }
    
    // Initialize rule engine
    ruleEngine, err := rules.NewRuleEngine(p.config.Rules.Atomic)
    if err != nil {
        return nil, nil, fmt.Errorf("failed to initialize rule engine: %w", err)
    }
    
    // Initialize detector
    detector := atomic.NewDetector(ruleEngine, p.seedManager)
    
    // Detect atomic markers
    markers, auditEvents, err := detector.Detect(transcript.ProcessedText)
    if err != nil {
        return nil, nil, fmt.Errorf("atomic detection failed: %w", err)
    }
    
    return markers, auditEvents, nil
}

// executeCompositeAggregation executes composite aggregation phase
func (p *Pipeline) executeCompositeAggregation(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    markers, ok := input.([]domain.Marker)
    if !ok {
        return nil, nil, errors.New("invalid input for composite aggregation phase")
    }
    
    // Initialize composite builder
    builder := composite.NewBuilder(p.config.Rules.Composite)
    
    // Build context windows (requires sentences from transcript)
    // Note: In production, we would pass transcript context
    var sentences []string
    // For now, use dummy sentences
    sentences = []string{"Dummy sentence for composite aggregation"}
    
    candidates := builder.BuildContextWindows(markers, sentences)
    
    // Initialize scorer
    scorer := composite.NewScorer(p.config.Rules.Composite)
    scoredCandidates := scorer.ScoreAllCandidates(candidates)
    
    // Initialize selector
    selector := composite.NewSelector(p.seedManager)
    selectedCandidates := selector.SelectTopCandidates(scoredCandidates, p.config.Rules.Composite.MaxCandidates)
    
    // Convert candidates back to markers
    var compositeMarkers []domain.Marker
    for _, candidate := range selectedCandidates {
        // Create composite marker from candidate
        compositeMarker := domain.NewMarker(
            2, // Composite markers are level 2
            "COMPOSITE",
            candidate.Markers[0].TextSpan, // Use first marker's text span
            candidate.SpanStart,
            candidate.SpanEnd,
            candidate.Score,
            "composite_rule",
            false, // Not atomic
        )
        
        // Add candidate metadata
        compositeMarker.AddMetadata("candidate_id", candidate.ID)
        compositeMarker.AddMetadata("marker_count", candidate.MarkerCount)
        compositeMarker.AddMetadata("density", candidate.Density)
        
        compositeMarkers = append(compositeMarkers, *compositeMarker)
    }
    
    // Combine atomic and composite markers
    allMarkers := append(markers, compositeMarkers...)
    
    // Combine audit events
    var auditEvents []domain.AuditEvent
    auditEvents = append(auditEvents, builder.GetAuditEvents()...)
    auditEvents = append(auditEvents, scorer.GetAuditEvents()...)
    auditEvents = append(auditEvents, selector.GetAuditEvents()...)
    
    return allMarkers, auditEvents, nil
}

// executeSemanticAnalysis executes semantic analysis phase
func (p *Pipeline) executeSemanticAnalysis(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    markers, ok := input.([]domain.Marker)
    if !ok {
        return nil, nil, errors.New("invalid input for semantic analysis phase")
    }
    
    // Initialize semantic analyzer
    analyzer := semantic.NewAnalyzer(p.config.Rules.Semantic, p.seedManager)
    
    // Analyze markers
    analyzedMarkers, auditEvents, err := analyzer.Analyze(markers)
    if err != nil {
        return nil, nil, fmt.Errorf("semantic analysis failed: %w", err)
    }
    
    return analyzedMarkers, auditEvents, nil
}

// executePostProcessing executes post-processing phase
func (p *Pipeline) executePostProcessing(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    markers, ok := input.([]domain.Marker)
    if !ok {
        return nil, nil, errors.New("invalid input for post-processing phase")
    }
    
    // Initialize filters
    filter := postprocess.NewFilter(
        p.config.Postprocessing.SuppressionPatterns,
        p.config.Postprocessing.Deduplication,
        p.seedManager,
    )
    
    // Apply filters
    filteredMarkers, filterEvents, filterStats := filter.ApplyAllFilters(markers, "")
    
    // Initialize conflict resolver
    resolver := postprocess.NewConflictResolver(
        p.config.Postprocessing.ConflictResolution,
        p.seedManager,
    )
    
    // Resolve conflicts
    resolvedMarkers, resolveEvents, conflicts := resolver.ResolveConflicts(filteredMarkers)
    
    // Initialize output formatter
    formatter := postprocess.NewOutputFormatter(
        p.config.Postprocessing.OutputFormatting,
        p.seedManager,
    )
    
    // Format output
    formattedMarkers, formatEvents := formatter.FormatOutput(resolvedMarkers, nil, nil)
    
    // Combine all audit events
    var auditEvents []domain.AuditEvent
    auditEvents = append(auditEvents, filterEvents...)
    auditEvents = append(auditEvents, resolveEvents...)
    auditEvents = append(auditEvents, formatEvents...)
    
    // Add post-processing metadata
    for i := range formattedMarkers {
        formattedMarkers[i].AddMetadata("post_processed", true)
        formattedMarkers[i].AddMetadata("conflicts_resolved", len(conflicts))
    }
    
    return formattedMarkers, auditEvents, nil
}

// executeQualityControl executes quality control phase
func (p *Pipeline) executeQualityControl(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    markers, ok := input.([]domain.Marker)
    if !ok {
        return nil, nil, errors.New("invalid input for quality control phase")
    }
    
    // Initialize confidence scorer
    scorer := quality.NewConfidenceScorer(p.config.Quality.Confidence)
    
    // Score all markers
    scoredMarkers, auditEvents, qualityReport := scorer.ScoreAllMarkers(markers, nil, p.auditEvents)
    
    // Add quality report to pipeline metadata
    p.addAuditEvent(&domain.AuditEvent{
        ID:        "quality_report",
        Timestamp: time.Now(),
        Stage:     "quality_control",
        Action:    "report_generated",
        DataSnapshot: map[string]interface{}{
            "quality_report": qualityReport,
        },
    })
    
    return scoredMarkers, auditEvents, nil
}

// executeReportGeneration executes report generation phase
func (p *Pipeline) executeReportGeneration(ctx context.Context, input interface{}) (interface{}, []domain.AuditEvent, error) {
    markers, ok := input.([]domain.Marker)
    if !ok {
        return nil, nil, errors.New("invalid input for report generation phase")
    }
    
    // Initialize report generator
    generator := report.NewReportGenerator(p.config.Quality.Reporting)
    
    // Create dummy analysis result for report
    analysisResult := &domain.AnalysisResult{
        TranscriptID: "dummy",
        Markers:      markers,
        Statistics: domain.Statistics{
            TotalMarkers: len(markers),
            ProcessingTime: float64(p.stats.TotalTimeMS) / 1000,
        },
    }
    
    // Create dummy quality report
    qualityReport := &quality.QualityReport{
        TranscriptID:     "dummy",
        TotalMarkers:     len(markers),
        HighConfidence:   countHighConfidence(markers),
        AverageConfidence: averageConfidence(markers),
    }
    
    // Generate reports
    reports, err := generator.GenerateReport(
        &domain.Transcript{Source: "input.txt"},
        analysisResult,
        qualityReport,
        nil,
    )
    
    if err != nil {
        return nil, nil, fmt.Errorf("report generation failed: %w", err)
    }
    
    // Create audit event for report generation
    event := domain.NewAuditEvent("report_generation", "complete")
    event.AddData("report_count", len(reports))
    event.AddData("report_formats", p.config.Quality.Reporting.Formats)
    
    return markers, []domain.AuditEvent{*event}, nil
}

// handlePhaseError handles phase execution errors
func (p *Pipeline) handlePhaseError(phaseID string, err error) {
    phaseError := PhaseError{
        PhaseID:   phaseID,
        Error:     err.Error(),
        Timestamp: time.Now(),
        StackTrace: getStackTrace(),
    }
    
    p.stats.Errors = append(p.stats.Errors, phaseError)
    
    // Create error audit event
    errorEvent := domain.NewAuditEvent("pipeline", "phase_error")
    errorEvent.AddData("phase_id", phaseID)
    errorEvent.AddData("error", err.Error())
    errorEvent.Error = err.Error()
    p.addAuditEvent(errorEvent)
}

// isFatalError checks if an error is fatal
func (p *Pipeline) isFatalError(err error) bool {
    // In production, you'd have more sophisticated logic
    fatalErrors := []string{
        "out of memory",
        "context deadline exceeded",
        "invalid configuration",
    }
    
    errStr := err.Error()
    for _, fatal := range fatalErrors {
        if contains(errStr, fatal) {
            return true
        }
    }
    
    return false
}

// generateDeterminismHash generates a determinism hash for the result
func (p *Pipeline) generateDeterminismHash(result *domain.AnalysisResult) string {
    // Create a deterministic string representation
    var builder strings.Builder
    
    builder.WriteString(result.TranscriptID)
    builder.WriteString(fmt.Sprintf("%d", result.Statistics.TotalMarkers))
    builder.WriteString(fmt.Sprintf("%.3f", result.Statistics.AverageConfidence))
    
    // Add marker hashes (sorted for determinism)
    markerHashes := make([]string, len(result.Markers))
    for i, marker := range result.Markers {
        markerHashes[i] = p.seedManager.DeterministicHash(
            fmt.Sprintf("%s:%d:%d:%.3f", 
                marker.Type, marker.Start, marker.End, marker.Confidence))
    }
    
    sort.Strings(markerHashes)
    for _, hash := range markerHashes {
        builder.WriteString(hash[:8])
    }
    
    return p.seedManager.DeterministicHash(builder.String())
}

// addAuditEvent adds an audit event
func (p *Pipeline) addAuditEvent(event *domain.AuditEvent) {
    p.mu.Lock()
    defer p.mu.Unlock()
    p.auditEvents = append(p.auditEvents, *event)
}

// GetStats returns pipeline statistics
func (p *Pipeline) GetStats() PipelineStats {
    p.mu.RLock()
    defer p.mu.RUnlock()
    return p.stats
}

// GetAuditEvents returns all audit events
func (p *Pipeline) GetAuditEvents() []domain.AuditEvent {
    p.mu.RLock()
    defer p.mu.RUnlock()
    return p.auditEvents
}

// Reset resets the pipeline
func (p *Pipeline) Reset() {
    p.mu.Lock()
    defer p.mu.Unlock()
    
    p.auditEvents = []domain.AuditEvent{}
    p.stats = PipelineStats{
        PhaseTimes: make(map[string]int64),
    }
    p.circuitBreaker.Reset()
}

// Circuit Breaker Methods
func (cb *CircuitBreaker) Allow() bool {
    cb.mu.RLock()
    defer cb.mu.RUnlock()
    
    if cb.state == "OPEN" {
        if time.Since(cb.lastFailure) > cb.resetTimeout {
            cb.state = "HALF_OPEN"
            return true
        }
        return false
    }
    
    return true
}

func (cb *CircuitBreaker) RecordSuccess() {
    cb.mu.Lock()
    defer cb.mu.Unlock()
    
    if cb.state == "HALF_OPEN" {
        cb.state = "CLOSED"
        cb.failureCount = 0
    }
}

func (cb *CircuitBreaker) RecordFailure() {
    cb.mu.Lock()
    defer cb.mu.Unlock()
    
    cb.failureCount++
    cb.lastFailure = time.Now()
    
    if cb.failureCount >= cb.failureThreshold {
        cb.state = "OPEN"
    }
}

func (cb *CircuitBreaker) Reset() {
    cb.mu.Lock()
    defer cb.mu.Unlock()
    
    cb.state = "CLOSED"
    cb.failureCount = 0
    cb.lastFailure = time.Time{}
}

// Helper functions
func getStackTrace() string {
    buf := make([]byte, 1024)
    n := runtime.Stack(buf, false)
    return string(buf[:n])
}

func contains(s, substr string) bool {
    return strings.Contains(strings.ToLower(s), strings.ToLower(substr))
}

func countHighConfidence(markers []domain.Marker) int {
    count := 0
    for _, marker := range markers {
        if marker.Confidence >= 0.8 {
            count++
        }
    }
    return count
}

func averageConfidence(markers []domain.Marker) float64 {
    if len(markers) == 0 {
        return 0.0
    }
    
    total := 0.0
    for _, marker := range markers {
        total += marker.Confidence
    }
    
    return total / float64(len(markers))
}
```

### **cmd/cli/main.go** (enhanced)
```go
package main

import (
    "context"
    "crypto/md5"
    "encoding/hex"
    "encoding/json"
    "flag"
    "fmt"
    "log"
    "os"
    "path/filepath"
    "runtime"
    "runtime/pprof"
    "strings"
    "time"

    "semantic-analyzer/cmd/pipeline"
    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/processor/text"
    "semantic-analyzer/pkg/config"
    "semantic-analyzer/pkg/determinism"
)

func main() {
    // Parse command line arguments
    configPath := flag.String("config", "./configs/config.yaml", "Path to configuration file")
    inputPath := flag.String("input", "", "Path to input text file (required)")
    outputDir := flag.String("output", "./results", "Output directory for results")
    phase := flag.String("phase", "", "Run specific phase only (e.g., 'atomic', 'composite')")
    fullPipeline := flag.Bool("full-pipeline", true, "Run all phases")
    validate := flag.Bool("validate", false, "Validate config before execution")
    benchmark := flag.Bool("benchmark", false, "Run in benchmark mode")
    determinismTest := flag.Bool("determinism-test", false, "Run determinism test (100 iterations)")
    cpuProfile := flag.String("cpu-profile", "", "Write CPU profile to file")
    memProfile := flag.String("mem-profile", "", "Write memory profile to file")
    
    flag.Parse()
    
    if *inputPath == "" {
        log.Fatal("Input file path is required. Use --input flag.")
    }
    
    // Create output directory
    if err := os.MkdirAll(*outputDir, 0755); err != nil {
        log.Fatalf("Failed to create output directory: %v", err)
    }
    
    // Run the requested operation
    if *determinismTest {
        runDeterminismTest(*configPath, *inputPath, *outputDir)
        return
    }
    
    if *benchmark {
        runBenchmark(*configPath, *inputPath, *outputDir)
        return
    }
    
    if *validate {
        if err := validateConfig(*configPath); err != nil {
            log.Fatal(err)
        }
        log.Println("Configuration is valid")
        return
    }
    
    // Run analysis
    if err := runAnalysis(*configPath, *inputPath, *outputDir, *phase, *fullPipeline, 
                        *cpuProfile, *memProfile); err != nil {
        log.Fatalf("Analysis failed: %v", err)
    }
    
    log.Println("Analysis completed successfully")
}

func runAnalysis(configPath, inputPath, outputDir, phase string, fullPipeline bool,
                 cpuProfile, memProfile string) error {
    
    // Start profiling if requested
    if cpuProfile != "" {
        f, err := os.Create(cpuProfile)
        if err != nil {
            return fmt.Errorf("failed to create CPU profile: %w", err)
        }
        defer f.Close()
        
        if err := pprof.StartCPUProfile(f); err != nil {
            return fmt.Errorf("failed to start CPU profile: %w", err)
        }
        defer pprof.StopCPUProfile()
    }
    
    startTime := time.Now()
    
    // Load configuration
    cfg, err := config.Load(configPath)
    if err != nil {
        return fmt.Errorf("failed to load config: %w", err)
    }
    
    // Read input file
    inputContent, err := os.ReadFile(inputPath)
    if err != nil {
        return fmt.Errorf("failed to read input file: %w", err)
    }
    
    // Initialize seed manager
    seedManager := determinism.NewSeedManager(cfg.Determinism.BaseSeed)
    
    // Create transcript
    transcript := &domain.Transcript{
        ID:        seedManager.DeterministicHash(string(inputContent)),
        RawText:   string(inputContent),
        Source:    filepath.Base(inputPath),
        CreatedAt: time.Now(),
        Metadata: map[string]interface{}{
            "file_size":     len(inputContent),
            "config_path":   configPath,
            "analysis_time": startTime.Format(time.RFC3339),
        },
    }
    
    // Create pipeline
    pipeline := pipeline.NewPipeline(cfg)
    
    // Run pipeline
    ctx := context.Background()
    result, err := pipeline.Execute(ctx, transcript)
    if err != nil {
        return fmt.Errorf("pipeline execution failed: %w", err)
    }
    
    // Generate output filename
    timestamp := time.Now().Format("20060102_150405")
    outputFile := filepath.Join(outputDir, 
        fmt.Sprintf("analysis_%s_%s.json", 
            transcript.ID[:8], 
            timestamp))
    
    // Write results to file
    outputData, err := json.MarshalIndent(result, "", "  ")
    if err != nil {
        return fmt.Errorf("failed to marshal results: %w", err)
    }
    
    if err := os.WriteFile(outputFile, outputData, 0644); err != nil {
        return fmt.Errorf("failed to write output file: %w", err)
    }
    
    // Write audit trail if enabled
    if cfg.Output.EnableAuditTrail {
        auditFile := filepath.Join(outputDir, 
            fmt.Sprintf("audit_%s_%s.json", 
                transcript.ID[:8], 
                timestamp))
        
        auditData, err := json.MarshalIndent(pipeline.GetAuditEvents(), "", "  ")
        if err != nil {
            return fmt.Errorf("failed to marshal audit trail: %w", err)
        }
        
        if err := os.WriteFile(auditFile, auditData, 0644); err != nil {
            return fmt.Errorf("failed to write audit file: %w", err)
        }
    }
    
    // Write pipeline stats
    stats := pipeline.GetStats()
    statsFile := filepath.Join(outputDir, 
        fmt.Sprintf("stats_%s_%s.json", 
            transcript.ID[:8], 
            timestamp))
    
    statsData, err := json.MarshalIndent(stats, "", "  ")
    if err != nil {
        return fmt.Errorf("failed to marshal stats: %w", err)
    }
    
    if err := os.WriteFile(statsFile, statsData, 0644); err != nil {
        return fmt.Errorf("failed to write stats file: %w", err)
    }
    
    // Generate memory profile if requested
    if memProfile != "" {
        f, err := os.Create(memProfile)
        if err != nil {
            return fmt.Errorf("failed to create memory profile: %w", err)
        }
        defer f.Close()
        
        runtime.GC()
        if err := pprof.WriteHeapProfile(f); err != nil {
            return fmt.Errorf("failed to write memory profile: %w", err)
        }
    }
    
    // Print summary
    printSummary(result, stats, outputFile, time.Since(startTime))
    
    return nil
}

func runDeterminismTest(configPath, inputPath, outputDir string) {
    log.Println("Running determinism test (100 iterations)...")
    
    var firstHash string
    var mismatches []int
    
    for i := 0; i < 100; i++ {
        log.Printf("Iteration %d/%d", i+1, 100)
        
        // Run analysis
        tempDir := filepath.Join(outputDir, fmt.Sprintf("run_%d", i))
        os.MkdirAll(tempDir, 0755)
        
        err := runAnalysis(configPath, inputPath, tempDir, "", true, "", "")
        if err != nil {
            log.Printf("Error in iteration %d: %v", i, err)
            continue
        }
        
        // Read output file
        outputFile := filepath.Join(tempDir, "analysis_*.json")
        files, _ := filepath.Glob(outputFile)
        if len(files) == 0 {
            continue
        }
        
        data, err := os.ReadFile(files[0])
        if err != nil {
            continue
        }
        
        // Calculate hash
        hash := md5.Sum(data)
        hashStr := hex.EncodeToString(hash[:])
        
        if i == 0 {
            firstHash = hashStr
            log.Printf("First run hash: %s", hashStr)
        } else {
            if hashStr != firstHash {
                mismatches = append(mismatches, i)
                log.Printf("Mismatch at iteration %d: %s != %s", i, hashStr, firstHash)
            }
        }
    }
    
    if len(mismatches) == 0 {
        log.Println("✅ Determinism test PASSED: All 100 iterations produced identical output")
    } else {
        log.Printf("❌ Determinism test FAILED: %d mismatches at iterations: %v", 
            len(mismatches), mismatches)
    }
}

func runBenchmark(configPath, inputPath, outputDir string) {
    log.Println("Running performance benchmark...")
    
    // Create a 10,000-word test file
    testFile := filepath.Join(outputDir, "benchmark_10k.txt")
    createTestFile(testFile, 10000)
    
    // Run benchmark
    startTime := time.Now()
    
    err := runAnalysis(configPath, testFile, outputDir, "", true, "", "")
    if err != nil {
        log.Printf("Benchmark failed: %v", err)
        return
    }
    
    duration := time.Since(startTime)
    
    // Check performance target
    target := 30 * time.Second
    if duration <= target {
        log.Printf("✅ Performance test PASSED: Processed 10,000 words in %v (< %v)", 
            duration, target)
    } else {
        log.Printf("⚠️ Performance test WARNING: Processed 10,000 words in %v (> %v)", 
            duration, target)
    }
    
    // Clean up
    os.Remove(testFile)
}

func createTestFile(path string, wordCount int) {
    words := []string{"lorem", "ipsum", "dolor", "sit", "amet", "consectetur", 
                      "adipiscing", "elit", "sed", "do", "eiusmod", "tempor", 
                      "incididunt", "ut", "labore", "et", "dolore", "magna", 
                      "aliqua", "contact@example.com", "urgent", "important"}
    
    var builder strings.Builder
    
    for i := 0; i < wordCount; i++ {
        word := words[i%len(words)]
        builder.WriteString(word)
        
        if i%10 == 9 {
            builder.WriteString(". ")
        } else if i%5 == 4 {
            builder.WriteString(", ")
        } else {
            builder.WriteString(" ")
        }
    }
    
    os.WriteFile(path, []byte(builder.String()), 0644)
}

func validateConfig(configPath string) error {
    _, err := config.Load(configPath)
    return err
}

func printSummary(result *domain.AnalysisResult, stats pipeline.PipelineStats, 
                  outputFile string, duration time.Duration) {
    
    fmt.Printf("\n=== ANALYSIS SUMMARY ===\n")
    fmt.Printf("Transcript ID: %s\n", result.TranscriptID[:12])
    fmt.Printf("Source: %s\n", result.Transcript.Source)
    fmt.Printf("Total words: %d\n", result.Transcript.TokenCount)
    fmt.Printf("Total sentences: %d\n", len(result.Transcript.Sentences))
    fmt.Printf("Markers found: %d\n", result.Statistics.TotalMarkers)
    fmt.Printf("Average confidence: %.2f\n", result.Statistics.AverageConfidence)
    fmt.Printf("Processing time: %v\n", duration)
    fmt.Printf("Pipeline phases: %d/%d successful\n", stats.ExecutedPhases, stats.TotalPhases)
    fmt.Printf("Memory usage: %.1f MB\n", stats.MemoryUsageMB)
    fmt.Printf("Output file: %s\n", outputFile)
    
    if len(result.Statistics.MarkerTypes) > 0 {
        fmt.Printf("\nMarker types:\n")
        for t, c := range result.Statistics.MarkerTypes {
            fmt.Printf("  %s: %d\n", t, c)
        }
    }
    
    fmt.Println()
}
