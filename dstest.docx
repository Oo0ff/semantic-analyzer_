### **internal/engine/composite/builder_test.go**
```go
package composite_test

import (
    "testing"
    "time"

    "semantic-analyzer/internal/domain"
    "semantic-analyzer/internal/engine/composite"
    "semantic-analyzer/pkg/config"
)

func TestBuilder_BuildContextWindows(t *testing.T) {
    // Create test configuration
    cfg := config.CompositeRulesConfig{
        ProximityWindow: 2,
        MinDensity:      0.1,
        MaxSpan:         1000,
        MaxCandidates:   5,
        SelectionWeights: config.SelectionWeights{
            MarkerCount:     0.4,
            Density:         0.3,
            SpanCompactness: 0.2,
            TypeDiversity:   0.1,
        },
    }
    
    builder := composite.NewBuilder(cfg)
    
    // Create test markers
    markers := []domain.Marker{
        *domain.NewMarker(1, "CONTACT", "test@example.com", 10, 25, 0.9, "email_pattern", true),
        *domain.NewMarker(1, "PRIORITY", "urgent", 50, 56, 0.6, "important_terms", true),
        *domain.NewMarker(1, "ACTION", "action item", 80, 90, 0.5, "action_items", true),
    }
    
    // Create test sentences
    sentences := []string{
        "Contact us at test@example.com for assistance.",
        "This is an urgent matter.",
        "Please complete the action item.",
    }
    
    // Build context windows
    candidates := builder.BuildContextWindows(markers, sentences)
    
    if len(candidates) == 0 {
        t.Error("Expected to find composite candidates")
    }
    
    // Verify candidate properties
    for _, candidate := range candidates {
        if candidate.MarkerCount < 2 {
            t.Errorf("Candidate should have at least 2 markers, got %d", candidate.MarkerCount)
        }
        
        if candidate.Density < cfg.MinDensity {
            t.Errorf("Candidate density %f below minimum %f", candidate.Density, cfg.MinDensity)
        }
        
        if candidate.SpanLength > cfg.MaxSpan {
            t.Errorf("Candidate span %d exceeds maximum %d", candidate.SpanLength, cfg.MaxSpan)
        }
    }
}

func TestBuilder_MergeSimilarCandidates(t *testing.T) {
    cfg := config.CompositeRulesConfig{
        ProximityWindow: 3,
        MinDensity:      0.1,
        MaxSpan:         500,
    }
    
    builder := composite.NewBuilder(cfg)
    
    // Create overlapping candidates
    candidates := []composite.CompositeCandidate{
        *composite.NewCompositeCandidate("c1", []domain.Marker{
            *domain.NewMarker(1, "CONTACT", "email1", 10, 20, 0.9, "r1", true),
        }, 10, 20, []int{0}),
        
        *composite.NewCompositeCandidate("c2", []domain.Marker{
            *domain.NewMarker(1, "CONTACT", "email1", 10, 20, 0.9, "r1", true),
            *domain.NewMarker(1, "PRIORITY", "urgent", 25, 31, 0.6, "r2", true),
        }, 10, 31, []int{0, 1}),
    }
    
    // Merge similar candidates
    merged := builder.MergeSimilarCandidates(candidates, 0.5)
    
    if len(merged) >= len(candidates) {
        t.Errorf("Expected merging to reduce candidates from %d, got %d", len(candidates), len(merged))
    }
    
    if len(merged) > 0 {
        mergedCandidate := merged[0]
        if mergedCandidate.MarkerCount < 2 {
            t.Errorf("Merged candidate should have at least 2 markers, got %d", mergedCandidate.MarkerCount)
        }
    }
}

func BenchmarkBuilder_BuildContextWindows(b *testing.B) {
    cfg := config.CompositeRulesConfig{
        ProximityWindow: 3,
        MinDensity:      0.2,
        MaxSpan:         1000,
    }
    
    builder := composite.NewBuilder(cfg)
    
    // Create larger test data
    var markers []domain.Marker
    var sentences []string
    
    for i := 0; i < 100; i++ {
        marker := domain.NewMarker(
            1,
            "TEST",
            "test",
            i*10,
            i*10+5,
            0.5,
            "test_rule",
            true,
        )
        markers = append(markers, *marker)
        
        sentences = append(sentences, "This is a test sentence.")
    }
    
    b.ResetTimer()
    for i := 0; i < b.N; i++ {
        builder.BuildContextWindows(markers, sentences)
    }
}
