```go
package config

import (
    "fmt"
    "os"
    "path/filepath"

    "github.com/spf13/viper"
)

// Config represents the application configuration
type Config struct {
    App         AppConfig         `mapstructure:"app"`
    Determinism DeterminismConfig `mapstructure:"determinism"`
    Processing  ProcessingConfig  `mapstructure:"processing"`
    Rules       RulesConfig       `mapstructure:"rules"`
    Performance PerformanceConfig `mapstructure:"performance"`
    Output      OutputConfig      `mapstructure:"output"`
}

// AppConfig contains general application settings
type AppConfig struct {
    Name         string `mapstructure:"name"`
    Version      string `mapstructure:"version"`
    MaxTextSize  int    `mapstructure:"max_text_size"`
    LogLevel     string `mapstructure:"log_level"`
    EnableDebug  bool   `mapstructure:"enable_debug"`
}

// DeterminismConfig contains determinism-related settings
type DeterminismConfig struct {
    BaseSeed         int64  `mapstructure:"base_seed"`
    EnableStableSort bool   `mapstructure:"enable_stable_sort"`
    HashAlgorithm    string `mapstructure:"hash_algorithm"`
}

// ProcessingConfig contains text processing settings
type ProcessingConfig struct {
    UnicodeNormalization string   `mapstructure:"unicode_normalization"`
    EnableLowercase      bool     `mapstructure:"enable_lowercase"`
    SentenceDelimiters   []string `mapstructure:"sentence_delimiters"`
    PreserveWhitespace   bool     `mapstructure:"preserve_whitespace"`
    MaxSentenceLength    int      `mapstructure:"max_sentence_length"`
    RemovePunctuation    bool     `mapstructure:"remove_punctuation"`
    StopWords            []string `mapstructure:"stop_words"`
}

// RulesConfig contains rule definitions for all levels
type RulesConfig struct {
    Atomic    AtomicRulesConfig    `mapstructure:"atomic"`
    Composite CompositeRulesConfig `mapstructure:"composite"`
    Semantic  SemanticRulesConfig  `mapstructure:"semantic"`
}

// AtomicRulesConfig contains atomic marker detection rules
type AtomicRulesConfig struct {
    RegexPatterns []RegexRuleConfig   `mapstructure:"regex_patterns"`
    KeywordLists  []KeywordRuleConfig `mapstructure:"keyword_lists"`
}

// CompositeRulesConfig contains composite marker detection rules
type CompositeRulesConfig struct {
    ProximityWindow  int               `mapstructure:"proximity_window"`
    MinDensity       float64           `mapstructure:"min_density"`
    MaxSpan          int               `mapstructure:"max_span"`
    MaxCandidates    int               `mapstructure:"max_candidates"`
    SelectionWeights SelectionWeights  `mapstructure:"selection_weights"`
    TypeWeights      map[string]float64 `mapstructure:"type_weights"`
}

// SelectionWeights contains weights for candidate selection
type SelectionWeights struct {
    MarkerCount   float64 `mapstructure:"marker_count"`
    Density       float64 `mapstructure:"density"`
    SpanCompactness float64 `mapstructure:"span_compactness"`
    TypeDiversity  float64 `mapstructure:"type_diversity"`
}

// SemanticRulesConfig contains semantic analysis rules
type SemanticRulesConfig struct {
    NER          NERConfig                     `mapstructure:"ner"`
    Networks     map[string][]string           `mapstructure:"networks"`
    ProximityWeights ProximityWeights          `mapstructure:"proximity_weights"`
    LogicalRules []LogicalRuleConfig           `mapstructure:"logical_rules"`
}

// NERConfig contains named entity recognition rules
type NERConfig struct {
    PersonTitles        []string          `mapstructure:"person_titles"`
    OrganizationSuffixes []string          `mapstructure:"organization_suffixes"`
    LocationPatterns    []string          `mapstructure:"location_patterns"`
    PersonPatterns      []RegexRuleConfig `mapstructure:"person_patterns"`
    OrganizationPatterns []RegexRuleConfig `mapstructure:"organization_patterns"`
    LocationKeywords    []string          `mapstructure:"location_keywords"`
}

// ProximityWeights contains weights for semantic proximity
type ProximityWeights struct {
    NetworkMatch    float64 `mapstructure:"network_match"`
    TypeSimilarity  float64 `mapstructure:"type_similarity"`
    ContextOverlap  float64 `mapstructure:"context_overlap"`
}

// LogicalRuleConfig contains logical expression rules
type LogicalRuleConfig struct {
    ID         string `mapstructure:"id"`
    Expression string `mapstructure:"expression"`
    Type       string `mapstructure:"type"`
    Level      int    `mapstructure:"level"`
    Weight     float64 `mapstructure:"weight"`
    OutputType string `mapstructure:"output_type"`
}

// PerformanceConfig contains performance-related settings
type PerformanceConfig struct {
    MaxWorkers                int  `mapstructure:"max_workers"`
    BufferSize                int  `mapstructure:"buffer_size"`
    EnableMemoryPool          bool `mapstructure:"enable_memory_pool"`
    RegexCompilationCacheSize int  `mapstructure:"regex_compilation_cache_size"`
    EnableParallelProcessing  bool `mapstructure:"enable_parallel_processing"`
}

// OutputConfig contains output settings
type OutputConfig struct {
    EnableAuditTrail      bool   `mapstructure:"enable_audit_trail"`
    PrettyPrintJSON       bool   `mapstructure:"pretty_print_json"`
    IncludeConfidence     bool   `mapstructure:"include_confidence_scores"`
    TimestampFormat       string `mapstructure:"timestamp_format"`
    OutputDirectory       string `mapstructure:"output_directory"`
    EnableCompression     bool   `mapstructure:"enable_compression"`
    MaxMarkersPerFile     int    `mapstructure:"max_markers_per_file"`
}

// Load loads configuration from file and environment variables
func Load(configPath string) (*Config, error) {
    // Set default values
    setDefaults()

    // Check if config file exists
    if configPath != "" {
        absPath, err := filepath.Abs(configPath)
        if err != nil {
            return nil, fmt.Errorf("failed to get absolute path: %w", err)
        }

        if _, err := os.Stat(absPath); os.IsNotExist(err) {
            return nil, fmt.Errorf("config file does not exist: %s", absPath)
        }

        viper.SetConfigFile(absPath)
    } else {
        // Use default config locations
        viper.AddConfigPath(".")
        viper.AddConfigPath("./configs")
        viper.AddConfigPath("/etc/semantic-analyzer")
        viper.SetConfigName("config")
        viper.SetConfigType("yaml")
    }

    // Read in environment variables
    viper.AutomaticEnv()
    viper.SetEnvPrefix("SEMANTIC")

    // Read configuration
    if err := viper.ReadInConfig(); err != nil {
        if _, ok := err.(viper.ConfigFileNotFoundError); ok {
            // Config file not found; use defaults
            fmt.Println("Warning: Config file not found, using defaults")
        } else {
            return nil, fmt.Errorf("failed to read config: %w", err)
        }
    }

    // Unmarshal configuration
    var cfg Config
    if err := viper.Unmarshal(&cfg); err != nil {
        return nil, fmt.Errorf("failed to unmarshal config: %w", err)
    }

    // Validate configuration
    if err := validateConfig(&cfg); err != nil {
        return nil, fmt.Errorf("config validation failed: %w", err)
    }

    return &cfg, nil
}

// validateConfig validates the configuration
func validateConfig(cfg *Config) error {
    // App validation
    if cfg.App.MaxTextSize <= 0 {
        return fmt.Errorf("app.max_text_size must be positive")
    }

    // Processing validation
    if cfg.Processing.MaxSentenceLength <= 0 {
        return fmt.Errorf("processing.max_sentence_length must be positive")
    }

    if len(cfg.Processing.SentenceDelimiters) == 0 {
        return fmt.Errorf("processing.sentence_delimiters cannot be empty")
    }

    // Rules validation
    for i, rule := range cfg.Rules.Atomic.RegexPatterns {
        if rule.ID == "" {
            return fmt.Errorf("rules.atomic.regex_patterns[%d].id cannot be empty", i)
        }
        if rule.Pattern == "" {
            return fmt.Errorf("rules.atomic.regex_patterns[%d].pattern cannot be empty", i)
        }
        if rule.Weight < 0 || rule.Weight > 1 {
            return fmt.Errorf("rules.atomic.regex_patterns[%d].weight must be between 0 and 1", i)
        }
        if rule.Level < 1 || rule.Level > 5 {
            return fmt.Errorf("rules.atomic.regex_patterns[%d].level must be between 1 and 5", i)
        }
    }

    for i, list := range cfg.Rules.Atomic.KeywordLists {
        if list.ID == "" {
            return fmt.Errorf("rules.atomic.keyword_lists[%d].id cannot be empty", i)
        }
        if len(list.Keywords) == 0 {
            return fmt.Errorf("rules.atomic.keyword_lists[%d].keywords cannot be empty", i)
        }
        if list.Weight < 0 || list.Weight > 1 {
            return fmt.Errorf("rules.atomic.keyword_lists[%d].weight must be between 0 and 1", i)
        }
        if list.Level < 1 || list.Level > 5 {
            return fmt.Errorf("rules.atomic.keyword_lists[%d].level must be between 1 and 5", i)
        }
    }

    // Composite validation
    if cfg.Rules.Composite.ProximityWindow <= 0 {
        return fmt.Errorf("rules.composite.proximity_window must be positive")
    }
    if cfg.Rules.Composite.MinDensity < 0 {
        return fmt.Errorf("rules.composite.min_density cannot be negative")
    }
    if cfg.Rules.Composite.MaxSpan <= 0 {
        return fmt.Errorf("rules.composite.max_span must be positive")
    }
    if cfg.Rules.Composite.MaxCandidates <= 0 {
        return fmt.Errorf("rules.composite.max_candidates must be positive")
    }

    // Semantic validation
    if len(cfg.Rules.Semantic.Networks) == 0 {
        return fmt.Errorf("rules.semantic.networks cannot be empty")
    }

    // Performance validation
    if cfg.Performance.MaxWorkers <= 0 {
        return fmt.Errorf("performance.max_workers must be positive")
    }
    if cfg.Performance.BufferSize <= 0 {
        return fmt.Errorf("performance.buffer_size must be positive")
    }

    return nil
}
```

### **pkg/config/defaults.go** (updated)
```go
package config

import "github.com/spf13/viper"

// setDefaults sets default configuration values
func setDefaults() {
    // App defaults
    viper.SetDefault("app.name", "Semantic Analyzer")
    viper.SetDefault("app.version", "1.0.0")
    viper.SetDefault("app.max_text_size", 1000000) // 1MB
    viper.SetDefault("app.log_level", "info")
    viper.SetDefault("app.enable_debug", false)

    // Determinism defaults
    viper.SetDefault("determinism.base_seed", 42)
    viper.SetDefault("determinism.enable_stable_sort", true)
    viper.SetDefault("determinism.hash_algorithm", "sha256")

    // Processing defaults
    viper.SetDefault("processing.unicode_normalization", "NFC")
    viper.SetDefault("processing.enable_lowercase", true)
    viper.SetDefault("processing.sentence_delimiters", []string{".", "!", "?", ";", ":"})
    viper.SetDefault("processing.preserve_whitespace", false)
    viper.SetDefault("processing.max_sentence_length", 1000)
    viper.SetDefault("processing.remove_punctuation", false)
    viper.SetDefault("processing.stop_words", []string{
        "the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for",
        "of", "with", "by", "is", "are", "was", "were", "be", "been", "being",
    })

    // Rules defaults
    viper.SetDefault("rules.atomic.regex_patterns", []map[string]interface{}{
        {
            "id":      "email_pattern",
            "pattern": `\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b`,
            "weight":  0.9,
            "type":    "CONTACT",
            "level":   1,
            "name":    "Email Address",
        },
        {
            "id":      "url_pattern",
            "pattern": `https?://[^\s]+|www\.[^\s]+`,
            "weight":  0.8,
            "type":    "URL",
            "level":   1,
            "name":    "URL",
        },
    })

    viper.SetDefault("rules.atomic.keyword_lists", []map[string]interface{}{
        {
            "id":            "important_terms",
            "keywords":      []string{"urgent", "important", "critical", "priority", "immediate"},
            "weight":        0.6,
            "type":          "PRIORITY",
            "level":         1,
            "case_sensitive": false,
            "name":          "Important Terms",
        },
        {
            "id":            "action_items",
            "keywords":      []string{"action", "todo", "task", "follow up", "next steps"},
            "weight":        0.5,
            "type":          "ACTION",
            "level":         1,
            "case_sensitive": false,
            "name":          "Action Items",
        },
    })

    // Composite defaults
    viper.SetDefault("rules.composite.proximity_window", 3)
    viper.SetDefault("rules.composite.min_density", 0.3)
    viper.SetDefault("rules.composite.max_span", 500)
    viper.SetDefault("rules.composite.max_candidates", 10)
    viper.SetDefault("rules.composite.selection_weights", map[string]float64{
        "marker_count":    0.4,
        "density":         0.3,
        "span_compactness": 0.2,
        "type_diversity":   0.1,
    })
    viper.SetDefault("rules.composite.type_weights", map[string]float64{
        "CONTACT":  1.0,
        "PRIORITY": 0.8,
        "ACTION":   0.6,
        "URL":      0.5,
    })

    // Semantic defaults
    viper.SetDefault("rules.semantic.ner.person_titles", []string{
        "Mr.", "Ms.", "Mrs.", "Dr.", "Prof.", "Rev.",
    })
    viper.SetDefault("rules.semantic.ner.organization_suffixes", []string{
        "Inc.", "Corp.", "Ltd.", "LLC", "GmbH", "Co.",
    })
    viper.SetDefault("rules.semantic.ner.location_patterns", []string{
        `\b[A-Z][a-z]+(?:[ -][A-Z][a-z]+)*\b`, // Capitalized words
    })
    viper.SetDefault("rules.semantic.ner.location_keywords", []string{
        "street", "avenue", "road", "boulevard", "city", "town", "state", "country",
    })
    
    viper.SetDefault("rules.semantic.ner.person_patterns", []map[string]interface{}{
        {
            "id":      "person_name",
            "pattern": `\b(?:Mr\.|Ms\.|Mrs\.|Dr\.|Prof\.)\s+[A-Z][a-z]+\s+[A-Z][a-z]+\b`,
            "weight":  0.9,
            "type":    "PERSON",
            "level":   3,
            "name":    "Person Name",
        },
    })
    
    viper.SetDefault("rules.semantic.ner.organization_patterns", []map[string]interface{}{
        {
            "id":      "organization_name",
            "pattern": `\b[A-Z][A-Za-z0-9&\.\s]+(?:Inc\.|Corp\.|Ltd\.|LLC|GmbH|Co\.)\b`,
            "weight":  0.8,
            "type":    "ORGANIZATION",
            "level":   3,
            "name":    "Organization Name",
        },
    })

    viper.SetDefault("rules.semantic.networks", map[string][]string{
        "technology": {"software", "hardware", "algorithm", "database", "network", "server", "cloud"},
        "business":   {"revenue", "profit", "market", "strategy", "investment", "budget", "financial"},
        "project":    {"timeline", "deadline", "milestone", "deliverable", "requirement", "specification"},
        "contact":    {"email", "phone", "address", "contact", "call", "message"},
    })
    
    viper.SetDefault("rules.semantic.proximity_weights", map[string]float64{
        "network_match":   0.5,
        "type_similarity": 0.3,
        "context_overlap": 0.2,
    })
    
    viper.SetDefault("rules.semantic.logical_rules", []map[string]interface{}{
        {
            "id":         "contact_with_action",
            "expression": "(ENTITY_TYPE:PERSON AND NEAR(ENTITY_TYPE:CONTACT, 3)) OR (MARKER_TYPE:PRIORITY AND MARKER_TYPE:ACTION)",
            "type":       "COMPLEX_CONTACT",
            "level":      4,
            "weight":     0.9,
            "output_type": "COMPOSITE",
        },
        {
            "id":         "urgent_contact",
            "expression": "MARKER_TYPE:PRIORITY AND NEAR(ENTITY_TYPE:CONTACT, 2)",
            "type":       "URGENT_CONTACT",
            "level":      4,
            "weight":     0.8,
            "output_type": "COMPOSITE",
        },
    })

    // Performance defaults
    viper.SetDefault("performance.max_workers", 10)
    viper.SetDefault("performance.buffer_size", 1000)
    viper.SetDefault("performance.enable_memory_pool", true)
    viper.SetDefault("performance.regex_compilation_cache_size", 100)
    viper.SetDefault("performance.enable_parallel_processing", true)

    // Output defaults
    viper.SetDefault("output.enable_audit_trail", true)
    viper.SetDefault("output.pretty_print_json", false)
    viper.SetDefault("output.include_confidence_scores", true)
    viper.SetDefault("output.timestamp_format", "2006-01-02T15:04:05Z07:00")
    viper.SetDefault("output.output_directory", "./results")
    viper.SetDefault("output.enable_compression", false)
    viper.SetDefault("output.max_markers_per_file", 1000)
}
