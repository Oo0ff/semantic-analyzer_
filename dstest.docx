```yaml
# Complete Configuration for Phases 1-8

app:
  name: "Deterministic Semantic Analyzer"
  version: "1.0.0"
  max_text_size: 1000000
  log_level: "info"
  enable_debug: false

determinism:
  base_seed: 42
  enable_stable_sort: true
  hash_algorithm: "sha256"

processing:
  unicode_normalization: "NFC"
  enable_lowercase: true
  sentence_delimiters: [".", "!", "?", ";", ":"]
  preserve_whitespace: false
  max_sentence_length: 1000
  remove_punctuation: false
  stop_words: ["the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for", "of", "with", "by", "is", "are", "was", "were", "be", "been", "being"]

rules:
  atomic:
    regex_patterns:
      - id: "email_pattern"
        pattern: "\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b"
        weight: 0.9
        type: "CONTACT"
        level: 1
        name: "Email Address"
      
      - id: "url_pattern"
        pattern: "https?://[^\s]+|www\.[^\s]+"
        weight: 0.8
        type: "URL"
        level: 1
        name: "URL"
      
      - id: "phone_pattern"
        pattern: "\b(\+\d{1,3}[-.]?)?\(?\d{3}\)?[-.]?\d{3}[-.]?\d{4}\b"
        weight: 0.85
        type: "CONTACT"
        level: 1
        name: "Phone Number"
      
      - id: "date_pattern"
        pattern: "\b\d{1,2}[/-]\d{1,2}[/-]\d{2,4}\b|\b(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]* \d{1,2},? \d{4}\b"
        weight: 0.7
        type: "DATE"
        level: 1
        name: "Date"

    keyword_lists:
      - id: "important_terms"
        keywords: ["urgent", "important", "critical", "priority", "immediate"]
        weight: 0.6
        type: "PRIORITY"
        level: 1
        case_sensitive: false
        name: "Important Terms"
      
      - id: "action_items"
        keywords: ["action", "todo", "task", "follow up", "next steps"]
        weight: 0.5
        type: "ACTION"
        level: 1
        case_sensitive: false
        name: "Action Items"

  composite:
    proximity_window: 3
    min_density: 0.3
    max_span: 500
    max_candidates: 10
    selection_weights:
      marker_count: 0.4
      density: 0.3
      span_compactness: 0.2
      type_diversity: 0.1
    type_weights:
      CONTACT: 1.0
      PRIORITY: 0.8
      ACTION: 0.6
      URL: 0.5

  semantic:
    ner:
      person_titles: ["Mr.", "Ms.", "Mrs.", "Dr.", "Prof.", "Rev."]
      organization_suffixes: ["Inc.", "Corp.", "Ltd.", "LLC", "GmbH", "Co."]
      location_patterns: ["\\b[A-Z][a-z]+(?:[ -][A-Z][a-z]+)*\\b"]
      location_keywords: ["street", "avenue", "road", "boulevard", "city", "town", "state", "country"]
      person_patterns:
        - id: "person_name"
          pattern: "\\b(?:Mr\\.|Ms\\.|Mrs\\.|Dr\\.|Prof\\.)\\s+[A-Z][a-z]+\\s+[A-Z][a-z]+\\b"
          weight: 0.9
          type: "PERSON"
          level: 3
          name: "Person Name"
      organization_patterns:
        - id: "organization_name"
          pattern: "\\b[A-Z][A-Za-z0-9&\\.\\s]+(?:Inc\\.|Corp\\.|Ltd\\.|LLC|GmbH|Co\\.)\\b"
          weight: 0.8
          type: "ORGANIZATION"
          level: 3
          name: "Organization Name"
    
    networks:
      technology: ["software", "hardware", "algorithm", "database", "network", "server", "cloud"]
      business: ["revenue", "profit", "market", "strategy", "investment", "budget", "financial"]
      project: ["timeline", "deadline", "milestone", "deliverable", "requirement", "specification"]
      contact: ["email", "phone", "address", "contact", "call", "message"]
    
    proximity_weights:
      network_match: 0.5
      type_similarity: 0.3
      context_overlap: 0.2
    
    logical_rules:
      - id: "contact_with_action"
        expression: "(ENTITY_TYPE:PERSON AND NEAR(ENTITY_TYPE:CONTACT, 3)) OR (MARKER_TYPE:PRIORITY AND MARKER_TYPE:ACTION)"
        type: "COMPLEX_CONTACT"
        level: 4
        weight: 0.9
        output_type: "COMPOSITE"
      
      - id: "urgent_contact"
        expression: "MARKER_TYPE:PRIORITY AND NEAR(ENTITY_TYPE:CONTACT, 2)"
        type: "URGENT_CONTACT"
        level: 4
        weight: 0.8
        output_type: "COMPOSITE"

# Phase 6: Post-processing Configuration
postprocessing:
  suppression_patterns:
    - pattern: ".*test.*@example\\.com"
      reason: "Test email pattern"
      weight: -1.0
    
    - pattern: "placeholder"
      reason: "Placeholder text"
      weight: -0.8
    
    - pattern: "lorem ipsum"
      reason: "Dummy text"
      weight: -1.0
  
  deduplication:
    overlap_threshold: 0.7
    merge_same_type: true
    max_gap_for_merge: 50
    enable_cross_level_dedup: false
  
  conflict_resolution:
    priority_weights:
      level: [0.4, 0.3, 0.2, 0.1, 0.05]  # Level 5 gets 0.4 weight, Level 1 gets 0.05
      confidence: 0.3
      span_length: 0.2
      rule_priority: 0.1
    
    hierarchy: [5, 4, 3, 2, 1]  # Level 5 has highest priority
  
  output_formatting:
    include_context: true
    context_sentences: 2
    include_paragraph: true
    max_context_chars: 500
    generate_deterministic_ids: true

# Phase 7: Quality Control Configuration
quality:
  confidence:
    min_threshold: 0.3
    review_threshold: 0.6
    warning_threshold: 0.8
    
    weights:
      rule_certainty: 0.4
      evidence_depth: 0.3
      context_coherence: 0.2
      conflict_history: 0.1
    
    bayesian:
      prior_probability: 0.5
      evidence_weight: 2.0
      conflict_penalty: 0.3
  
  audit:
    enable_trail: true
    max_events_per_marker: 100
    export_formats: ["json", "text"]
    include_decision_tree: true
    compress_audit_log: false
  
  reporting:
    formats: ["markdown", "html", "text"]
    sections: ["executive_summary", "key_findings", "rule_performance", "anomalies", "recommendations"]
    include_visualizations: false
    max_markers_per_section: 20

# Performance Configuration
performance:
  max_workers: 10
  buffer_size: 1000
  enable_memory_pool: true
  regex_compilation_cache_size: 100
  enable_parallel_processing: true
  
  # Pipeline optimization
  phase_timeout_seconds: 300
  max_memory_mb: 1024
  enable_circuit_breaker: true
  circuit_breaker_threshold: 5

# Output Configuration
output:
  enable_audit_trail: true
  pretty_print_json: false
  include_confidence_scores: true
  timestamp_format: "2006-01-02T15:04:05Z07:00"
  output_directory: "./results"
